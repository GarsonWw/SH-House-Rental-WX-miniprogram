/* app.wxss - 全局样式 */
page {
  background-color: #EFF8FB;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #111111;
  box-sizing: border-box;
}

/* Brand palette
   Soft sky: #EFF8FB
   Clear cyan: #28B8BC
   Light cyan surface: #DDF5F8
   Ink: #111111
   Muted text: #667A82
   Card: #FFFFFF
*/

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 通用卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 12rpx 36rpx rgba(51, 113, 125, 0.08);
}

/* 按钮样式 */
.btn-primary {
  background: #28B8BC;
  color: #FFFFFF;
  border-radius: 999rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 800;
  height: 88rpx;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 28rpx rgba(40, 184, 188, 0.22);
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: rgba(255,255,255,0.72);
  color: #111111;
  border-radius: 999rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.12);
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.btn-outline::after {
  border: none;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #E2F6F8;
  color: #111111;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.tag-blue {
  background: #DDF5F8;
  color: #111111;
}

.tag-green {
  background: #E6FAF2;
  color: #111111;
}

/* 价格样式 */
.price {
  color: #111111;
  font-weight: 700;
}

.price-number {
  font-size: 48rpx;
}

.price-unit {
  font-size: 24rpx;
  font-weight: 400;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: rgba(17, 17, 17, 0.08);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #667A82;
}

.empty-state text {
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #667A82;
  font-size: 26rpx;
}

/* 安全区域底部 */
.safe-bottom {
  height: env(safe-area-inset-bottom);
  height: constant(safe-area-inset-bottom);
}

/* Premium emphasis */
.price,
.price-number,
.price-unit,
.mini-price,
.result-price,
.fav-price,
.card-price,
.preview-price,
.preview-price-unit,
.stat-num,
.s-num {
  color: #111111;
}

.btn-primary,
.submit-btn,
.next-btn,
.contact-main,
.publish-btn,
.empty-action {
  letter-spacing: 1rpx;
}

button,
input,
textarea,
picker,
scroll-view,
view,
text {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

/* New visual language safety layer */
.submit-btn,
.next-btn,
.publish-btn,
.empty-action,
.contact-main,
.search-btn,
.edit-confirm,
.login-btn,
.modal-confirm,
.modal-copy-btn {
  background: #28B8BC !important;
  color: #FFFFFF !important;
  border-radius: 999rpx !important;
  border-color: #28B8BC !important;
  box-shadow: 0 14rpx 30rpx rgba(40, 184, 188, 0.22) !important;
}

.tag,
.chip,
.f-chip,
.sh-tag,
.r-tag,
.status-opt,
.tag-option,
.mode-pill,
.crowd-tag,
.round-btn {
  border-radius: 999rpx !important;
}

.price,
.price-number,
.price-unit,
.mini-price,
.result-price,
.fav-price,
.card-price,
.preview-price,
.preview-price-unit,
.stat-num,
.s-num,
.count-num {
  color: #111111 !important;
}

.card,
.form-card,
.detail-card,
.info-card,
.landlord-card,
.entry-card,
.menu-card,
.brand-trust-card,
.platform-card,
.trust-card,
.section-block,
.result-card,
.fav-card,
.house-card {
  border-radius: 34rpx;
}
