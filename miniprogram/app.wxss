/* app.wxss - 全局样式 */
page {
  background-color: #F4F1EA;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #27241F;
  box-sizing: border-box;
}

/* Brand palette
   Deep navy: #0F2F4A
   Champagne gold: #B8894D
   Porcelain background: #F4F1EA
   Ivory card: #FFFFFF
   Ink text: #171512 / #4F4A43 / #7A746B
*/

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 通用卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(15, 47, 74, 0.06);
  box-shadow: 0 8rpx 28rpx rgba(15, 47, 74, 0.08);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #0F2F4A, #1C4966);
  color: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(15, 47, 74, 0.24);
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: rgba(255,255,255,0.72);
  color: #0F2F4A;
  border-radius: 50rpx;
  border: 2rpx solid #0F2F4A;
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.btn-outline::after {
  border: none;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  background: #F4EFE6;
  color: #8A6A3D;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.tag-blue {
  background: #EAF1F6;
  color: #2F6F95;
}

.tag-green {
  background: #EAF6EF;
  color: #2E7D5B;
}

/* 价格样式 */
.price {
  color: #B8894D;
  font-weight: 700;
}

.price-number {
  font-size: 48rpx;
}

.price-unit {
  font-size: 24rpx;
  font-weight: 400;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #E6E0D8;
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #7A746B;
}

.empty-state text {
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #7A746B;
  font-size: 26rpx;
}

/* 安全区域底部 */
.safe-bottom {
  height: env(safe-area-inset-bottom);
  height: constant(safe-area-inset-bottom);
}

/* Premium emphasis */
.price,
.price-number,
.price-unit,
.mini-price,
.result-price,
.fav-price,
.card-price,
.preview-price,
.preview-price-unit,
.stat-num,
.s-num {
  color: #B8894D;
}

.btn-primary,
.submit-btn,
.next-btn,
.contact-main,
.publish-btn,
.empty-action {
  letter-spacing: 1rpx;
}
