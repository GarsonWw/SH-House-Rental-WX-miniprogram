/* app.wxss - 全局样式 */
page {
  background-color: #EFF8FB;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #111111;
  box-sizing: border-box;
}

.tab-bottom-space {
  height: calc(176rpx + env(safe-area-inset-bottom));
}

/* Brand palette
   Soft sky: #EFF8FB
   Clear cyan: #28B8BC
   Light cyan surface: #DDF5F8
   Ink: #111111
   Muted text: #667A82
   Card: #FFFFFF
*/

/* Unified product icons */
.icon-token {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  background: #DDF5F8;
  color: #28B8BC;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-token-round {
  border-radius: 50%;
}

.icon-token-ink {
  background: #111111;
  color: #FFFFFF;
}

.icon-token-light {
  background: rgba(255, 255, 255, 0.22);
  color: #111111;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
}

.icon-token-soft {
  background: #F5FCFD;
  color: #28B8BC;
  border: 1rpx solid rgba(40, 184, 188, 0.18);
}

.ui-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  flex-shrink: 0;
  color: inherit;
}

.ui-icon::before,
.ui-icon::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.ui-icon-home::before {
  left: 10rpx;
  right: 10rpx;
  bottom: 8rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 4rpx 4rpx 7rpx 7rpx;
}

.ui-icon-home::after {
  left: 12rpx;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  border-radius: 4rpx 0 0 0;
  transform: rotate(45deg);
}

.ui-icon-route::before {
  left: 6rpx;
  right: 6rpx;
  top: 20rpx;
  border-top: 4rpx solid currentColor;
  border-radius: 999rpx;
}

.ui-icon-route::after {
  left: 6rpx;
  top: 9rpx;
  width: 32rpx;
  height: 26rpx;
  border: 4rpx solid currentColor;
  border-left-color: transparent;
  border-bottom-color: transparent;
  border-radius: 50%;
  transform: rotate(28deg);
}

.ui-icon-chat::before {
  left: 6rpx;
  right: 6rpx;
  top: 8rpx;
  height: 26rpx;
  border: 4rpx solid currentColor;
  border-radius: 15rpx;
}

.ui-icon-chat::after {
  left: 14rpx;
  bottom: 5rpx;
  width: 12rpx;
  height: 12rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: skew(-18deg) rotate(-18deg);
}

.ui-icon-map::before {
  left: 7rpx;
  right: 7rpx;
  top: 9rpx;
  height: 27rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
}

.ui-icon-map::after {
  left: 19rpx;
  top: 11rpx;
  width: 6rpx;
  height: 23rpx;
  border-left: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
  opacity: 0.55;
}

.ui-icon-user::before {
  left: 14rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.ui-icon-user::after {
  left: 9rpx;
  right: 9rpx;
  bottom: 7rpx;
  height: 16rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 18rpx 18rpx 0 0;
}

.ui-icon-search::before {
  left: 7rpx;
  top: 7rpx;
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.ui-icon-search::after {
  left: 29rpx;
  top: 29rpx;
  width: 14rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.ui-icon-bookmark::before {
  left: 12rpx;
  top: 7rpx;
  width: 20rpx;
  height: 31rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx 6rpx 4rpx 4rpx;
}

.ui-icon-bookmark::after {
  left: 18rpx;
  bottom: 5rpx;
  width: 10rpx;
  height: 10rpx;
  background: #DDF5F8;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
}

.icon-token-ink .ui-icon-bookmark::after,
.icon-token-light .ui-icon-bookmark::after {
  background: transparent;
}

.ui-icon-info::before {
  left: 7rpx;
  top: 7rpx;
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.ui-icon-info::after {
  left: 20rpx;
  top: 18rpx;
  width: 4rpx;
  height: 13rpx;
  background: currentColor;
  border-radius: 999rpx;
  box-shadow: 0 -8rpx 0 currentColor;
}

.ui-icon-shield::before {
  left: 9rpx;
  top: 6rpx;
  width: 26rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-radius: 12rpx 12rpx 16rpx 16rpx;
}

.ui-icon-shield::after {
  left: 16rpx;
  top: 19rpx;
  width: 13rpx;
  height: 8rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(-45deg);
}

.ui-icon-phone::before {
  left: 12rpx;
  top: 9rpx;
  width: 20rpx;
  height: 26rpx;
  border: 4rpx solid currentColor;
  border-top-width: 7rpx;
  border-bottom-width: 7rpx;
  border-radius: 9rpx;
  transform: rotate(-24deg);
}

.ui-icon-phone::after {
  left: 23rpx;
  top: 26rpx;
  width: 8rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 999rpx;
  transform: rotate(-24deg);
}

.ui-icon-plus::before,
.ui-icon-plus::after {
  left: 10rpx;
  top: 20rpx;
  width: 24rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 999rpx;
}

.ui-icon-plus::after {
  transform: rotate(90deg);
}

.ui-icon-share::before {
  left: 8rpx;
  top: 20rpx;
  width: 26rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 999rpx;
  transform: rotate(-28deg);
}

.ui-icon-share::after {
  right: 8rpx;
  top: 10rpx;
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid currentColor;
  border-right: 4rpx solid currentColor;
  transform: rotate(45deg);
  border-radius: 2rpx;
}

.ui-icon-trash::before {
  left: 12rpx;
  top: 15rpx;
  width: 20rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 6rpx 6rpx;
}

.ui-icon-trash::after {
  left: 10rpx;
  top: 8rpx;
  width: 24rpx;
  height: 8rpx;
  border-top: 4rpx solid currentColor;
  border-radius: 999rpx;
  box-shadow: 7rpx -4rpx 0 -2rpx currentColor;
}

.ui-icon-compass::before {
  left: 7rpx;
  top: 7rpx;
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.ui-icon-compass::after {
  left: 17rpx;
  top: 10rpx;
  width: 0;
  height: 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  border-bottom: 23rpx solid currentColor;
  transform: rotate(38deg);
}

