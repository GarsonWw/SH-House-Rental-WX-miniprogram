.consult-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 17, 17, 0.45);
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

.consult-card {
  width: 100%;
  max-width: 620rpx;
  background: #ffffff;
  border-radius: 48rpx;
  padding: 48rpx 44rpx 40rpx;
  text-align: center;
  box-shadow: 0 32rpx 96rpx rgba(51, 113, 125, 0.15);
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-sizing: border-box;
}

.consult-badge {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 700;
  color: #8a6a3d;
  background: rgba(138, 106, 61, 0.1);
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  margin-bottom: 24rpx;
}

.consult-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111111;
  margin-bottom: 12rpx;
}

.consult-sub {
  font-size: 22rpx;
  color: #667a82;
  line-height: 1.55;
}

.consult-sub-last {
  margin-bottom: 24rpx;
}

.consult-qr-box {
  width: 480rpx;
  height: 480rpx;
  margin: 24rpx auto 20rpx;
  border-radius: 32rpx;
  background: #f5fcfd;
  border: 1rpx dashed rgba(40, 184, 188, 0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 10rpx 8rpx;
  box-sizing: border-box;
}

.consult-qr-image-wrap {
  flex: 1;
  width: 100%;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.consult-qr-image {
  width: 100%;
  height: 100%;
}

.consult-qr-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #667a82;
  font-weight: 600;
  line-height: 1.4;
  margin-top: 6rpx;
}

.consult-mentor {
  font-size: 22rpx;
  color: #667a82;
  margin-bottom: 28rpx;
}

.consult-mentor-strong {
  color: #28b8bc;
  font-weight: 700;
}

.consult-btn-primary {
  width: 100%;
  height: 88rpx;
  border-radius: 999rpx;
  background: #28b8bc;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(40, 184, 188, 0.28);
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.consult-btn-ghost {
  font-size: 24rpx;
  color: #8a9aa1;
  padding: 12rpx 0 4rpx;
}
