<!-- components/house-card/house-card.wxml -->
<view class="house-card" bindtap="onTap">
  <!-- 封面图片区 -->
  <view class="card-image">
    <image 
      wx:if="{{house.images && house.images.length > 0}}"
      src="{{house.images[0]}}" 
      class="cover-img" 
      mode="aspectFill"
    />
    <view wx:else class="cover-placeholder">
      <view class="placeholder-icon ui-icon ui-icon-home"></view>
      <text class="placeholder-text">{{house.neighborhood}}</text>
    </view>
    <!-- 可用状态标签 -->
    <view class="status-badge available" wx:if="{{house.available}}">
      可租
    </view>
    <!-- 房型标签 -->
    <view class="room-type-badge">{{house.roomType}}</view>
  </view>

  <!-- 信息区 -->
  <view class="card-content">
    <view class="card-main-row">
      <view class="card-main-info">
        <!-- 标题 -->
        <text class="house-title">{{house.title}}</text>

        <!-- 小区和地区 -->
        <view class="location-row">
          <text class="neighborhood">{{house.neighborhood}}</text>
          <text class="district">{{house.district}}</text>
        </view>

        <!-- 房屋信息 -->
        <view class="house-info-row">
          <text class="info-item">{{house.area}}㎡</text>
          <text class="info-divider">·</text>
          <text class="info-item">{{house.floor}}</text>
          <text class="info-divider">·</text>
          <text class="info-item">{{house.orientation}}</text>
          <text class="info-divider">·</text>
          <text class="info-item">{{house.decoration}}</text>
        </view>
      </view>

      <view class="card-side-info">
        <view class="price-section">
          <text class="price-number">{{house.price}}</text>
          <text class="price-unit">元/月</text>
        </view>
        <text class="side-status" wx:if="{{house.available}}">可预约</text>
      </view>
    </view>

    <!-- 标签 -->
    <view class="tags-row" wx:if="{{house.tags && house.tags.length > 0}}">
      <text class="tag" wx:for="{{house.tags}}" wx:key="index">{{item}}</text>
    </view>

    <!-- 底部：价格和联系 -->
    <view class="card-footer">
      <view class="contact-section" wx:if="{{showContact && house.available}}">
        <view 
          class="contact-btn phone-btn" 
          catchtap="onPhoneCall"
          data-phone="{{house.landlordPhone}}"
        >
          <text class="phone-symbol">☎</text>
          <text>电话</text>
        </view>
        <button
          class="contact-btn wechat-btn"
          open-type="contact"
          show-message-card="true"
          send-message-title="{{house.neighborhood}}在线咨询"
          send-message-path="/pages/detail/detail?id={{house.id}}"
          session-from="house-card"
          hover-class="none"
        >
          <view class="contact-icon ui-icon ui-icon-chat"></view>
          <text>咨询</text>
        </button>
      </view>

      <view class="meta-info" wx:else>
        <text class="view-count">浏览 {{house.viewCount || 0}}</text>
        <text class="create-time">{{house.createTime}}</text>
      </view>
    </view>
  </view>
</view>
