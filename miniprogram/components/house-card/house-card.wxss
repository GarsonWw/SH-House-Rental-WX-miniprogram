/* components/house-card/house-card.wxss */
.house-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 图片区 */
.card-image {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #E5F5F7, #CFEAED);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  color: #28B8BC;
  transform: scale(1.35);
}

.placeholder-text {
  font-size: 26rpx;
  color: #0F2F4A;
  margin-top: 12rpx;
  font-weight: 500;
}

.status-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 18rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.available {
  background: #2E7D5B;
}

.unavailable {
  background: #D64545;
}

.room-type-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 18rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: rgba(0, 0, 0, 0.45);
}

/* 内容区 */
.card-content {
  padding: 20rpx 24rpx 20rpx;
}

.card-main-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-main-info {
  flex: 1;
  min-width: 0;
}

.card-side-info {
  flex: 0 0 178rpx;
  min-height: 116rpx;
  padding: 8rpx 0 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.house-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #171512;
  display: block;
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.location-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.neighborhood {
  font-size: 26rpx;
  color: #0F2F4A;
  font-weight: 500;
}

.district {
  font-size: 24rpx;
  color: #7A746B;
  margin-left: 12rpx;
}

.house-info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
}

.info-item {
  font-size: 24rpx;
  color: #4F4A43;
}

.info-divider {
  color: #D8D1C7;
  margin: 0 10rpx;
  font-size: 24rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  background: #E2F6F8;
  color: #0F2F4A;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

/* 底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: 18rpx;
  border-top: 1rpx solid #F4F1EA;
}

.price-section {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  flex-shrink: 0;
  min-width: 0;
}

.price-number {
  font-size: 42rpx;
  font-weight: 900;
  color: #0F2F4A;
  line-height: 1;
}

.price-unit {
  font-size: 20rpx;
  color: #0F2F4A;
  margin-left: 4rpx;
  white-space: nowrap;
}

.side-status {
  margin-top: 14rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #E2F6F8;
  color: #111111;
  font-size: 21rpx;
  font-weight: 800;
  white-space: nowrap;
}

.contact-section {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  width: 100%;
  min-width: 0;
  margin-left: 0;
  gap: 14rpx;
}

.contact-btn {
  min-width: 0;
  height: 76rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
  padding: 0;
  border: 0;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
  margin: 0;
  color: #111111;
  white-space: nowrap;
}

.contact-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 8rpx;
  transform: scale(.62);
}

.phone-symbol {
  margin-right: 8rpx;
  color: #111111;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.contact-btn text {
  display: block;
  line-height: 1;
}

.contact-btn::after {
  border: 0;
}

.phone-btn {
  background: #F2F9FA;
  width: 156rpx;
  flex: 0 0 156rpx;
}

.wechat-btn {
  background: #EAF6EF;
  flex: 1;
  min-width: 0;
  margin-left: 0;
}

.meta-info {
  display: flex;
  align-items: center;
}

.meta-info .view-count {
  margin-right: 16rpx;
}

.view-count, .create-time {
  font-size: 22rpx;
  color: #A8A196;
}

/* 2026 UI refresh */
.house-card {
  border-radius: 34rpx;
  background: #FFFFFF;
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
  border: 1rpx solid rgba(17, 17, 17, 0.05);
}

.card-image {
  height: 300rpx;
}

.cover-placeholder {
  background: linear-gradient(135deg, #DDF5F8, #F8FEFF);
}

.placeholder-text,
.neighborhood,
.price-number,
.price-unit {
  color: #111111;
}

.status-badge,
.room-type-badge,
.contact-btn {
  border-radius: 999rpx;
}

.available {
  background: #2E7D5B;
}

.unavailable,
.room-type-badge {
  background: rgba(17, 17, 17, 0.72);
}

.unavailable {
  background: #D64545;
}

.house-title {
  color: #111111;
  font-weight: 800;
}

.district,
.info-item,
.view-count,
.create-time {
  color: #667A82;
}

.tag {
  background: #E2F6F8;
  color: #111111;
  border-radius: 999rpx;
}

.card-footer {
  border-top: 1rpx solid rgba(17, 17, 17, 0.06);
}

.phone-btn,
.wechat-btn {
  background: #DDF5F8;
}

.phone-btn {
  color: #111111;
  box-shadow: inset 0 0 0 1rpx rgba(40, 184, 188, 0.16);
}

.wechat-btn {
  background: #28B8BC;
  color: #FFFFFF;
  box-shadow: 0 10rpx 24rpx rgba(40, 184, 188, 0.22);
}
