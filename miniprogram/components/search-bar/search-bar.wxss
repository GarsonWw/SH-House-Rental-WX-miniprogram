/* components/search-bar/search-bar.wxss */
.search-bar {
  display: flex;
  align-items: center;
  background: #F8F6F1;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  height: 80rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #27241F;
  height: 100%;
}

.search-placeholder {
  color: #A8A196;
  font-size: 28rpx;
}

.clear-btn {
  font-size: 28rpx;
  color: #A8A196;
  padding: 0 12rpx;
  flex-shrink: 0;
}

.search-btn {
  font-size: 26rpx;
  color: #0F2F4A;
  font-weight: 600;
  flex-shrink: 0;
  padding-left: 12rpx;
  border-left: 1rpx solid #E6E0D8;
}

/* 2026 UI refresh */
.search-bar {
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 12rpx 28rpx rgba(39, 122, 139, 0.08);
}

.search-input,
.search-btn {
  color: #111111;
}

.search-placeholder,
.clear-btn {
  color: #8A9AA1;
}

.search-btn {
  border-left-color: rgba(17, 17, 17, 0.08);
}
