<view class="tab-shell">
  <view class="tab-bar">
    <view
      class="tab-item {{selected === index ? 'tab-item-active' : ''}}"
      wx:for="{{list}}"
      wx:key="pagePath"
      data-index="{{index}}"
      catchtap="onSwitchTab"
    >
      <text class="tab-text">{{item.text}}</text>
      <view class="active-line" wx:if="{{selected === index}}"></view>
    </view>
  </view>
</view>
