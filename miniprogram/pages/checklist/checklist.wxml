<!-- pages/checklist/checklist.wxml -->
<view class="page-bg">

  <!-- 院校选择 -->
  <view wx:if="{{!activeUni}}" class="school-select-page">
    <view class="select-hero">
      <text class="select-icon">🎓</text>
      <text class="select-title">选择你的入学院校</text>
      <text class="select-sub">选定后，后续只展示该院校对应的入学准备清单。</text>
    </view>

    <view class="school-card-list">
      <view
        class="school-card {{item.key}}-school-card"
        wx:for="{{universities}}"
        wx:key="key"
        bindtap="onSelectUni"
        data-uni="{{item.key}}"
      >
        <view class="school-logo {{item.key}}-logo"><text>{{item.logo}}</text></view>
        <view class="school-info">
          <text class="school-name">{{item.name}}</text>
          <text class="school-code">{{item.code}}</text>
          <text class="school-desc">{{item.desc}}</text>
        </view>
        <text class="school-arr">›</text>
      </view>
    </view>
  </view>

  <!-- 当前院校清单 -->
  <view wx:else class="checklist-page">
    <view class="school-switch-row">
      <view>
        <text class="current-label">当前院校</text>
        <text class="current-school">{{currentSchoolName}} {{currentSchoolCode}}</text>
      </view>
      <view class="change-school-btn" bindtap="onChangeSchool">切换学校</view>
    </view>

    <view class="prog-card {{currentTheme}}-prog-card">
      <view class="prog-header">
        <view>
          <text class="prog-title">入学准备进度</text>
          <text class="prog-school">{{currentSchoolName}} {{currentSchoolCode}}</text>
        </view>
        <text class="prog-pct">{{currentProgress}}%</text>
      </view>
      <view class="prog-bar-bg">
        <view class="prog-bar-fill {{currentTheme}}-fill" style="width:{{currentProgress}}%"></view>
      </view>
      <text class="prog-done">已完成 {{currentDone}} / {{currentList.length}} 项</text>
    </view>

    <view class="list-card">
      <block wx:for="{{currentList}}" wx:key="id">
        <view
          wx:if="{{index === 0 || currentList[index-1].category !== item.category}}"
          class="cat-title {{currentTheme}}-cat"
        >{{item.category}}</view>
        <view
          class="check-item {{item.checked ? 'item-done' : ''}}"
          bindtap="onCheckItem"
          data-id="{{item.id}}"
        >
          <view class="check-box {{item.checked ? currentBoxClass : ''}}">
            <text wx:if="{{item.checked}}" class="tick">✓</text>
          </view>
          <text class="check-text">{{item.text}}</text>
        </view>
      </block>
    </view>

    <view class="reset-row">
      <view class="reset-btn {{currentTheme}}-reset" bindtap="onResetChecklist">重置全部勾选</view>
    </view>
  </view>

  <view style="height: 80rpx;"></view>
</view>
