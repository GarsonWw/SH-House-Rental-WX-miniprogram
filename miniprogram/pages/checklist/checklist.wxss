/* pages/checklist/checklist.wxss */
.page-bg { background: #F5F6FA; min-height: 100vh; }

/* ── 院校选择 ── */
.school-select-page { padding: 56rpx 24rpx 0; }
.select-hero {
  display: flex; flex-direction: column; align-items: center;
  text-align: center; margin-bottom: 36rpx;
}
.select-icon { font-size: 84rpx; margin-bottom: 12rpx; }
.select-title { font-size: 40rpx; font-weight: 800; color: #1A1A1A; }
.select-sub {
  font-size: 26rpx; color: #777; line-height: 1.6;
  margin-top: 12rpx; max-width: 620rpx;
}
.school-card-list { display: flex; flex-direction: column; gap: 20rpx; }
.school-card {
  background: #FFF; border-radius: 20rpx; padding: 28rpx;
  display: flex; align-items: center;
  box-shadow: 0 4rpx 18rpx rgba(0,0,0,0.06);
  border: 2rpx solid transparent;
}
.hkust-school-card { border-color: #DDEBFF; }
.hku-school-card { border-color: #DDF4E5; }
.school-logo {
  width: 80rpx; height: 80rpx; border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 900; color: #FFF;
  margin-right: 22rpx; flex-shrink: 0;
}
.hkust-logo { background: linear-gradient(135deg, #003566, #0066CC); }
.hku-logo   { background: linear-gradient(135deg, #007A33, #00B050); }
.school-info { flex: 1; display: flex; flex-direction: column; }
.school-name { font-size: 30rpx; font-weight: 800; color: #1A1A1A; }
.school-code { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.school-desc { font-size: 24rpx; color: #666; line-height: 1.5; margin-top: 12rpx; }
.school-arr { font-size: 44rpx; color: #CCC; margin-left: 18rpx; }

/* ── 清单页 ── */
.checklist-page { padding: 24rpx 24rpx 0; }

.school-switch-row {
  background: #FFF; border-radius: 18rpx; padding: 22rpx 24rpx;
  margin-bottom: 20rpx; display: flex; align-items: center; justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.current-label { font-size: 22rpx; color: #999; display: block; margin-bottom: 4rpx; }
.current-school { font-size: 30rpx; font-weight: 800; color: #1A1A1A; display: block; }
.change-school-btn {
  font-size: 24rpx; color: #2B6FD9; background: #F0F4FF;
  padding: 12rpx 22rpx; border-radius: 50rpx; flex-shrink: 0;
}

/* 进度卡片 */
.prog-card {
  border-radius: 20rpx; padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}
.hkust-prog-card { background: linear-gradient(135deg, #003566, #0055AA); }
.hku-prog-card   { background: linear-gradient(135deg, #005C26, #007A33); }

.prog-header {
  display: flex; justify-content: space-between;
  align-items: flex-start; margin-bottom: 20rpx;
}
.prog-title  { font-size: 22rpx; color: rgba(255,255,255,0.75); display: block; }
.prog-school { font-size: 30rpx; font-weight: 700; color: #FFF; margin-top: 4rpx; display: block; }
.prog-pct    { font-size: 56rpx; font-weight: 900; color: #FFF; line-height: 1; }

.prog-bar-bg {
  background: rgba(255,255,255,0.25); height: 12rpx;
  border-radius: 6rpx; overflow: hidden; margin-bottom: 14rpx;
}
.prog-bar-fill { height: 12rpx; border-radius: 6rpx; transition: width 0.4s; }
.hkust-fill { background: linear-gradient(90deg, #70B3FF, #FFFFFF); }
.hku-fill   { background: linear-gradient(90deg, #7DE09A, #FFFFFF); }

.prog-done { font-size: 22rpx; color: rgba(255,255,255,0.8); }

/* 清单列表卡片 */
.list-card {
  background: #FFF; border-radius: 20rpx;
  overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.cat-title {
  font-size: 22rpx; font-weight: 700; letter-spacing: 2rpx;
  padding: 24rpx 28rpx 12rpx;
}
.hkust-cat { color: #0066CC; }
.hku-cat   { color: #007A33; }

.check-item {
  display: flex; align-items: center;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #F8F8F8;
}
.check-item.item-done .check-text {
  color: #BBBBBB; text-decoration: line-through;
}

.check-box {
  width: 44rpx; height: 44rpx; border-radius: 50%;
  border: 3rpx solid #DDDDDD;
  display: flex; align-items: center; justify-content: center;
  margin-right: 18rpx; flex-shrink: 0;
  transition: all 0.2s;
}
.box-hkust { background: #0066CC; border-color: #0066CC; }
.box-hku   { background: #007A33; border-color: #007A33; }

.tick { font-size: 24rpx; color: #FFF; font-weight: 800; }
.check-text { font-size: 26rpx; color: #333; flex: 1; line-height: 1.6; }

/* 重置行 */
.reset-row { display: flex; justify-content: center; margin: 24rpx 0; }
.reset-btn {
  font-size: 24rpx; padding: 14rpx 48rpx;
  border-radius: 50rpx; border: 1rpx solid;
}
.hkust-reset { color: #0066CC; border-color: #0066CC; background: #EAF2FF; }
.hku-reset   { color: #007A33; border-color: #007A33; background: #E6F9ED; }
