<!-- pages/detail/detail.wxml -->
<view class="page-container" wx:if="{{house}}">

  <!-- 大图展示 -->
  <view class="image-section hero-image-section">
    <swiper
      wx:if="{{house.images && house.images.length > 0}}"
      class="image-swiper"
      indicator-dots
      autoplay
      circular
    >
      <swiper-item wx:for="{{house.images}}" wx:key="index">
        <image src="{{item}}" class="house-img" mode="aspectFill" />
      </swiper-item>
    </swiper>
    <view wx:else class="image-placeholder">
      <view class="placeholder-mark ui-icon ui-icon-home"></view>
      <text class="placeholder-name">{{house.neighborhood}}</text>
    </view>
    <view class="image-overlay">
      <view class="status-tag available" wx:if="{{house.available}}">
        可租
      </view>
    </view>
  </view>

  <!-- 小区名称和核心信息 -->
  <view class="intro-card">
    <view class="intro-head">
      <view class="intro-copy">
        <text class="intro-neighborhood">{{house.neighborhood}}</text>
      </view>
      <view class="favorite-btn {{isFavorited ? 'favorited' : ''}}" bindtap="onFavorite">
        <view class="favorite-heart"></view>
      </view>
    </view>
    <text class="house-title">{{house.title}}</text>
    <view class="intro-bottom">
      <view class="price-block">
        <text class="price-num">{{house.price}}</text>
        <text class="price-unit">元/月</text>
      </view>
      <view class="location-link" bindtap="onNeighborhoodTap">查看小区测评 ›</view>
    </view>
    <view class="facts-row" wx:if="{{house.district || house.basicFacts.length}}">
      <text class="fact-pill" wx:if="{{house.district}}">{{house.district}}</text>
      <text class="fact-pill" wx:for="{{house.basicFacts}}" wx:key="index">{{item}}</text>
    </view>
    <view class="tags-row" wx:if="{{house.tags && house.tags.length > 0}}">
      <text class="tag" wx:for="{{house.tags}}" wx:key="index">{{item}}</text>
    </view>
  </view>

  <view class="video-section inline-video-section" wx:if="{{house.videos && house.videos.length > 0}}">
    <video
      src="{{house.videos[0]}}"
      class="detail-video"
      controls
      show-mute-btn
      object-fit="cover"
      enable-progress-gesture
    ></video>
    <view class="video-badge">视频带看</view>
  </view>

  <!-- 实地测评优先 -->
  <view
    class="review-card review-card-{{item.type}}"
    wx:for="{{house.reviewSections}}"
    wx:key="label"
  >
    <view class="review-head">
      <view>
        <text class="review-label">{{index + 1}}. {{item.label}}</text>
        <text class="review-title">{{item.title}}</text>
      </view>
    </view>
    <text class="review-text" wx:if="{{item.value}}">{{item.value}}</text>
    <view class="review-points" wx:if="{{item.points && item.points.length}}">
      <view
        class="review-point"
        wx:for="{{item.points}}"
        wx:key="pointIndex"
        wx:for-item="point"
        wx:for-index="pointIndex"
      >
        <block wx:if="{{point.label}}">
          <text class="point-label">{{point.label}}</text>
          <text class="point-value">{{point.value}}</text>
        </block>
        <block wx:else>
          <text class="point-value">{{point.value}}</text>
        </block>
      </view>
    </view>
  </view>

  <!-- 管家信息 -->
  <view class="housekeeper-card">
    <view class="housekeeper-head">
      <view>
        <text class="card-title">管家信息</text>
        <text class="housekeeper-subtitle">实地测评 · 深港通勤 · 免中介费</text>
      </view>
      <text class="housekeeper-pill">在线可咨询</text>
    </view>

    <view class="landlord-info">
      <view class="landlord-avatar">
        <image
          wx:if="{{house.landlordAvatar}}"
          src="{{house.landlordAvatar}}"
          class="avatar-img"
          mode="aspectFill"
        />
        <view wx:else class="avatar-placeholder">
          <view class="ui-icon ui-icon-shield"></view>
        </view>
      </view>
      <view class="landlord-detail">
        <text class="landlord-name">{{house.housekeeperName}}</text>
        <text class="landlord-badge">从业10年 · 深港通勤多年经验</text>
      </view>
    </view>

    <view class="trust-mini">
      <text>帮你判断这套房是否适合</text>
      <text>结合通勤、预算、租期和生活配套，减少无效看房。</text>
    </view>

    <view class="contact-methods" wx:if="{{house.available}}">
      <button
        class="contact-method online-method primary-contact"
        open-type="contact"
        show-message-card="true"
        send-message-title="{{house.neighborhood}}在线咨询"
        send-message-path="/pages/detail/detail?id={{house.id}}"
        session-from="house-detail"
        hover-class="none"
      >
        <view class="method-icon-wrap wechat-icon-bg">
          <view class="method-icon ui-icon ui-icon-chat"></view>
        </view>
        <view class="method-info">
          <text class="method-label">小程序私信</text>
          <text class="method-value">在线咨询管家</text>
        </view>
        <view class="method-action wechat-action">
          <text>立即咨询</text>
        </view>
      </button>

      <view class="contact-method phone-method secondary-contact" bindtap="onPhoneCall">
        <view class="method-icon-wrap phone-icon-bg">
          <view class="method-icon ui-icon ui-icon-phone"></view>
        </view>
        <view class="method-info">
          <text class="method-label">电话咨询</text>
          <text class="method-value">{{house.landlordPhone || '待补充'}}</text>
        </view>
        <view class="method-action phone-action">
          <text>拨打</text>
        </view>
      </view>
    </view>

  </view>

  <view class="meta-card">
    <text class="meta-item">发布于 {{house.displayCreateTime}}</text>
    <text class="meta-item">已有 {{house.viewCount || 0}} 人浏览</text>
  </view>

  <view class="detail-bottom-space"></view>
</view>

<!-- 底部固定联系栏 -->
<view class="bottom-bar" wx:if="{{house && house.available}}">
  <view class="bottom-bar-inner">
    <view class="bottom-phone" bindtap="onPhoneCall">
      <view class="bottom-action-icon ui-icon ui-icon-phone"></view>
      <view class="bottom-labels">
        <text class="bottom-kicker">备用</text>
        <text class="bottom-text">电话咨询</text>
      </view>
    </view>
    <button
      class="bottom-wechat"
      open-type="contact"
      show-message-card="true"
      send-message-title="{{house.neighborhood}}在线咨询"
      send-message-path="/pages/detail/detail?id={{house.id}}"
      session-from="house-bottom"
      hover-class="none"
    >
      <view class="bottom-action-icon ui-icon ui-icon-chat"></view>
      <text class="bottom-text">在线咨询</text>
    </button>
  </view>
</view>

<consult-modal visible="{{showConsultModal}}" bind:dismiss="onConsultDismiss" />
