/* pages/detail/detail.wxss */
.page-container {
  background: #F4F1EA;
  min-height: 100vh;
}

/* 视频带看 */
.video-section {
  position: relative; background: #000; width: 100%;
}
.detail-video {
  width: 100%; height: 420rpx; display: block;
}
.video-badge {
  position: absolute; top: 16rpx; left: 16rpx;
  background: rgba(0,0,0,0.55); color: #FFF;
  font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 50rpx;
}

/* 图片区 */
.image-section {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: #F0F0F0;
}

.image-swiper {
  width: 100%;
  height: 480rpx;
}

.house-img {
  width: 100%;
  height: 480rpx;
}

.image-placeholder {
  width: 100%;
  height: 480rpx;
  background: linear-gradient(135deg, #EFE3D0, #D9C19F);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-emoji {
  font-size: 120rpx;
}

.placeholder-name {
  font-size: 32rpx;
  color: #0F2F4A;
  font-weight: 600;
  margin-top: 20rpx;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.status-tag {
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.available {
  background: rgba(46, 204, 113, 0.9);
}

.rented {
  background: rgba(153, 153, 153, 0.9);
}

.share-btn {
  background: rgba(255,255,255,0.85);
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  color: #4F4A43;
  border: 0;
  line-height: 1.4;
  margin: 0;
}
.share-btn::after { border: 0; }

/* 通用卡片 */
.info-card,
.detail-card,
.landlord-card,
.meta-card {
  background: #FFFFFF;
  margin: 16rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 基本信息 */
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.price-block {
  display: flex;
  align-items: baseline;
}

.price-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #0F2F4A;
}

.price-unit {
  font-size: 26rpx;
  color: #0F2F4A;
  margin-left: 6rpx;
}

.favorite-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #E6E0D8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.heart-icon {
  font-size: 36rpx;
  color: #C9C0B4;
}

.favorite-btn.favorited {
  border-color: #0F2F4A;
  background: #F4EFE6;
}

.house-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #171512;
  display: block;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.location-row {
  display: flex;
  align-items: center;
  background: #FAF7F1;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.neighborhood-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F2F4A;
}

.district-name {
  font-size: 24rpx;
  color: #7A746B;
  margin-left: 10rpx;
}

.view-more {
  font-size: 22rpx;
  color: #0F2F4A;
  margin-left: auto;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  padding: 6rpx 20rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  background: #F4EFE6;
  color: #0F2F4A;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
}

/* 参数卡片 */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #171512;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F4F1EA;
}

.params-grid {
  display: flex;
  flex-wrap: wrap;
}

.param-item {
  width: 50%;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
}

.param-label {
  font-size: 24rpx;
  color: #7A746B;
  margin-bottom: 6rpx;
}

.param-value {
  font-size: 28rpx;
  color: #27241F;
  font-weight: 500;
}

.address-text {
  font-size: 24rpx;
}

/* 描述 */
.description-text {
  font-size: 28rpx;
  color: #45413B;
  line-height: 1.8;
  display: block;
}

/* 房东信息（核心） */
.landlord-card {
  border: 2rpx solid #E6D7BF;
}

.landlord-info {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.landlord-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  background: #F4F1EA;
  flex-shrink: 0;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #EFE3D0, #D9C19F);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.landlord-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.landlord-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #171512;
  margin-bottom: 8rpx;
}

.landlord-badge {
  font-size: 24rpx;
  color: #2E7D5B;
  background: #EAF6EF;
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
  display: inline-block;
  width: fit-content;
}

/* 联系方式 */
.contact-methods {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.contact-method {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #F8F6F1;
}

.method-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.phone-icon-bg {
  background: #EAF1F6;
}

.wechat-icon-bg {
  background: #EAF6EF;
}

.method-icon {
  font-size: 40rpx;
}

.method-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.method-label {
  font-size: 22rpx;
  color: #7A746B;
  margin-bottom: 6rpx;
}

.method-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #27241F;
}

.wechat-id {
  color: #1F8A5B;
}

.method-action {
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.phone-action {
  background: #EAF1F6;
  color: #2F6F95;
}

.wechat-action {
  background: #EAF6EF;
  color: #1F8A5B;
}

.wechat-action.copied {
  background: #F4F1EA;
  color: #7A746B;
}

.contact-tips {
  background: #FAF7F1;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #0F2F4A;
}

/* 元信息 */
.meta-card {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: #FAFAFA;
  border: none;
  box-shadow: none;
}

.meta-item {
  font-size: 22rpx;
  color: #A8A196;
}

/* 底部固定联系栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.bottom-bar-inner {
  display: flex;
  height: 120rpx;
}

.bottom-phone, .bottom-wechat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.bottom-phone {
  background: linear-gradient(135deg, #2F6F95, #3D82A8);
}

.bottom-wechat {
  background: linear-gradient(135deg, #1F8A5B, #35A36F);
}

.bottom-icon {
  font-size: 40rpx;
}

.bottom-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-top: 6rpx;
}

.bottom-divider {
  width: 2rpx;
  background: rgba(255,255,255,0.3);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  width: 100%;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171512;
}

.modal-close {
  font-size: 36rpx;
  color: #7A746B;
  padding: 8rpx;
}

.modal-landlord {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-avatar {
  font-size: 80rpx;
  width: 120rpx;
  height: 120rpx;
  background: #F4EFE6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 120rpx;
  margin-bottom: 16rpx;
}

.modal-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #171512;
}

.modal-wechat-section {
  margin-bottom: 32rpx;
}

.modal-label {
  font-size: 24rpx;
  color: #7A746B;
  display: block;
  margin-bottom: 12rpx;
}

.modal-wechat-id {
  background: #F4F1EA;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.wechat-id-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F8A5B;
  letter-spacing: 4rpx;
}

.modal-steps {
  background: #FAF7F1;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.steps-title {
  font-size: 24rpx;
  color: #0F2F4A;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.step-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  background: #0F2F4A;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: #45413B;
}

.modal-copy-btn {
  background: linear-gradient(135deg, #1F8A5B, #35A36F);
  color: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  width: 100%;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.3);
}

.modal-copy-btn::after {
  border: none;
}

.modal-phone-btn {
  background: transparent;
  color: #2F6F95;
  border-radius: 50rpx;
  border: 2rpx solid #2F6F95;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
}

.modal-phone-btn::after {
  border: none;
}
