/* pages/detail/detail.wxss */
.page-container {
  background: #F4F1EA;
  min-height: 100vh;
}

/* 视频带看 */
.video-section {
  position: relative; background: #000; width: 100%;
}
.detail-video {
  width: 100%; height: 420rpx; display: block;
}
.video-badge {
  position: absolute; top: 16rpx; left: 16rpx;
  background: rgba(0,0,0,0.55); color: #FFF;
  font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 50rpx;
}

/* 图片区 */
.image-section {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: #F0F0F0;
}

.image-swiper {
  width: 100%;
  height: 480rpx;
}

.house-img {
  width: 100%;
  height: 480rpx;
}

.image-placeholder {
  width: 100%;
  height: 480rpx;
  background: linear-gradient(135deg, #EFE3D0, #D9C19F);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-mark {
  color: #28B8BC;
  transform: scale(1.55);
}

.placeholder-name {
  font-size: 32rpx;
  color: #0F2F4A;
  font-weight: 600;
  margin-top: 20rpx;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.status-tag {
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.available {
  background: #2E7D5B;
}

.rented {
  background: #D64545;
}

/* 通用卡片 */
.info-card,
.detail-card,
.landlord-card,
.meta-card {
  background: #FFFFFF;
  margin: 16rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 基本信息 */
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.price-block {
  display: flex;
  align-items: baseline;
}

.price-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #0F2F4A;
}

.price-unit {
  font-size: 26rpx;
  color: #0F2F4A;
  margin-left: 6rpx;
}

.favorite-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #E6E0D8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-heart {
  position: relative;
  width: 42rpx;
  height: 42rpx;
}

.favorite-heart::before {
  content: '♡';
  position: absolute;
  inset: 0;
  color: #8FA1A7;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
}

.favorite-btn.favorited {
  border-color: rgba(255, 49, 84, 0.18);
  background: #FFF2F5;
}

.favorite-btn.favorited .favorite-heart::before {
  content: '♥';
  color: #FF3154;
}

.house-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #171512;
  display: block;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.location-row {
  display: flex;
  align-items: center;
  background: #FAF7F1;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.neighborhood-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F2F4A;
}

.district-name {
  font-size: 24rpx;
  color: #7A746B;
  margin-left: 10rpx;
}

.view-more {
  font-size: 22rpx;
  color: #0F2F4A;
  margin-left: auto;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  padding: 6rpx 20rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  background: #F4EFE6;
  color: #0F2F4A;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
}

/* 参数卡片 */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #171512;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F4F1EA;
}

.params-grid {
  display: flex;
  flex-wrap: wrap;
}

.param-item {
  width: 50%;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
}

.param-label {
  font-size: 24rpx;
  color: #7A746B;
  margin-bottom: 6rpx;
}

.param-value {
  font-size: 28rpx;
  color: #27241F;
  font-weight: 500;
}

.address-text {
  font-size: 24rpx;
}

/* 描述 */
.description-text {
  font-size: 28rpx;
  color: #45413B;
  line-height: 1.8;
  display: block;
}

.guide-expand-card {
  position: relative;
  overflow: hidden;
  border: 2rpx solid #E6D7BF;
  background: linear-gradient(180deg, #FFFFFF 0%, #FFFCF7 100%);
}

.guide-expand-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 26rpx;
  bottom: 26rpx;
  width: 6rpx;
  border-radius: 0 8rpx 8rpx 0;
  background: #B8894D;
}

.guide-expand-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.guide-expand-eyebrow {
  display: block;
  font-size: 22rpx;
  color: #B8894D;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.guide-expand-title {
  display: block;
  font-size: 34rpx;
  color: #171512;
  font-weight: 800;
  line-height: 1.35;
}

.guide-expand-pill {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #0F2F4A;
  background: #F4EFE6;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  margin-left: 18rpx;
}

.guide-summary-text {
  display: block;
  font-size: 28rpx;
  color: #45413B;
  line-height: 1.8;
  white-space: pre-wrap;
}

.summary-collapsed {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.guide-full-content {
  margin-top: 20rpx;
  padding: 22rpx 22rpx 4rpx;
  border-radius: 14rpx;
  background: #F8F6F1;
  border-left: 4rpx solid #0F2F4A;
}

.guide-full-content text {
  display: block;
  font-size: 28rpx;
  color: #45413B;
  line-height: 1.85;
  white-space: pre-wrap;
}

.guide-tip {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #FFF8EA;
  border: 1rpx solid #E8D5AF;
}

.guide-tip-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #B8894D;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 34rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.guide-tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #6F4D20;
  line-height: 1.7;
  white-space: pre-wrap;
}

.guide-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0F2F4A;
  font-size: 26rpx;
  font-weight: 700;
  padding-top: 24rpx;
}

.guide-toggle-arrow {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* 管家信息 */
.landlord-card {
  border: 2rpx solid #E6D7BF;
}

.landlord-info {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.trust-mini {
  background: #F8F6F1;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  margin: 20rpx 0;
}

.trust-mini text {
  display: block;
  font-size: 23rpx;
  color: #4F4A43;
  line-height: 1.6;
}

.trust-mini text:first-child {
  color: #0F2F4A;
  font-weight: 800;
  margin-bottom: 6rpx;
}

.landlord-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  background: #F4F1EA;
  flex-shrink: 0;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #EFE3D0, #D9C19F);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #28B8BC;
}

.avatar-placeholder .ui-icon {
  transform: scale(1.12);
}

.landlord-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.landlord-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #171512;
  margin-bottom: 8rpx;
}

.landlord-badge {
  font-size: 24rpx;
  color: #2E7D5B;
  background: #EAF6EF;
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
  display: inline-block;
  width: fit-content;
}

/* 联系方式 */
.contact-methods {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.contact-method {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #F8F6F1;
}

.method-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.phone-icon-bg {
  background: #EAF1F6;
}

.wechat-icon-bg {
  background: #EAF6EF;
}

.method-icon {
  color: #28B8BC;
  transform: scale(.82);
}

.method-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.method-label {
  font-size: 22rpx;
  color: #7A746B;
  margin-bottom: 6rpx;
}

.method-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #27241F;
}

.wechat-id {
  color: #1F8A5B;
}

.method-action {
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.phone-action {
  background: #EAF1F6;
  color: #2F6F95;
}

.wechat-action {
  background: #EAF6EF;
  color: #1F8A5B;
}

.wechat-action.copied {
  background: #F4F1EA;
  color: #7A746B;
}

.contact-tips {
  background: #FAF7F1;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #0F2F4A;
}

/* 元信息 */
.meta-card {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: #FAFAFA;
  border: none;
  box-shadow: none;
}

.meta-item {
  font-size: 22rpx;
  color: #A8A196;
}

.detail-bottom-space {
  height: calc(230rpx + env(safe-area-inset-bottom));
}

/* 底部固定联系栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.bottom-bar-inner {
  display: flex;
  height: 120rpx;
}

.bottom-phone, .bottom-wechat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.bottom-phone {
  background: linear-gradient(135deg, #2F6F95, #3D82A8);
}

.bottom-wechat {
  background: linear-gradient(135deg, #1F8A5B, #35A36F);
}

.bottom-icon {
  font-size: 40rpx;
}

.bottom-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-top: 6rpx;
}

.bottom-divider {
  width: 2rpx;
  background: rgba(255,255,255,0.3);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  width: 100%;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171512;
}

.modal-close {
  font-size: 36rpx;
  color: #7A746B;
  padding: 8rpx;
}

.modal-landlord {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-avatar {
  font-size: 80rpx;
  width: 120rpx;
  height: 120rpx;
  background: #F4EFE6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 120rpx;
  margin-bottom: 16rpx;
}

.modal-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #171512;
}

.modal-wechat-section {
  margin-bottom: 32rpx;
}

.modal-label {
  font-size: 24rpx;
  color: #7A746B;
  display: block;
  margin-bottom: 12rpx;
}

.modal-wechat-id {
  background: #F4F1EA;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.wechat-id-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F8A5B;
  letter-spacing: 4rpx;
}

.modal-steps {
  background: #FAF7F1;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.steps-title {
  font-size: 24rpx;
  color: #0F2F4A;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.step-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  background: #0F2F4A;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: #45413B;
}

.modal-copy-btn {
  background: linear-gradient(135deg, #1F8A5B, #35A36F);
  color: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  width: 100%;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.3);
}

.modal-copy-btn::after {
  border: none;
}

.modal-phone-btn {
  background: transparent;
  color: #2F6F95;
  border-radius: 50rpx;
  border: 2rpx solid #2F6F95;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
}

.modal-phone-btn::after {
  border: none;
}

/* 2026 UI refresh */
.page-container {
  background: #EFF8FB;
}

.image-section,
.image-swiper,
.house-img,
.detail-video {
  border-radius: 0 0 42rpx 42rpx;
}

.info-card,
.detail-card,
.landlord-card,
.meta-card {
  margin: 18rpx 30rpx 0;
  border-radius: 34rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.price-num,
.price-unit,
.house-title,
.card-title,
.landlord-name,
.modal-title,
.steps-title,
.neighborhood-name {
  color: #111111;
}

.district-name,
.param-label,
.description-text,
.guide-summary-text,
.guide-full-content text,
.step-text,
.meta-item,
.contact-tips,
.trust-mini text,
.method-label {
  color: #667A82;
}

.favorite-btn,
.location-row,
.contact-method,
.modal-wechat-id,
.modal-steps,
.trust-mini,
.guide-full-content {
  border-radius: 26rpx;
  background: #F5FCFD;
}

.favorite-btn.favorited,
.tag,
.guide-expand-pill,
.landlord-badge {
  background: #DDF5F8;
  color: #111111;
  border-color: transparent;
}

.favorite-btn.favorited {
  background: #FFF2F5;
  border-color: rgba(255, 49, 84, 0.18);
}

.guide-expand-card {
  border-color: rgba(40, 184, 188, 0.26);
  background: #FFFFFF;
}

.guide-expand-card::before,
.step-num,
.guide-tip-icon {
  background: #28B8BC;
}

.guide-expand-eyebrow,
.guide-toggle,
.guide-toggle-arrow,
.wechat-id,
.wechat-id-text {
  color: #28B8BC;
}

.guide-tip {
  background: #F2FCFD;
  border-color: rgba(40, 184, 188, 0.22);
  border-radius: 26rpx;
}

.guide-tip-text {
  color: #33464D;
}

.phone-action,
.wechat-action,
.phone-icon-bg,
.wechat-icon-bg {
  background: #DDF5F8;
  color: #111111;
}

.bottom-bar {
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 -10rpx 34rpx rgba(39, 122, 139, 0.12);
}

.bottom-phone,
.bottom-wechat,
.modal-copy-btn {
  background: #28B8BC;
  box-shadow: none;
}

.modal-phone-btn {
  color: #111111;
  border-color: rgba(17, 17, 17, 0.16);
}

.status-tag.available {
  background: #2E7D5B;
}

/* Refined contact dock */
.bottom-bar {
  background: transparent;
  padding: 0 24rpx calc(18rpx + env(safe-area-inset-bottom));
  box-shadow: none;
  pointer-events: none;
}

.bottom-bar-inner {
  height: 104rpx;
  padding: 10rpx;
  gap: 10rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 42rpx rgba(30, 91, 102, 0.16);
  pointer-events: auto;
}

.bottom-phone,
.bottom-wechat {
  min-width: 0;
  height: 84rpx;
  flex-direction: row;
  border-radius: 23rpx;
}

.bottom-phone {
  flex: 0 0 43%;
  justify-content: flex-start;
  padding: 0 22rpx;
  background: #F2F9FA;
}

.bottom-wechat {
  justify-content: center;
  background: #28B8BC;
  box-shadow: 0 8rpx 20rpx rgba(40, 184, 188, 0.2);
}

.bottom-labels {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.bottom-action-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  transform: scale(.72);
}

.bottom-phone .bottom-action-icon {
  color: #28B8BC;
}

.bottom-wechat .bottom-action-icon {
  color: #FFFFFF;
}

.bottom-kicker {
  color: #7B9097;
  font-size: 20rpx;
  line-height: 1.2;
}

.bottom-text {
  margin-top: 2rpx;
  color: #111111;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.25;
}

.bottom-wechat .bottom-text {
  margin-top: 0;
  color: #FFFFFF;
  font-size: 28rpx;
}

.bottom-icon {
  position: relative;
  width: 38rpx;
  height: 38rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.bottom-icon-phone {
  border: 3rpx solid #28B8BC;
  border-width: 0 0 3rpx 3rpx;
  border-radius: 5rpx 5rpx 5rpx 18rpx;
  transform: rotate(-45deg) scale(.72);
}

.bottom-icon-phone::before,
.bottom-icon-phone::after {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 8rpx;
  border-radius: 6rpx;
  background: #28B8BC;
}

.bottom-icon-phone::before {
  left: -6rpx;
  top: -2rpx;
  transform: rotate(45deg);
}

.bottom-icon-phone::after {
  right: -2rpx;
  bottom: -5rpx;
  transform: rotate(45deg);
}

.bottom-icon-wechat {
  width: 34rpx;
  height: 28rpx;
  border: 3rpx solid rgba(255, 255, 255, .92);
  border-radius: 50%;
}

.bottom-icon-wechat::after {
  content: '';
  position: absolute;
  right: -3rpx;
  bottom: -5rpx;
  width: 9rpx;
  height: 9rpx;
  border-right: 3rpx solid rgba(255, 255, 255, .92);
  transform: rotate(35deg);
}

.bottom-divider {
  display: none;
}

/* Product detail rebuild */
.hero-image-section,
.hero-image-section .image-swiper,
.hero-image-section .house-img,
.hero-image-section .image-placeholder {
  height: 620rpx;
}

.intro-card,
.review-card,
.housekeeper-card {
  margin: 18rpx 30rpx 0;
  padding: 30rpx;
  border-radius: 34rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
  box-sizing: border-box;
}

.intro-card {
  margin-top: -34rpx;
  position: relative;
  z-index: 2;
}

.intro-head,
.intro-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.intro-copy {
  min-width: 0;
  flex: 1;
}

.intro-neighborhood {
  display: block;
}

.intro-neighborhood {
  font-size: 42rpx;
  color: #111111;
  font-weight: 900;
  line-height: 1.25;
}

.intro-bottom {
  margin-top: 8rpx;
  margin-bottom: 18rpx;
}

.location-link {
  flex-shrink: 0;
  margin-left: 18rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #DDF5F8;
  color: #111111;
  font-size: 23rpx;
  font-weight: 800;
}

.facts-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
}

.fact-pill {
  margin: 0 10rpx 10rpx 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #F2F9FA;
  color: #33464D;
  font-size: 23rpx;
  font-weight: 700;
}

.inline-video-section {
  margin: 18rpx 30rpx 0;
  overflow: hidden;
  border-radius: 34rpx;
  background: #111111;
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.inline-video-section .detail-video {
  border-radius: 34rpx;
}

.review-card {
  position: relative;
  overflow: hidden;
}

.review-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 28rpx;
  bottom: 28rpx;
  width: 7rpx;
  border-radius: 0 8rpx 8rpx 0;
  background: #28B8BC;
}

.review-card-scout {
  border-color: rgba(40, 184, 188, 0.28);
}

.review-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.review-label,
.review-title,
.review-text {
  display: block;
}

.review-label {
  font-size: 22rpx;
  color: #28B8BC;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.review-title {
  font-size: 34rpx;
  color: #111111;
  font-weight: 900;
  line-height: 1.35;
}

.review-text {
  font-size: 28rpx;
  color: #455960;
  line-height: 1.75;
  white-space: pre-wrap;
}

.review-points {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.review-point {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #F5FCFD;
}

.point-label {
  flex-shrink: 0;
  min-width: 120rpx;
  margin-right: 14rpx;
  color: #111111;
  font-size: 24rpx;
  font-weight: 900;
}

.point-value {
  flex: 1;
  min-width: 0;
  color: #667A82;
  font-size: 25rpx;
  line-height: 1.55;
}

.housekeeper-card .card-title {
  border-bottom-color: rgba(17, 17, 17, 0.06);
}

.housekeeper-card {
  border-color: rgba(40, 184, 188, 0.24);
}

.housekeeper-card .avatar-placeholder {
  background: #DDF5F8;
  color: #111111;
  font-size: 38rpx;
  font-weight: 900;
}

.online-method,
.bottom-wechat,
.modal-copy-btn {
  margin: 0;
  border: 0;
  padding: 20rpx;
  text-align: left;
  line-height: 1.2;
  box-sizing: border-box;
}

.online-method::after,
.bottom-wechat::after,
.modal-copy-btn::after {
  border: 0;
}

.online-method {
  width: 100%;
  color: inherit;
  border-radius: 26rpx;
  background: #F5FCFD;
}

.bottom-wechat {
  padding: 0 24rpx;
  color: #FFFFFF;
}

.bottom-wechat .bottom-icon {
  width: auto;
  height: auto;
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* Housekeeper card redesign */
.housekeeper-card {
  margin: 22rpx 24rpx 0;
  padding: 28rpx;
  border: 1rpx solid rgba(40, 184, 188, 0.22);
  border-radius: 34rpx;
  background: #FFFFFF;
  box-shadow: 0 14rpx 38rpx rgba(39, 122, 139, 0.08);
}

.housekeeper-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.06);
}

.housekeeper-card .card-title {
  display: block;
  margin: 0;
  padding: 0;
  border: 0;
  font-size: 32rpx;
  color: #111111;
  font-weight: 900;
  line-height: 1.25;
}

.housekeeper-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #667A82;
  font-size: 23rpx;
  line-height: 1.35;
}

.housekeeper-pill {
  flex-shrink: 0;
  margin-left: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #DDF5F8;
  color: #0F4C75;
  font-size: 22rpx;
  font-weight: 900;
}

.housekeeper-card .landlord-info {
  margin: 24rpx 0 0;
  align-items: center;
}

.housekeeper-card .landlord-avatar,
.housekeeper-card .avatar-img,
.housekeeper-card .avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
}

.housekeeper-card .landlord-avatar {
  margin-right: 22rpx;
  border-radius: 50%;
  background: #DDF5F8;
}

.housekeeper-card .avatar-placeholder {
  background: #DDF5F8;
  color: #28B8BC;
}

.housekeeper-card .landlord-name {
  font-size: 34rpx;
  color: #111111;
  font-weight: 900;
  line-height: 1.25;
}

.housekeeper-card .landlord-badge {
  margin-top: 10rpx;
  padding: 7rpx 16rpx;
  background: #F2F9FA;
  color: #0F4C75;
  font-size: 23rpx;
  font-weight: 800;
  border-radius: 999rpx;
}

.housekeeper-card .trust-mini {
  margin: 24rpx 0 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: #F5FCFD;
}

.housekeeper-card .trust-mini text:first-child {
  margin-bottom: 8rpx;
  color: #0F4C75;
  font-size: 25rpx;
  font-weight: 900;
}

.housekeeper-card .trust-mini text:last-child {
  color: #667A82;
  font-size: 24rpx;
  line-height: 1.65;
}

.housekeeper-card .contact-methods {
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.housekeeper-card .contact-method {
  width: 100%;
  min-height: 92rpx;
  margin: 0;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.housekeeper-card .primary-contact {
  background: linear-gradient(135deg, #E8FBFC, #F6FEFF);
  border: 1rpx solid rgba(40, 184, 188, 0.22);
}

.housekeeper-card .secondary-contact {
  background: #F5FCFD;
  border: 1rpx solid rgba(17, 17, 17, 0.04);
}

.housekeeper-card .method-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  margin-right: 18rpx;
  background: #DDF5F8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.housekeeper-card .method-icon {
  color: #28B8BC;
}

.housekeeper-card .method-label {
  margin-bottom: 4rpx;
  color: #667A82;
  font-size: 22rpx;
}

.housekeeper-card .method-value {
  color: #111111;
  font-size: 28rpx;
  font-weight: 900;
}

.housekeeper-card .method-action {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #DDF5F8;
  color: #0F4C75;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1;
}

.housekeeper-card .primary-contact .method-action,
.housekeeper-card .secondary-contact .method-action {
  background: #28B8BC;
  color: #FFFFFF;
}

.bottom-phone .bottom-icon {
  width: auto;
  height: auto;
  margin-right: 12rpx;
  font-size: 30rpx;
}

.meta-card {
  margin: 18rpx 30rpx 0;
  border-radius: 24rpx;
  background: transparent;
}
