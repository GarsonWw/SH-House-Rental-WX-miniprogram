<!-- pages/index/index.wxml -->
<view class="page-wrap">

  <!-- 顶部精选房源轮播 -->
  <view class="hero-wrap" wx:if="{{heroSlides.length}}">
    <swiper
      class="hero-swiper"
      autoplay="{{heroSlides.length > 1}}"
      circular="{{heroSlides.length > 1}}"
      interval="4500"
      duration="450"
      current="{{heroIndex}}"
      bindchange="onHeroChange"
    >
      <swiper-item wx:for="{{heroSlides}}" wx:key="id">
        <view class="hero-slide" bindtap="onHeroTap" data-id="{{item.id}}">
          <image class="hero-image" src="{{item.image}}" mode="aspectFill" />
          <view class="hero-badge">罗湖直租 · 免中介费</view>
          <view class="hero-content">
            <view class="hero-copy">
              <text class="hero-neighborhood">{{item.neighborhood}}</text>
              <text class="hero-meta">{{item.meta}} · {{item.statusText}}</text>
            </view>
            <view class="hero-conversion">
              <view class="hero-price"><text class="hero-price-number">{{item.price}}</text><text class="hero-price-unit">元/月</text></view>
              <view class="hero-cta">查看房源</view>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
    <view class="hero-pagination">
      <view
        class="hero-dot {{heroIndex === index ? 'hero-dot-active' : ''}}"
        wx:for="{{heroSlides}}"
        wx:key="id"
      ></view>
    </view>
  </view>

  <view class="hero-empty" wx:else>
    <text class="hero-empty-kicker">深圳罗湖直租</text>
    <text class="hero-empty-title">真实房源，直联房东</text>
    <text class="hero-empty-desc">新房源整理中，可先按小区浏览</text>
  </view>

  <view class="service-proof">
    <view class="proof-item">
      <text class="proof-value">3年</text>
      <text class="proof-label">罗湖沉淀</text>
    </view>
    <view class="proof-divider"></view>
    <view class="proof-item">
      <text class="proof-value">1000+</text>
      <text class="proof-label">真实用户服务</text>
    </view>
    <view class="proof-divider"></view>
    <view class="proof-item">
      <text class="proof-value">{{platformStats.available}}</text>
      <text class="proof-label">当前可租房源</text>
    </view>
  </view>

  <view class="trust-card trust-card-compact">
    <view class="trust-summary">
      <view class="trust-summary-copy">
        <text class="trust-kicker">服务保障</text>
        <text class="trust-title">深港租房双城通</text>
        <text class="trust-summary-text">免中介费 · 真实房源 · 深港生活经验</text>
      </view>
    </view>
    <view class="trust-detail">
      <text class="trust-desc">自2023年起，我们专注深圳罗湖租房直租服务，结合深港生活经验、通勤时间、预算需求和生活配套，为港硕学生、香港高校学生及深港通勤人群提供更省心、高效、透明的罗湖租房建议。</text>
      <view class="trust-points">
        <text>罗湖直租</text>
        <text>免中介费</text>
        <text>深港通勤经验</text>
        <text>真实房源</text>
      </view>
    </view>
  </view>

  <!-- ③ Tab 切换 -->
  <view class="main-tabs">
    <view
      class="main-tab {{activeTab === 'overview' ? 'main-tab-active' : ''}}"
      bindtap="onTabSwitch"
      data-tab="overview"
    >全部房源</view>
    <view
      class="main-tab {{activeTab === 'match' ? 'main-tab-active' : ''}}"
      bindtap="onTabSwitch"
      data-tab="match"
    >🔍 智能匹配</view>
  </view>

  <!-- ══ 全部房源 Tab ════════════════════════════ -->
  <view wx:if="{{activeTab === 'overview'}}">

    <!-- ④ 三维度筛选 -->
    <view class="dim-row">
      <view
        class="dim-item {{activeDim === item ? 'dim-active' : ''}}"
        wx:for="{{filterDims}}"
        wx:key="index"
        bindtap="onDimSelect"
        data-dim="{{item}}"
      >{{item}}</view>
    </view>

    <!-- ⑤ 筛选芯片 -->
    <scroll-view scroll-x class="chips-scroll">
      <view class="chips-row">
        <view
          class="chip {{item.active ? 'chip-active' : ''}}"
          wx:for="{{overviewFilterOptions}}"
          wx:key="index"
          bindtap="onOverviewFilterSelect"
          data-value="{{item.label}}"
          data-idx="{{item.idx}}"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- ⑥ 无内容提示 -->
    <view class="empty-tip" wx:if="{{neighborhoodSections.length === 0}}">
      <text class="empty-icon">🏘️</text>
      <text class="empty-text">该区域暂无房源</text>
    </view>

    <!-- ⑦ 小区分区块列表 -->
    <view class="section-block" wx:for="{{neighborhoodSections}}" wx:key="name">
      <view class="sb-head">
        <view class="sb-title-col">
          <view class="sb-title-row">
            <text class="sb-icon">{{item.icon}}</text>
            <text class="sb-name">{{item.name}}</text>
            <view class="sb-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
          </view>
          <text class="sb-category">{{item.categoryLabel}} · {{item.district}}</text>
        </view>
        <view class="sb-link" catchtap="onNeighborhoodTap" data-name="{{item.name}}">
          <text>查看联系方式</text>
        </view>
      </view>

      <text class="sb-desc" wx:if="{{item.desc}}">{{item.desc}}</text>

      <view class="sb-review-wrap" wx:if="{{item.review}}">
        <view class="sb-review-quote"></view>
        <text class="sb-review {{item.expanded ? '' : 'sb-review-clamp'}}">{{item.review}}</text>
        <view class="sb-expand" bindtap="onExpandSection" data-idx="{{index}}">
          <text>{{item.expanded ? '收起 ↑' : '展开完整点评 ↓'}}</text>
        </view>
      </view>

      <scroll-view scroll-x class="house-scroll">
        <view class="house-row">
          <view
            class="mini-card"
            wx:for="{{item.houses}}"
            wx:key="id"
            wx:for-item="h"
            bindtap="onHouseTap"
            data-id="{{h.id}}"
          >
            <view class="mini-img-wrap">
              <image
                wx:if="{{h.images && h.images.length > 0}}"
                src="{{h.images[0]}}"
                class="mini-img"
                mode="aspectFill"
                lazy-load
              />
              <view wx:else class="mini-img-ph"><text>🏠</text></view>
              <view class="mini-badge {{h.available ? '' : 'mini-rented'}}">
                {{h.available ? '可租' : '已租'}}
              </view>
            </view>
            <text class="mini-title">{{h.title}}</text>
            <text class="mini-meta">{{h.roomType}} · {{h.area}}㎡</text>
            <text class="mini-price">{{h.price}}元/月</text>
          </view>
          <view class="mini-more" catchtap="onNeighborhoodTap" data-name="{{item.name}}">
            <text class="more-icon">›</text>
            <text class="more-text">查看{{item.name}}全部房源</text>
          </view>
        </view>
      </scroll-view>
    </view>


  </view>

  <!-- ══ 智能匹配 Tab ════════════════════════════ -->
  <view wx:if="{{activeTab === 'match'}}" class="match-wrap">

    <!-- 筛选面板 -->
    <view class="filter-panel">
      <text class="filter-panel-title">🎯 设置条件，自动为你匹配合适房源</text>

      <!-- 地区选择 -->
      <view class="filter-row">
        <text class="filter-label">📍 地区</text>
        <scroll-view scroll-x class="filter-scroll">
          <view class="filter-chips">
            <view
              class="f-chip {{matchSelectedDistrict === item ? 'f-chip-active' : ''}}"
              wx:for="{{matchDistrictList}}"
              wx:key="index"
              bindtap="onMatchDistrictSelect"
              data-district="{{item}}"
            >{{item}}</view>
          </view>
        </scroll-view>
      </view>

      <!-- 价格区间 -->
      <view class="filter-row">
        <text class="filter-label">💰 价格</text>
        <scroll-view scroll-x class="filter-scroll">
          <view class="filter-chips">
            <view
              class="f-chip {{selectedPriceIdx === index ? 'f-chip-active' : ''}}"
              wx:for="{{priceRanges}}"
              wx:key="index"
              bindtap="onPriceSelect"
              data-idx="{{index}}"
            >{{item}}</view>
          </view>
        </scroll-view>
      </view>

      <!-- 房型 -->
      <view class="filter-row">
        <text class="filter-label">🏡 房型</text>
        <scroll-view scroll-x class="filter-scroll">
          <view class="filter-chips">
            <view
              class="f-chip {{selectedRoomType === item ? 'f-chip-active' : ''}}"
              wx:for="{{roomTypes}}"
              wx:key="index"
              bindtap="onRoomTypeSelect"
              data-type="{{item}}"
            >{{item}}</view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 匹配结果区 -->
    <view class="match-results">

      <!-- 结果标题 -->
      <view class="result-header" wx:if="{{hasSearched}}">
        <text class="result-title">为你找到</text>
        <text class="result-count">{{matchCount}}</text>
        <text class="result-title">套房源</text>
      </view>

      <!-- 无结果 -->
      <view class="no-result" wx:if="{{hasSearched && matchCount === 0}}">
        <text class="no-result-icon">🔍</text>
        <text class="no-result-text">暂无符合条件的房源</text>
        <text class="no-result-sub">试试放宽地区或价格条件？</text>
      </view>

      <!-- 结果列表 -->
      <view
        class="result-card"
        wx:for="{{matchResults}}"
        wx:key="id"
        bindtap="onHouseTap"
        data-id="{{item.id}}"
      >
        <!-- 图片 -->
        <view class="result-img-wrap">
          <image
            wx:if="{{item.images && item.images.length}}"
            src="{{item.images[0]}}"
            class="result-img"
            mode="aspectFill"
            lazy-load
          />
          <view wx:else class="result-img-ph"><text>🏠</text></view>
          <view class="result-avail {{item.available ? '' : 'avail-rented'}}">
            {{item.available ? '可租' : '已租'}}
          </view>
        </view>

        <!-- 信息 -->
        <view class="result-info">
          <text class="result-name">{{item.title}}</text>
          <view class="result-tags">
            <view class="r-tag r-tag-district">{{item.district}}</view>
            <view class="r-tag r-tag-room">{{item.roomType}}</view>
            <view class="r-tag r-tag-area">{{item.area}}㎡</view>
          </view>
          <text class="result-hood">📍 {{item.neighborhood}}</text>
          <view class="result-bottom">
            <text class="result-price">{{item.price}}<text class="price-unit">元/月</text></text>
            <view class="result-arrow">查看详情 →</view>
          </view>
        </view>
      </view>

    </view>

  </view>

  <view style="height: 50rpx;"></view>
</view>
