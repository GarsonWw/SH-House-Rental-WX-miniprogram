/* pages/index/index.wxss */
.page-wrap {
  min-height: 100vh;
  background: #F4F1EA;
  padding-bottom: 20rpx;
}

/* ① 顶部 Banner */
.select-banner {
  margin: 20rpx 24rpx 0;
  background: linear-gradient(135deg, #0F2F4A, #1C4966);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 12rpx 32rpx rgba(15,47,74,0.18);
}

.banner-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.banner-icon-bg {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1rpx rgba(255,255,255,0.18);
}

.banner-icon {
  font-size: 40rpx;
}

.banner-texts {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}

.banner-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.72);
  margin-top: 4rpx;
  display: block;
}

.banner-action {
  font-size: 24rpx;
  font-weight: 700;
  color: #0F2F4A;
  background: #F4EFE6;
  padding: 10rpx 22rpx;
  border-radius: 50rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.16);
}

.trust-card {
  margin: 16rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(15,47,74,0.06);
  box-shadow: 0 10rpx 28rpx rgba(15,47,74,0.08);
}

.trust-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.trust-title {
  font-size: 30rpx;
  color: #171512;
  font-weight: 800;
}

.trust-badge {
  flex-shrink: 0;
  background: #F4EFE6;
  color: #8A6A3D;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  margin-left: 16rpx;
}

.trust-desc {
  display: block;
  font-size: 24rpx;
  color: #4F4A43;
  line-height: 1.75;
}

.trust-points {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.trust-points text {
  font-size: 22rpx;
  color: #0F2F4A;
  background: #F8F6F1;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

/* ② 平台信息卡 */
.platform-card {
  margin: 16rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  border: 1rpx solid rgba(15,47,74,0.06);
  box-shadow: 0 10rpx 28rpx rgba(15,47,74,0.08);
}

.platform-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
}

.platform-avatar {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #0F2F4A, #1C4966);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.platform-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.platform-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.platform-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #171512;
}

.platform-divider {
  color: #D8D1C7;
  margin: 0 12rpx;
  font-size: 26rpx;
}

.platform-tagline {
  font-size: 28rpx;
  font-weight: 600;
  color: #0F2F4A;
}

.platform-meta {
  font-size: 22rpx;
  color: #7A746B;
  display: block;
  margin-bottom: 8rpx;
}

.platform-desc {
  font-size: 24rpx;
  color: #4F4A43;
  line-height: 1.5;
  display: block;
}

.platform-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 900;
  color: #B8894D;
  line-height: 1;
}

.stat-lbl {
  font-size: 20rpx;
  color: #A8A196;
  margin-top: 6rpx;
}

/* ③ Main Tabs */
.main-tabs {
  margin: 20rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 16rpx 16rpx 0 0;
  display: flex;
  padding: 0 8rpx;
}

.main-tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0 20rpx;
  font-size: 28rpx;
  color: #7A746B;
  font-weight: 500;
  position: relative;
}

.main-tab-active {
  color: #0F4C75;
  font-weight: 700;
}

.main-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 5rpx;
  background: #0F4C75;
  border-radius: 3rpx;
}

/* ④ 筛选维度 */
.dim-row {
  margin: 0 24rpx;
  background: #FFFFFF;
  display: flex;
  border-bottom: 1rpx solid #F2F2F2;
  padding-bottom: 16rpx;
  padding-top: 4rpx;
}

.dim-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #4F4A43;
  padding: 12rpx 0;
  position: relative;
}

.dim-active {
  color: #171512;
  font-weight: 700;
}

.dim-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 3rpx;
  background: #0F2F4A;
  border-radius: 2rpx;
}

/* ⑤ 芯片筛选 */
.chips-scroll {
  margin: 0 24rpx;
  background: #FFFFFF;
  padding: 16rpx 8rpx 20rpx;
  white-space: nowrap;
  border-radius: 0 0 16rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.chips-row {
  display: flex;
  white-space: nowrap;
  padding: 0 8rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #45413B;
  background: #F1EEE7;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.chip-active {
  background: #0F2F4A;
  color: #FFFFFF;
  font-weight: 700;
}

.chip-count {
  font-size: 22rpx;
  opacity: 0.8;
  margin-left: 2rpx;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}

.empty-icon {
  font-size: 90rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7A746B;
  margin-top: 16rpx;
  display: block;
}

.empty-btn {
  margin-top: 28rpx;
  background: #0F2F4A;
  color: #FFFFFF;
  padding: 16rpx 48rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* ⑦ 小区区块 */
.section-block {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15,47,74,0.06);
  box-shadow: 0 10rpx 28rpx rgba(15,47,74,0.07);
}

/* 区块头部 */
.sb-head {
  padding: 24rpx 24rpx 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.sb-title-col {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.sb-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.sb-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.sb-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #171512;
  margin-right: 12rpx;
}

.sb-category {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.sb-badge {
  background: #F4EFE6;
  color: #0F2F4A;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 50rpx;
  border: 1rpx solid #D8C29E;
}

.sb-link {
  font-size: 24rpx;
  color: #0F4C75;
  flex-shrink: 0;
  margin-left: 16rpx;
  padding-top: 4rpx;
}

/* 描述段落 */
.sb-desc {
  display: block;
  font-size: 26rpx;
  color: #36332E;
  line-height: 1.7;
  padding: 16rpx 24rpx 0;
}

/* 点评引用 */
.sb-review-wrap {
  margin: 16rpx 24rpx 0;
  background: #F8F6F1;
  border-radius: 12rpx;
  padding: 18rpx 20rpx 14rpx;
  position: relative;
}

.sb-review-quote {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 5rpx;
  background: #0F4C75;
  border-radius: 3rpx;
}

.sb-review {
  font-size: 24rpx;
  color: #45413B;
  line-height: 1.8;
  display: block;
  padding-left: 16rpx;
}

.sb-review-clamp {
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.sb-expand {
  padding-left: 16rpx;
  margin-top: 10rpx;
}

.sb-expand text {
  font-size: 22rpx;
  color: #0F4C75;
  font-weight: 600;
}

/* 横滑房源 */
.house-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.house-row {
  display: flex;
  white-space: nowrap;
  padding: 0 20rpx 24rpx;
}

.mini-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.mini-img-wrap {
  position: relative;
  width: 220rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.mini-img {
  width: 220rpx;
  height: 180rpx;
}

.mini-img-ph {
  width: 220rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #EFE3D0, #D9C19F);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.mini-badge {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  background: #2E7D5B;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 50rpx;
}

.mini-rented {
  background: rgba(0,0,0,0.45);
}

.mini-title {
  font-size: 24rpx;
  color: #171512;
  font-weight: 600;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 220rpx;
}

.mini-meta {
  font-size: 20rpx;
  color: #AAAAAA;
  display: block;
  margin-top: 4rpx;
}

.mini-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #B8894D;
  display: block;
  margin-top: 6rpx;
}

/* 末尾"查看更多"卡片 */
.mini-more {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 180rpx;
  background: #F8F6F1;
  border-radius: 12rpx;
  flex-shrink: 0;
  border: 2rpx dashed #D8D1C7;
}

.more-icon {
  font-size: 52rpx;
  color: #A8A196;
}

.more-text {
  font-size: 20rpx;
  color: #AAAAAA;
  text-align: center;
  white-space: normal;
  width: 130rpx;
  line-height: 1.4;
  margin-top: 8rpx;
}

/* ══ 智能匹配 Tab ══════════════════════════════ */
.match-wrap { padding: 0 0 20rpx; }

/* 筛选面板 */
.filter-panel {
  background: #FFF; margin: 16rpx 24rpx 0;
  border-radius: 20rpx; padding: 24rpx 24rpx 8rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.filter-panel-title {
  font-size: 26rpx; color: #555; display: block;
  margin-bottom: 20rpx; line-height: 1.5;
}
.filter-row {
  margin-bottom: 20rpx;
}
.filter-label {
  font-size: 26rpx; font-weight: 700; color: #333;
  display: block; margin-bottom: 12rpx;
}
.filter-scroll { white-space: nowrap; }
.filter-chips { display: flex; white-space: nowrap; padding-bottom: 4rpx; }

.f-chip {
  display: inline-flex; align-items: center;
  padding: 12rpx 28rpx; border-radius: 50rpx;
  font-size: 26rpx; color: #555;
  background: #F1EEE7; margin-right: 14rpx;
  flex-shrink: 0; border: 2rpx solid transparent;
}
.f-chip-active {
  background: #F4EFE6; color: #0F2F4A;
  border-color: #0F2F4A; font-weight: 700;
}

/* 结果区 */
.match-results { padding: 0 24rpx; margin-top: 20rpx; }

.result-header {
  display: flex; align-items: baseline;
  margin-bottom: 16rpx; padding: 0 4rpx;
}
.result-title { font-size: 28rpx; color: #555; }
.result-count {
  font-size: 44rpx; font-weight: 900; color: #0F2F4A;
  margin: 0 8rpx;
}

/* 无结果 */
.no-result {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 0;
}
.no-result-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.no-result-text { font-size: 30rpx; font-weight: 600; color: #444; margin-bottom: 10rpx; }
.no-result-sub  { font-size: 24rpx; color: #999; }

/* 结果卡片 */
.result-card {
  background: #FFF; border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
  display: flex;
}

.result-img-wrap {
  width: 220rpx; flex-shrink: 0; position: relative;
}
.result-img { width: 220rpx; height: 200rpx; display: block; }
.result-img-ph {
  width: 220rpx; height: 200rpx;
  background: linear-gradient(135deg, #EFE3D0, #D9C19F);
  display: flex; align-items: center; justify-content: center;
  font-size: 64rpx;
}
.result-avail {
  position: absolute; top: 12rpx; left: 12rpx;
  background: #2E7D5B; color: #FFF;
  font-size: 18rpx; font-weight: 700;
  padding: 4rpx 14rpx; border-radius: 50rpx;
}
.avail-rented { background: rgba(0,0,0,0.45); }

.result-info {
  flex: 1; min-width: 0; padding: 20rpx 20rpx 20rpx 18rpx;
  display: flex; flex-direction: column; justify-content: space-between;
}
.result-name {
  font-size: 28rpx; font-weight: 700; color: #171512;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  display: block;
}
.result-tags { display: flex; flex-wrap: wrap; margin: 8rpx 0; }
.r-tag {
  font-size: 20rpx; padding: 3rpx 12rpx;
  border-radius: 50rpx; margin-right: 8rpx; margin-bottom: 4rpx;
}
.r-tag-district { background: #EAF1F6; color: #0F4C75; }
.r-tag-room     { background: #F4EFE6; color: #0F2F4A; }
.r-tag-area     { background: #F0FFF4; color: #27AE60; }

.result-hood { font-size: 22rpx; color: #999; display: block; }

.result-bottom {
  display: flex; align-items: center;
  justify-content: space-between; margin-top: 10rpx;
}
.result-price {
  font-size: 34rpx; font-weight: 800; color: #B8894D;
}
.price-unit { font-size: 20rpx; font-weight: 400; }
.result-arrow { font-size: 22rpx; color: #0F4C75; }

/* 底部发布 */
.bottom-publish {
  margin: 0 24rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #D8C29E;
}

.bp-icon {
  font-size: 36rpx;
  color: #0F2F4A;
  margin-right: 12rpx;
  font-weight: 300;
}

.bp-text {
  font-size: 28rpx;
  color: #0F2F4A;
  font-weight: 600;
}

/* 2026 UI refresh: soft blue, rounded, action-first */
.page-wrap {
  background: linear-gradient(180deg, #DFF5FA 0%, #EFF8FB 360rpx, #EFF8FB 100%);
  padding: 22rpx 0 28rpx;
}

.select-banner {
  margin: 10rpx 30rpx 0;
  min-height: 136rpx;
  border-radius: 999rpx;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 18rpx 42rpx rgba(39, 122, 139, 0.12);
}

.banner-icon-bg {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: #E2F6F8;
  box-shadow: none;
}

.banner-title,
.platform-name,
.sb-name,
.result-name {
  color: #111111;
}

.banner-sub,
.platform-meta,
.platform-desc,
.sb-category,
.result-hood,
.mini-meta {
  color: #667A82;
}

.banner-action {
  background: #28B8BC;
  color: #FFFFFF;
  border-radius: 999rpx;
  box-shadow: 0 12rpx 26rpx rgba(40, 184, 188, 0.22);
}

.trust-card,
.platform-card,
.filter-panel,
.section-block,
.result-card,
.bottom-publish {
  border-radius: 34rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.trust-card,
.platform-card {
  margin: 18rpx 30rpx 0;
  background: rgba(255, 255, 255, 0.9);
}

.trust-title {
  color: #111111;
}

.trust-badge,
.trust-points text,
.sb-badge,
.tag,
.r-tag-room,
.sh-tag {
  background: #E2F6F8;
  color: #111111;
  border: 0;
  border-radius: 999rpx;
}

.trust-desc,
.sb-desc,
.sb-review,
.filter-panel-title,
.filter-label {
  color: #33464D;
}

.platform-avatar {
  border-radius: 50%;
  background: #111111;
}

.platform-tagline,
.stat-num,
.result-count,
.mini-price,
.result-price,
.bp-icon,
.bp-text,
.sb-link,
.sb-expand text,
.result-arrow {
  color: #111111;
}

.main-tabs {
  margin: 24rpx 30rpx 0;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(39, 122, 139, 0.08);
}

.main-tab {
  border-radius: 999rpx;
  padding: 20rpx 0;
  color: #667A82;
}

.main-tab-active {
  background: #111111;
  color: #FFFFFF;
}

.main-tab-active::after,
.dim-active::after {
  display: none;
}

.dim-row,
.chips-scroll {
  margin-left: 30rpx;
  margin-right: 30rpx;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.dim-item {
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #667A82;
}

.dim-active {
  background: #FFFFFF;
  color: #111111;
  box-shadow: 0 8rpx 20rpx rgba(39, 122, 139, 0.08);
}

.chip,
.f-chip {
  background: rgba(255, 255, 255, 0.88);
  color: #33464D;
  border-radius: 999rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.04);
}

.chip-active,
.f-chip-active {
  background: #28B8BC;
  color: #FFFFFF;
  border-color: #28B8BC;
}

.section-block,
.filter-panel,
.match-results,
.bottom-publish {
  margin-left: 30rpx;
  margin-right: 30rpx;
}

.sb-review-wrap,
.preview-neighborhood-extra {
  background: #F5FCFD;
  border-radius: 24rpx;
}

.sb-review-quote {
  background: #28B8BC;
}

.mini-img-wrap,
.result-img-wrap,
.mini-more,
.result-card {
  border-radius: 28rpx;
}

.mini-card {
  width: 246rpx;
}

.mini-img-wrap,
.mini-img,
.mini-img-ph {
  width: 246rpx;
  height: 204rpx;
}

.mini-title {
  width: 246rpx;
}

.mini-badge,
.result-avail {
  background: rgba(17, 17, 17, 0.78);
  color: #FFFFFF;
}

.available,
