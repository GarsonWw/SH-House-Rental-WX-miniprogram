<!-- pages/landlord/landlord.wxml -->
<view class="page-bg">

  <!-- 顶部身份卡 -->
  <view class="landlord-hero">
    <view class="hero-left">
      <view class="hero-badge">
        <view class="ui-icon ui-icon-shield"></view>
      </view>
      <view class="hero-info">
        <text class="hero-title">管家管理中心</text>
        <text class="hero-sub">实地测评 · 小程序私信 · 0中介费</text>
      </view>
    </view>
    <view class="exit-btn" bindtap="onExitLandlord">退出</view>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-box">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-lbl">总房源</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-box">
      <text class="stat-num green">{{stats.available}}</text>
      <text class="stat-lbl">可租中</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-box">
      <text class="stat-num gray">{{stats.rented}}</text>
      <text class="stat-lbl">已出租</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-box">
      <text class="stat-num orange">{{stats.totalViews}}</text>
      <text class="stat-lbl">总浏览</text>
    </view>
  </view>

  <!-- 发布新房源按钮 -->
  <view class="publish-btn" bindtap="onPublish">
    <view class="publish-icon ui-icon ui-icon-plus"></view>
    <text class="publish-text">发布新房源</text>
  </view>

  <view class="config-entry-card" bindtap="onNeighborhoodConfig">
    <view>
      <text class="config-entry-title">小区详情配置</text>
      <text class="config-entry-sub">发布房源后，按小区单独补充通勤、配套、点评和转化内容</text>
    </view>
    <text class="config-entry-arrow">›</text>
  </view>

  <!-- 筛选 Tab -->
  <view class="filter-tabs">
    <view class="f-tab {{filterStatus === 'all' ? 'f-tab-active' : ''}}"
      bindtap="onFilterChange" data-status="all">全部 ({{stats.total}})</view>
    <view class="f-tab {{filterStatus === 'available' ? 'f-tab-active' : ''}}"
      bindtap="onFilterChange" data-status="available">可租 ({{stats.available}})</view>
    <view class="f-tab {{filterStatus === 'rented' ? 'f-tab-active' : ''}}"
      bindtap="onFilterChange" data-status="rented">已租 ({{stats.rented}})</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-txt">加载中...</text>
  </view>

  <!-- 房源列表（片区 → 小区） -->
  <view wx:else>
    <view class="empty-wrap" wx:if="{{myHouseList.length === 0}}">
      <text class="empty-title">还没有发布任何房源</text>
      <text class="empty-sub">点击上方按钮开始发布</text>
    </view>

    <view class="empty-wrap" wx:elif="{{groupedHouseList.length === 0 && neighborhoodSearchKeyword}}">
      <text class="empty-title">未找到「{{neighborhoodSearchKeyword}}」</text>
      <text class="empty-sub">试试输入小区名称的一部分</text>
    </view>

    <view class="empty-wrap" wx:elif="{{groupedHouseList.length === 0}}">
      <text class="empty-title">当前筛选下暂无房源</text>
      <text class="empty-sub">试试切换到「全部」或其他状态</text>
    </view>

    <block wx:else>
      <view class="fold-actions">
        <view class="fold-search-wrap">
          <text class="fold-search-icon">🔍</text>
          <input
            class="fold-search-input"
            value="{{neighborhoodSearchKeyword}}"
            bindinput="onNeighborhoodSearchInput"
            confirm-type="search"
            placeholder="搜索小区名称"
            placeholder-class="fold-search-placeholder"
          />
          <text
            wx:if="{{neighborhoodSearchKeyword}}"
            class="fold-search-clear"
            catchtap="onClearNeighborhoodSearch"
          >×</text>
        </view>
        <view class="fold-action-btn" bindtap="onExpandAll">全部展开</view>
        <view class="fold-action-btn fold-action-btn-muted" bindtap="onCollapseAll">全部收起</view>
      </view>

      <view class="district-group" wx:for="{{groupedHouseList}}" wx:key="district">
        <view class="district-head" bindtap="onToggleDistrict" data-district="{{item.district}}">
          <view class="district-head-left">
            <text class="fold-arrow {{item.expanded ? 'expanded' : ''}}">›</text>
            <text class="district-name">{{item.district}}</text>
          </view>
          <text class="district-meta">{{item.count}}套 · 可租{{item.available}}</text>
        </view>

        <block wx:if="{{item.expanded}}">
          <view class="neighborhood-group" wx:for="{{item.neighborhoods}}" wx:for-item="nb" wx:key="key">
            <view class="neighborhood-head">
              <view
                class="neighborhood-head-left"
                bindtap="onToggleNeighborhood"
                data-district="{{item.district}}"
                data-key="{{nb.key}}"
              >
                <view class="neighborhood-title-row">
                  <text class="fold-arrow fold-arrow-sm {{nb.expanded ? 'expanded' : ''}}">›</text>
                  <text class="neighborhood-name {{nb.matched && neighborhoodSearchKeyword ? 'neighborhood-name-hit' : ''}}">{{nb.name}}</text>
                </view>
                <text class="neighborhood-meta">{{nb.count}}套 · 可租{{nb.available}}</text>
              </view>
              <view
                class="neighborhood-config-btn"
                catchtap="onEditNeighborhood"
                data-name="{{nb.name}}"
              >配置小区</view>
            </view>

            <block wx:if="{{nb.expanded}}">
              <view class="house-card" wx:for="{{nb.houses}}" wx:for-item="house" wx:key="id">
            <!-- 图片区 -->
            <view class="card-img-wrap" bindtap="onHouseTap" data-id="{{house.id}}">
              <image
                wx:if="{{house.images && house.images.length}}"
                src="{{house.images[0]}}" class="card-img" mode="aspectFill" lazy-load
              />
              <view wx:else class="card-img-ph">
                <view class="ui-icon ui-icon-home"></view>
                <text class="card-img-ph-text">待上传照片</text>
              </view>
              <view class="status-tag {{house.available ? 'tag-ok' : 'tag-rented'}}">
                {{house.available ? '可租' : '已租'}}
              </view>
              <view class="views-tag">浏览 {{house.viewCount || 0}}</view>
            </view>

            <!-- 信息区 -->
            <view class="card-body" bindtap="onHouseTap" data-id="{{house.id}}">
              <text class="card-title">{{house.title}}</text>
              <text class="card-meta">{{house.roomType}} · {{house.area}}㎡</text>
              <text class="card-setup-hint" wx:if="{{house.setupHint}}">{{house.setupHint}}</text>
              <text class="card-price">{{house.price}}<text class="price-u">元/月</text></text>
            </view>

            <!-- 操作行 -->
            <view class="card-actions">
              <view
                class="act-btn act-edit"
                bindtap="onEditHouse"
                data-id="{{house.id}}"
              >编辑</view>
              <view
                class="act-btn act-community"
                bindtap="onEditNeighborhood"
                data-name="{{house.neighborhood}}"
              >配置小区</view>
              <view
                class="act-btn {{house.available ? 'act-rent' : 'act-open'}}"
                bindtap="onToggleStatus"
                data-id="{{house.id}}"
                data-available="{{house.available}}"
              >{{house.available ? '标记已租' : '重新出租'}}</view>
              <view
                class="act-btn act-del"
                catchtap="onDeleteHouse"
                data-id="{{house.id}}"
                data-title="{{house.title}}"
              >删除</view>
            </view>
              </view>
            </block>
          </view>
        </block>
      </view>
    </block>
  </view>

  <view style="height: 60rpx;"></view>
</view>

<!-- 编辑弹窗 -->
<view class="edit-mask" wx:if="{{showEditModal}}" bindtap="onEditCancel">
  <view class="edit-box" catchtap="noop">
    <text class="edit-title">编辑房源信息</text>

    <scroll-view scroll-y class="edit-scroll">
      <view class="edit-section-title">基础信息</view>
      <view class="edit-field">
        <text class="edit-label">标题</text>
        <input class="edit-input" value="{{editForm.title}}" bindinput="onEditInput" data-field="title" placeholder="房源标题" />
      </view>

      <view class="edit-field">
        <text class="edit-label">小区名称</text>
        <input class="edit-input" value="{{editForm.neighborhood}}" bindinput="onEditInput" data-field="neighborhood" placeholder="小区名称" />
      </view>

      <view class="edit-field">
        <text class="edit-label">罗湖片区</text>
        <picker range="{{districtOptions}}" bindchange="onEditPickerChange" data-field="district" data-options="districtOptions">
          <view class="edit-input">{{editForm.district || '请选择罗湖片区'}}</view>
        </picker>
      </view>

      <view class="edit-field">
        <text class="edit-label">详细地址</text>
        <input class="edit-input" value="{{editForm.address}}" bindinput="onEditInput" data-field="address" placeholder="楼栋门牌号" />
      </view>

      <view class="edit-grid">
        <view class="edit-field edit-grid-item">
          <text class="edit-label">月租金（元）</text>
          <input class="edit-input" value="{{editForm.price}}" bindinput="onEditInput" data-field="price" placeholder="月租金" type="digit" />
        </view>
        <view class="edit-field edit-grid-item">
          <text class="edit-label">面积（㎡）</text>
          <input class="edit-input" value="{{editForm.area}}" bindinput="onEditInput" data-field="area" placeholder="面积" type="digit" />
        </view>
      </view>

      <view class="edit-field">
        <text class="edit-label">房型</text>
        <picker range="{{roomTypeOptions}}" bindchange="onEditPickerChange" data-field="roomType" data-options="roomTypeOptions">
          <view class="edit-picker">
            <text class="{{editForm.roomType ? 'edit-picker-value' : 'edit-picker-placeholder'}}">{{editForm.roomType || '请选择房型'}}</text>
            <text class="edit-picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="edit-grid">
        <view class="edit-field edit-grid-item">
          <text class="edit-label">楼层</text>
          <input class="edit-input" value="{{editForm.floor}}" bindinput="onEditInput" data-field="floor" placeholder="如：8/18层" />
        </view>
        <view class="edit-field edit-grid-item">
          <text class="edit-label">朝向</text>
          <picker range="{{orientationOptions}}" bindchange="onEditPickerChange" data-field="orientation" data-options="orientationOptions">
            <view class="edit-picker">
              <text class="{{editForm.orientation ? 'edit-picker-value' : 'edit-picker-placeholder'}}">{{editForm.orientation || '请选择'}}</text>
              <text class="edit-picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="edit-field">
        <text class="edit-label">装修</text>
        <picker range="{{decorationOptions}}" bindchange="onEditPickerChange" data-field="decoration" data-options="decorationOptions">
          <view class="edit-picker">
            <text class="{{editForm.decoration ? 'edit-picker-value' : 'edit-picker-placeholder'}}">{{editForm.decoration || '请选择装修情况'}}</text>
            <text class="edit-picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="edit-field">
        <text class="edit-label">房源描述</text>
        <textarea class="edit-textarea" value="{{editForm.description}}" bindinput="onEditInput" data-field="description" placeholder="补充描述（可选）" />
      </view>

      <view class="edit-section-title">管家信息</view>
      <view class="edit-prefill-btn" bindtap="onPrefillEditLandlordInfo">一键填充：管家居居侠 · 13520174107</view>

      <view class="edit-field">
        <text class="edit-label">管家姓名</text>
        <input class="edit-input" value="{{editForm.landlordName}}" bindinput="onEditInput" data-field="landlordName" placeholder="管家姓名" />
      </view>

      <view class="edit-field">
        <text class="edit-label">联系电话</text>
        <input class="edit-input" value="{{editForm.landlordPhone}}" bindinput="onEditInput" data-field="landlordPhone" placeholder="联系电话" type="number" maxlength="11" />
      </view>

      <view class="edit-section-title">状态与标签</view>
      <view class="edit-status-row">
        <view
          class="edit-status {{editForm.available ? 'edit-status-active' : ''}}"
          bindtap="onEditStatusChange"
          data-available="true"
        >可租</view>
        <view
          class="edit-status {{!editForm.available ? 'edit-status-rented' : ''}}"
          bindtap="onEditStatusChange"
          data-available="false"
        >已租</view>
      </view>

      <view class="edit-field">
        <text class="edit-label">房源标签（最多5个）</text>
        <view class="edit-tags">
          <view
            class="edit-tag {{editForm.tags.indexOf(item) > -1 ? 'edit-tag-active' : ''}}"
            wx:for="{{tagOptions}}"
            wx:key="index"
            bindtap="onEditTagToggle"
            data-tag="{{item}}"
          >{{item}}</view>
        </view>
      </view>
    </scroll-view>

    <view class="edit-btns">
      <view class="edit-cancel" bindtap="onEditCancel">取消</view>
      <view class="edit-confirm" bindtap="onEditConfirm">保存</view>
    </view>
  </view>
</view>
