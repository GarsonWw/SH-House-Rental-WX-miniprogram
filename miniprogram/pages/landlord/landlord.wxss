/* pages/landlord/landlord.wxss */
.page-bg { background: #F0F4F8; min-height: 100vh; }

/* 顶部身份卡 */
.landlord-hero {
  background: linear-gradient(135deg, #1A3A5C, #0F4C75);
  padding: 48rpx 32rpx 40rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.hero-left { display: flex; align-items: center; }
.hero-badge {
  width: 88rpx; height: 88rpx; border-radius: 20rpx;
  background: rgba(255,255,255,0.2); border: 3rpx solid rgba(255,255,255,0.4);
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; margin-right: 20rpx;
}
.hero-title { font-size: 36rpx; font-weight: 800; color: #FFF; display: block; }
.hero-sub   { font-size: 22rpx; color: rgba(255,255,255,0.75); margin-top: 5rpx; display: block; }
.exit-btn {
  font-size: 24rpx; color: rgba(255,255,255,0.8);
  border: 1rpx solid rgba(255,255,255,0.4);
  padding: 10rpx 24rpx; border-radius: 50rpx;
}

/* 统计行 */
.stats-row {
  background: #FFF; margin: 20rpx 24rpx 0;
  border-radius: 20rpx; padding: 24rpx 8rpx;
  display: flex; justify-content: space-around;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.stat-box { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 44rpx; font-weight: 900; color: #222; }
.stat-num.green  { color: #2E7D5B; }
.stat-num.gray   { color: #999; }
.stat-num.orange { color: #B8894D; }
.stat-lbl { font-size: 20rpx; color: #999; margin-top: 6rpx; }
.stat-divider { width: 1rpx; background: #F0F0F0; align-self: center; height: 44rpx; }

/* 发布按钮 */
.publish-btn {
  background: linear-gradient(135deg, #0F2F4A, #1C4966);
  margin: 20rpx 24rpx 0; border-radius: 20rpx;
  padding: 28rpx; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(15,47,74,0.24);
}
.publish-icon { font-size: 40rpx; color: #FFF; margin-right: 12rpx; font-weight: 200; }
.publish-text { font-size: 32rpx; font-weight: 700; color: #FFF; }

.config-entry-card {
  margin: 18rpx 24rpx 0;
  padding: 26rpx 28rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
  border: 1rpx solid rgba(17, 17, 17, 0.05);
}

.config-entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #111111;
}

.config-entry-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #667A82;
  line-height: 1.5;
}

.config-entry-arrow {
  font-size: 44rpx;
  color: #28B8BC;
  margin-left: 20rpx;
}

/* 筛选 Tab */
.filter-tabs {
  display: flex; background: #FFF;
  margin: 20rpx 24rpx 0; border-radius: 16rpx;
  overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.f-tab {
  flex: 1; text-align: center; padding: 22rpx 0;
  font-size: 26rpx; color: #999;
  border-bottom: 4rpx solid transparent;
}
.f-tab-active { color: #1A3A5C; font-weight: 700; border-bottom-color: #0F4C75; }

/* 加载/空 */
.loading-wrap { padding: 60rpx; text-align: center; }
.loading-txt  { font-size: 26rpx; color: #BBB; }
.empty-wrap   { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon   { font-size: 90rpx; margin-bottom: 20rpx; }
.empty-title  { font-size: 32rpx; font-weight: 600; color: #444; }
.empty-sub    { font-size: 24rpx; color: #999; margin-top: 10rpx; }

/* 房源卡片 */
.house-card {
  background: #FFF; margin: 16rpx 24rpx 0;
  border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.card-img-wrap { position: relative; height: 200rpx; }
.card-img { width: 100%; height: 200rpx; display: block; }
.card-img-ph {
  width: 100%; height: 200rpx;
  background: linear-gradient(135deg, #E8EFF8, #C8D8F0);
  display: flex; align-items: center; justify-content: center; font-size: 80rpx;
}
.status-tag {
  position: absolute; top: 16rpx; left: 16rpx;
  font-size: 20rpx; font-weight: 700; padding: 5rpx 16rpx; border-radius: 50rpx;
}
.tag-ok     { background: #2E7D5B; color: #FFF; }
.tag-rented { background: rgba(0,0,0,0.5); color: #FFF; }
.views-tag {
  position: absolute; top: 16rpx; right: 16rpx;
  background: rgba(0,0,0,0.45); color: #FFF;
  font-size: 20rpx; padding: 5rpx 14rpx; border-radius: 50rpx;
}

.card-body { padding: 20rpx 24rpx 12rpx; }
.card-title {
  font-size: 28rpx; font-weight: 700; color: #171512;
  display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.card-meta  { font-size: 22rpx; color: #999; display: block; margin-top: 6rpx; }
.card-price { font-size: 34rpx; font-weight: 800; color: #0F2F4A; display: block; margin-top: 8rpx; }
.price-u    { font-size: 20rpx; font-weight: 400; }

.card-actions {
  display: flex; flex-wrap: wrap; padding: 0 20rpx 12rpx; border-top: 1rpx solid #F4F1EA; padding-top: 16rpx;
}
.act-btn { font-size: 24rpx; padding: 12rpx 22rpx; border-radius: 10rpx; margin-right: 10rpx; margin-bottom: 10rpx; }
.act-edit  { background: #FFFBF0; color: #E6920A; }
.act-community { background: #EEF6FF; color: #0F4C75; }
.act-rent  { background: #EAF1F6; color: #0F4C75; }
.act-open  { background: #F0FFF4; color: #2E7D5B; }
.act-del   { background: #F7ECE7; color: #A64B3C; }

/* 编辑弹窗 */
.edit-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 999;
  display: flex; align-items: flex-end;
}
.edit-box {
  background: #FFF; border-radius: 28rpx 28rpx 0 0;
  padding: 40rpx 32rpx 60rpx; width: 100%;
}
.edit-title { font-size: 34rpx; font-weight: 800; color: #171512; display: block; margin-bottom: 32rpx; }
.edit-scroll { max-height: 70vh; }
.edit-section-title {
  font-size: 24rpx; font-weight: 800; color: #1A3A5C;
  margin: 8rpx 0 20rpx; padding-left: 14rpx;
  border-left: 6rpx solid #0F4C75;
}
.edit-field { margin-bottom: 24rpx; }
.edit-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 10rpx; }
.edit-grid {
  display: flex; gap: 18rpx;
}
.edit-grid-item {
  flex: 1;
}
.edit-input {
  width: 100%; background: #F4F1EA; border-radius: 12rpx;
  padding: 20rpx; font-size: 28rpx; color: #222;
  border: 2rpx solid #E6E0D8; box-sizing: border-box;
}
.edit-picker {
  height: 82rpx; background: #F4F1EA; border-radius: 12rpx;
  padding: 0 20rpx; border: 2rpx solid #E6E0D8;
  display: flex; align-items: center; justify-content: space-between;
  box-sizing: border-box;
}
.edit-picker-value { font-size: 28rpx; color: #222; }
.edit-picker-placeholder { font-size: 28rpx; color: #BBB; }
.edit-picker-arrow { font-size: 36rpx; color: #BBB; }
.edit-textarea {
  width: 100%; background: #F4F1EA; border-radius: 12rpx;
  padding: 20rpx; font-size: 26rpx; color: #222; height: 160rpx;
  border: 2rpx solid #E6E0D8; box-sizing: border-box;
}
.edit-prefill-btn {
  background: #EAF1F6; color: #0F4C75;
  border: 2rpx solid #C9D8E3; border-radius: 12rpx;
  padding: 18rpx 20rpx; font-size: 24rpx;
  font-weight: 600; margin-bottom: 24rpx; text-align: center;
}
.edit-status-row {
  display: flex; margin-bottom: 24rpx;
}
.edit-status {
  padding: 14rpx 42rpx; border-radius: 999rpx;
  background: #F4F1EA; color: #888; font-size: 26rpx;
  border: 2rpx solid #E6E0D8; margin-right: 18rpx;
}
.edit-status-active {
  color: #2E7D5B; background: #EAF6EF; border-color: #2E7D5B; font-weight: 700;
}
.edit-status-rented {
  color: #999; background: #F4F1EA; border-color: #BBB; font-weight: 700;
}
.edit-tags {
  display: flex; flex-wrap: wrap; gap: 14rpx;
}
.edit-tag {
  font-size: 24rpx; color: #666;
  padding: 12rpx 20rpx; border-radius: 999rpx;
  background: #F4F1EA; border: 2rpx solid #E6E0D8;
}
.edit-tag-active {
  color: #FFF; background: #0F4C75; border-color: #0F4C75;
}
.edit-btns { display: flex; margin-top: 32rpx; }
.edit-cancel {
  flex: 1; text-align: center; padding: 22rpx 0; font-size: 28rpx; color: #999;
  border: 1rpx solid #E0E0E0; border-radius: 50rpx; margin-right: 16rpx;
}
.edit-confirm {
  flex: 2; text-align: center; padding: 22rpx 0; font-size: 28rpx; font-weight: 700; color: #FFF;
  background: linear-gradient(135deg, #1A3A5C, #0F4C75); border-radius: 50rpx;
}

/* 2026 UI refresh */
.page-bg,
.landlord-page,
.container {
  background: #EFF8FB;
}

.stat-card,
.house-card,
.empty-card,
.edit-box,
.edit-input,
.edit-picker,
.edit-textarea {
  border-radius: 34rpx;
}

.stat-card,
.house-card,
.empty-card,
.edit-box {
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.card-title,
.card-name,
.card-price,
.edit-title,
.edit-section-title,
.edit-picker-value {
  color: #111111;
}

.card-meta,
.edit-label,
.edit-picker-placeholder {
  color: #667A82;
}

.publish-btn,
.edit-confirm,
.edit-tag-active,
.edit-status-active {
  background: #28B8BC;
  border-color: #28B8BC;
  color: #FFFFFF;
  border-radius: 999rpx;
}

.act-btn,
.edit-prefill-btn,
.edit-status,
.edit-tag {
  border-radius: 999rpx;
}

.edit-input,
.edit-picker,
.edit-textarea {
  background: #F5FCFD;
  border-color: rgba(17, 17, 17, 0.08);
}
