<!-- pages/map/map.wxml -->
<view class="map-page">

  <!-- 地图主体 -->
  <map
    id="myMap"
    class="map-view"
    latitude="{{mapLat}}"
    longitude="{{mapLng}}"
    scale="{{scale}}"
    markers="{{markers}}"
    enable-zoom
    enable-scroll
    enable-rotate="{{false}}"
    bindmarkertap="onMarkerTap"
    bindtap="onMapTap"
    bindregionchange="onRegionChange"
  />

  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-inner">
      <view class="search-mark ui-icon ui-icon-search"></view>
      <input
        class="search-input"
        placeholder="搜索小区或地址，点击标记查看房源"
        placeholder-class="search-ph"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 缩放提示 -->
  <view class="scale-tip">缩放: {{currentScale}}</view>

  <!-- 右侧图层按钮 -->
  <view class="layer-panel">
    <view
      class="layer-btn {{activeLayer === item.key ? 'layer-active' : ''}}"
      wx:for="{{layers}}"
      wx:key="key"
      bindtap="onLayerTap"
      data-key="{{item.key}}"
    >
      <view class="layer-mark ui-icon ui-icon-{{item.icon}}"></view>
      <text class="layer-label">{{item.label}}</text>
    </view>
    <view class="reset-map-btn" bindtap="onResetMap">
      <view class="reset-map-icon">◎</view>
      <text class="reset-map-text">回正</text>
    </view>
  </view>

  <!-- 罗湖片区筛选浮层 -->
  <view class="district-panel" wx:if="{{showDistrictPanel}}">
    <view
      class="dp-item {{selectedDistrict === item ? 'dp-active' : ''}}"
      wx:for="{{districtList}}"
      wx:key="index"
      bindtap="onDistrictSelect"
      data-district="{{item}}"
    >{{item}}</view>
  </view>

  <!-- 底部提示卡片（无选中时） -->
  <view class="hint-cards" wx:if="{{!showSheet}}">
    <view class="hint-card">
      <view class="hint-mark ui-icon ui-icon-map"></view>
      <text class="hint-txt">点击地图标记查看该小区房源</text>
    </view>
    <view class="hint-card">
      <view class="hint-mark ui-icon ui-icon-home"></view>
      <text class="hint-txt">共 {{markers.length}} 个小区有在租房源</text>
    </view>
  </view>

  <!-- 底部房源列表浮层 -->
  <view class="bottom-sheet {{showSheet ? 'sheet-show' : ''}}">
    <!-- 拖动指示条 -->
    <view class="sheet-handle"></view>

    <!-- 标题行 -->
    <view class="sheet-header">
      <view class="sheet-title-block">
        <view class="sheet-title-wrap">
          <text class="sheet-title">{{sheetNeighborhood}}</text>
          <text class="sheet-count">{{sheetTotalCount}}套在租</text>
        </view>
        <text class="sheet-sub" wx:if="{{sheetDistrict || sheetPriceText}}">
          {{sheetDistrict}}{{sheetDistrict && sheetPriceText ? ' · ' : ''}}{{sheetPriceText}}
        </text>
        <text class="sheet-address" wx:if="{{sheetAddress}}">📍 {{sheetAddress}}</text>
      </view>
      <view class="sheet-close" bindtap="onCloseSheet">关闭</view>
    </view>

    <view class="sheet-actions">
      <view class="sheet-action-btn" bindtap="onOpenSheetDetail">
        <view class="sheet-action-icon ui-icon ui-icon-home"></view>
        <text>看测评</text>
      </view>
      <view
        class="sheet-action-btn sheet-action-primary {{sheetHasLocation ? '' : 'sheet-action-disabled'}}"
        bindtap="onOpenSheetMap"
      >
        <view class="sheet-action-icon ui-icon ui-icon-map"></view>
        <text>导航</text>
      </view>
      <button
        class="sheet-action-btn sheet-action-contact"
        open-type="contact"
        show-message-card="true"
        send-message-title="{{sheetNeighborhood}}联系管家"
        send-message-path="/pages/messages/messages"
        session-from="map-sheet-contact"
        hover-class="none"
      >
        <view class="sheet-action-icon ui-icon ui-icon-chat"></view>
        <text>联系管家</text>
      </button>
    </view>

    <!-- 智能找房 -->
    <view class="sheet-match" wx:if="{{sheetTotalCount > 0}}">
      <view class="sheet-filter-panel">
        <text class="sheet-filter-title">在本小区按预算和户型筛选</text>

        <view class="sheet-filter-row">
          <text class="sheet-filter-label">💰 价格</text>
          <scroll-view scroll-x class="sheet-filter-scroll" enable-flex>
            <view class="sheet-filter-chips">
              <view
                class="sheet-f-chip {{selectedPriceIdx === index ? 'sheet-f-chip-active' : ''}}"
                wx:for="{{priceRanges}}"
                wx:key="index"
                bindtap="onSheetPriceSelect"
                data-idx="{{index}}"
              >{{item}}</view>
            </view>
          </scroll-view>
        </view>

        <view class="sheet-filter-row">
          <text class="sheet-filter-label">🏡 房型</text>
          <scroll-view scroll-x class="sheet-filter-scroll" enable-flex>
            <view class="sheet-filter-chips">
              <view
                class="sheet-f-chip {{selectedRoomType === item ? 'sheet-f-chip-active' : ''}}"
                wx:for="{{roomTypes}}"
                wx:key="index"
                bindtap="onSheetRoomTypeSelect"
                data-type="{{item}}"
              >{{item}}</view>
            </view>
          </scroll-view>
        </view>
      </view>

      <view class="sheet-match-summary" wx:if="{{hasSheetMatchSearched}}">
        <text class="sheet-match-text">为你找到 </text>
        <text class="sheet-match-count">{{sheetMatchCount}}</text>
        <text class="sheet-match-text"> 套房源</text>
      </view>
    </view>

    <!-- 房源列表 -->
    <view class="sheet-list-wrap">
      <scroll-view scroll-y class="sheet-list" enhanced show-scrollbar>
      <view class="sheet-empty" wx:if="{{hasSheetMatchSearched && sheetMatchCount === 0}}">
        <text>暂无符合条件的房源，试试放宽价格或房型条件</text>
      </view>

      <view
        class="sheet-house"
        wx:for="{{sheetHouses}}"
        wx:key="id"
        bindtap="onHouseTap"
        data-id="{{item.id}}"
      >
        <!-- 图片 -->
        <view class="sh-img-wrap">
          <image
            wx:if="{{item.images && item.images.length > 0}}"
            src="{{item.images[0]}}"
            class="sh-img"
            mode="aspectFill"
            lazy-load
          />
          <view wx:else class="sh-img-ph">
            <view class="ui-icon ui-icon-home"></view>
          </view>
          <view class="sh-status" wx:if="{{item.available}}">
            可租
          </view>
        </view>

        <!-- 信息 -->
        <view class="sh-info">
          <text class="sh-title">{{item.title}}</text>
          <text class="sh-meta">{{item.roomType}} · {{item.area}}㎡ · {{item.floor}}</text>
          <view class="sh-tags">
            <text class="sh-tag" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">{{tag}}</text>
          </view>
          <view class="sh-footer">
            <text class="sh-price">{{item.price}}<text class="sh-price-unit">元/月</text></text>
            <view class="sh-contacts">
              <view
                class="sh-contact-btn sh-phone"
                catchtap="onPhoneCall"
                data-phone="{{item.landlordPhone}}"
                data-name="{{item.landlordName}}"
              >
                <view class="sh-contact-icon ui-icon ui-icon-phone"></view>
                <text>电话</text>
              </view>
              <button
                class="sh-contact-btn sh-wechat"
                open-type="contact"
                show-message-card="true"
                send-message-title="{{item.neighborhood}}在线咨询"
                send-message-path="/pages/detail/detail?id={{item.id}}"
                session-from="map-sheet"
                hover-class="none"
              >
                <view class="sh-contact-icon ui-icon ui-icon-chat"></view>
                <text>咨询</text>
              </button>
            </view>
          </view>
        </view>
      </view>

      <view class="sheet-bottom-space"></view>
      </scroll-view>
    </view>
  </view>

</view>
