/* pages/map/map.wxss */
.map-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* 地图全屏 */
.map-view {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ── 顶部搜索栏 ─────────────────────────────── */
.search-bar {
  position: absolute;
  top: 20rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  z-index: 100;
}

.search-inner {
  flex: 1;
  background: #FFFFFF;
  border-radius: 50rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

.search-icon-txt {
  font-size: 30rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #27241F;
  height: 72rpx;
  line-height: 72rpx;
}

.search-ph {
  color: #A8A196;
  font-size: 24rpx;
}

.search-btn {
  background: #0F4C75;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 50rpx;
  margin-left: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(26,95,180,0.35);
  flex-shrink: 0;
}

/* ── 缩放提示 ───────────────────────────────── */
.scale-tip {
  position: absolute;
  top: 108rpx;
  right: 24rpx;
  background: rgba(0,0,0,0.5);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 50rpx;
  z-index: 100;
}

/* ── 右侧图层按钮 ────────────────────────────── */
.layer-panel {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  z-index: 100;
}

.layer-btn {
  width: 100rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.12);
}

.layer-active {
  background: #EAF1F6;
  border: 2rpx solid #0F4C75;
}

.layer-icon {
  font-size: 36rpx;
}

.layer-label {
  font-size: 20rpx;
  color: #45413B;
  margin-top: 6rpx;
  font-weight: 500;
}

.layer-active .layer-label {
  color: #0F4C75;
  font-weight: 700;
}

/* ── 区域筛选浮层 ────────────────────────────── */
.district-panel {
  position: absolute;
  right: 140rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 12rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.15);
  z-index: 200;
}

.dp-item {
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #27241F;
  border-radius: 10rpx;
  white-space: nowrap;
}

.dp-active {
  background: #EAF1F6;
  color: #0F4C75;
  font-weight: 700;
}

/* ── 定位按钮 ───────────────────────────────── */
.locate-btn {
  position: absolute;
  left: 24rpx;
  bottom: 380rpx;
  width: 80rpx;
  height: 80rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.15);
  z-index: 100;
}

.locate-icon {
  font-size: 36rpx;
  color: #0F4C75;
}

/* ── 底部提示卡片 ────────────────────────────── */
.hint-cards {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.hint-card {
  background: rgba(255,255,255,0.92);
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hint-txt {
  font-size: 24rpx;
  color: #45413B;
}

/* ── 底部房源浮层 ────────────────────────────── */
.bottom-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 300;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -4rpx 32rpx rgba(0,0,0,0.12);
}

.sheet-show {
  transform: translateY(0);
}

.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: #E0E0E0;
  border-radius: 3rpx;
  margin: 16rpx auto 0;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #F4F1EA;
}

.sheet-title-wrap {
  display: flex;
  align-items: center;
}

.sheet-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #171512;
  margin-right: 14rpx;
}

.sheet-count {
  background: #EAF1F6;
  color: #0F4C75;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
}

.sheet-close {
  font-size: 36rpx;
  color: #A8A196;
  padding: 8rpx;
}

/* 房源列表 */
.sheet-list {
  flex: 1;
  overflow: hidden;
  max-height: 54vh;
}

.sheet-house {
  display: flex;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #F8F6F1;
}

.sh-img-wrap {
  position: relative;
  width: 160rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.sh-img {
  width: 160rpx;
  height: 140rpx;
}

.sh-img-ph {
  width: 160rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #EFE3D0, #D9C19F);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.sh-status {
  position: absolute;
  bottom: 6rpx;
  left: 6rpx;
  background: #2E7D5B;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 700;
  padding: 3rpx 10rpx;
  border-radius: 50rpx;
}

.sh-rented {
  background: rgba(0,0,0,0.4);
}

.sh-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.sh-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #171512;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sh-meta {
  font-size: 22rpx;
  color: #7A746B;
  display: block;
  margin-top: 6rpx;
}

.sh-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.sh-tag {
  font-size: 20rpx;
  color: #0F2F4A;
  background: #F4EFE6;
  padding: 3rpx 12rpx;
  border-radius: 50rpx;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}

.sh-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.sh-price {
  font-size: 32rpx;
  font-weight: 800;
  color: #0F2F4A;
}

.sh-price-unit {
  font-size: 20rpx;
  font-weight: 400;
}

.sh-contacts {
  display: flex;
}

.sh-contact-btn {
  font-size: 21rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 50rpx;
  margin-left: 10rpx;
}

.sh-phone {
  background: #EAF1F6;
  color: #0F4C75;
}

.sh-wechat {
  background: #EAF6EF;
  color: #1F8A5B;
}

.sheet-bottom-space {
  height: env(safe-area-inset-bottom);
  min-height: 30rpx;
}

/* 2026 UI refresh */
.search-inner,
.search-btn,
.scale-tip,
.layer-btn,
.district-panel,
.locate-btn,
.hint-card,
.bottom-sheet,
.sheet-house,
.sh-contact-btn {
  border-radius: 999rpx;
}

.bottom-sheet {
  border-radius: 42rpx 42rpx 0 0;
  box-shadow: 0 -18rpx 46rpx rgba(39, 122, 139, 0.14);
}

.search-inner,
.layer-btn,
.district-panel,
.locate-btn,
.hint-card,
.sheet-house {
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.12);
}

.search-btn,
.layer-active,
.dp-active,
.sh-phone,
.sh-wechat {
  background: #28B8BC;
  color: #FFFFFF;
  border-color: #28B8BC;
}

.search-input,
.dp-item,
.sheet-title,
.sh-title,
.sh-price,
.sh-price-unit,
.locate-icon,
.layer-active .layer-label {
  color: #111111;
}

.search-ph,
.layer-label,
.hint-txt,
.sh-meta {
  color: #667A82;
}

.sheet-count,
.sh-tag {
  background: #DDF5F8;
  color: #111111;
  border-radius: 999rpx;
}

.sheet-header {
  border-bottom-color: rgba(17, 17, 17, 0.06);
}

.sh-img,
.sh-img-ph {
  border-radius: 24rpx;
}

.sh-available {
  background: #28B8BC;
}

.scale-tip {
  background: rgba(17, 17, 17, 0.72);
}
