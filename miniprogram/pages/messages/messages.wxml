<!-- pages/messages/messages.wxml -->
<view class="messages-page">
  <view class="message-hero">
    <text class="message-kicker">在线咨询</text>
    <text class="message-title">管家居居侠</text>
    <text class="message-sub">把找房条件一次说清，管家按通勤和实地测评继续匹配。</text>
  </view>

  <button
    class="consult-btn"
    open-type="contact"
    show-message-card="true"
    send-message-title="联系管家居居侠"
    send-message-path="/pages/messages/messages"
    session-from="messages-tab"
    hover-class="none"
  >
    在线咨询管家
  </button>

  <view class="message-card focus-card">
    <view class="card-head">
      <text class="card-title">建议先发这三项</text>
      <text class="status-pill">更快匹配</text>
    </view>
    <view class="focus-list">
      <view class="focus-item">
        <text class="focus-label">预算</text>
        <text class="focus-text">可接受月租和押付方式</text>
      </view>
      <view class="focus-item">
        <text class="focus-label">通勤</text>
        <text class="focus-text">学校、公司或常用口岸</text>
      </view>
      <view class="focus-item">
        <text class="focus-label">时间</text>
        <text class="focus-text">入住日期和预计租期</text>
      </view>
    </view>
  </view>

  <view class="share-section">
    <view class="share-head">
      <text class="share-title">我的收藏房源</text>
      <text class="share-note">{{favoriteHouses.length}} 套可咨询</text>
    </view>

    <view class="favorite-empty" wx:if="{{favoriteHouses.length === 0}}">
      <text class="favorite-empty-title">暂无收藏房源</text>
      <text class="favorite-empty-sub">先收藏感兴趣的房源，再从这里发给管家继续咨询。</text>
    </view>

    <view
      class="share-house"
      wx:for="{{favoriteHouses}}"
      wx:key="id"
      bindtap="onHouseTap"
      data-id="{{item.id}}"
    >
      <image
        wx:if="{{item.cover}}"
        class="share-img"
        src="{{item.cover}}"
        mode="aspectFill"
        lazy-load
      />
      <view wx:else class="share-img share-img-empty">
        <view class="ui-icon ui-icon-home"></view>
      </view>
      <view class="share-info">
        <text class="share-house-title">{{item.title}}</text>
        <text class="share-meta">{{item.neighborhood}} · {{item.roomType}} · {{item.area}}㎡</text>
        <view class="share-bottom">
          <text class="share-price">{{item.price}}元/月</text>
          <button
            class="share-btn"
            open-type="contact"
            show-message-card="true"
            send-message-title="{{item.consultTitle}}"
            send-message-path="/pages/detail/detail?id={{item.id}}"
            session-from="favorite-house"
            catchtap="noop"
            hover-class="none"
          >
            发给管家
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="tab-bottom-space"></view>
</view>
