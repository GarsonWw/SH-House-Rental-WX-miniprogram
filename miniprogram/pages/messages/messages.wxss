/* pages/messages/messages.wxss */
.messages-page {
  min-height: 100vh;
  background: #EFF8FB;
  padding: 28rpx 30rpx 0;
  box-sizing: border-box;
}

.message-hero {
  padding: 38rpx 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #DDF5F8, #FFFFFF);
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.message-kicker,
.message-title,
.message-sub {
  display: block;
}

.message-kicker {
  font-size: 24rpx;
  color: #28B8BC;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.message-title {
  font-size: 44rpx;
  color: #111111;
  font-weight: 900;
  line-height: 1.25;
}

.message-sub {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: #667A82;
  line-height: 1.55;
}

.consult-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  margin: 24rpx 0 0;
  border-radius: 28rpx;
  background: #28B8BC;
  color: #FFFFFF;
  font-size: 31rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 32rpx rgba(40, 184, 188, 0.24);
}

.consult-btn::after {
  border: 0;
}

.message-card {
  background: #FFFFFF;
  border-radius: 30rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
  margin-top: 24rpx;
  padding: 26rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 31rpx;
  color: #111111;
  font-weight: 900;
}

.status-pill {
  font-size: 22rpx;
  color: #111111;
  background: #DDF5F8;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 800;
}

.focus-card {
  background: #F8FEFF;
}

.focus-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.focus-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
}

.focus-label {
  width: 88rpx;
  color: #111111;
  font-size: 25rpx;
  font-weight: 900;
}

.focus-text {
  flex: 1;
  color: #667A82;
  font-size: 25rpx;
  line-height: 1.45;
}

.share-section {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.share-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.share-title {
  font-size: 31rpx;
  color: #111111;
  font-weight: 900;
}

.share-note {
  font-size: 22rpx;
  color: #111111;
  background: #DDF5F8;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 800;
}

.favorite-empty {
  padding: 34rpx 24rpx;
  border-radius: 24rpx;
  background: #F5FCFD;
  border: 1rpx dashed rgba(40, 184, 188, 0.28);
}

.favorite-empty-title,
.favorite-empty-sub {
  display: block;
}

.favorite-empty-title {
  color: #111111;
  font-size: 28rpx;
  font-weight: 900;
}

.favorite-empty-sub {
  margin-top: 10rpx;
  color: #667A82;
  font-size: 24rpx;
  line-height: 1.55;
}

.share-house {
  display: flex;
  align-items: stretch;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(17, 17, 17, 0.06);
}

.share-house:first-of-type {
  border-top: 0;
}

.share-img {
  width: 150rpx;
  height: 132rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  background: #DDF5F8;
}

.share-img-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #28B8BC;
}

.share-info {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.share-house-title {
  font-size: 27rpx;
  color: #111111;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.28;
}

.share-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #667A82;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-price {
  font-size: 26rpx;
  color: #111111;
  font-weight: 900;
}

.share-bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.share-btn {
  width: 116rpx;
  height: 54rpx;
  line-height: 54rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #DDF5F8;
  color: #0F4C75;
  font-size: 23rpx;
  font-weight: 900;
  flex-shrink: 0;
  box-shadow: none;
}

.share-btn::after {
  border: 0;
}
