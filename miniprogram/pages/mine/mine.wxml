<!-- pages/mine/mine.wxml -->
<view class="page-bg">

  <!-- ══ 未登录状态 ══ -->
  <view wx:if="{{!isLoggedIn}}" class="login-page">
    <view class="login-hero">
      <view class="login-big-icon">
        <view class="ui-icon ui-icon-route"></view>
      </view>
      <text class="login-title">深港租房双城通</text>
      <text class="login-sub">登录后使用收藏夹、个人资料等个性化功能</text>
    </view>
    <view class="login-btn" bindtap="onLogin">微信一键登录</view>
    <view class="login-hint">登录后您的收藏数据将同步云端，换设备不丢失</view>

    <view class="brand-trust-card">
      <text class="brand-trust-title">从业10年 · 深港通勤多年经验</text>
      <text class="brand-trust-desc">专注深圳罗湖租房服务，坚持免中介费、真实房源、实地测评，结合深港通勤经验帮你更安心找罗湖房。</text>
      <view class="brand-trust-tags">
        <text>只做罗湖</text>
        <text>免中介费</text>
        <text>真实房源</text>
      </view>
    </view>

  </view>

  <!-- ══ 已登录状态 ══ -->
  <view wx:else>

    <!-- 用户头部 -->
    <view class="user-header">
      <view class="avatar-wrap" bindtap="onSetProfile">
        <image
          wx:if="{{userProfile && userProfile.avatarUrl}}"
          src="{{userProfile.avatarUrl}}"
          class="user-avatar-img"
          mode="aspectFill"
        />
        <view wx:else class="user-avatar-ph">
          <view class="ui-icon ui-icon-user"></view>
        </view>
        <view class="user-info">
          <text class="user-name">{{userProfile ? userProfile.nickName : '点击设置昵称'}}</text>
          <text class="user-sub">深港找房 · 0中介费</text>
        </view>
      </view>
      <view class="edit-profile" bindtap="onSetProfile">
        <text>编辑</text>
      </view>
    </view>

    <view class="brand-trust-card logged-trust">
      <text class="brand-trust-title">可靠的罗湖租房直租服务</text>
      <text class="brand-trust-desc">累计服务超过1000+位租客，深耕罗湖口岸、国贸、东门、黄贝岭、翠竹、笋岗等片区，陪伴用户完成从看房到入住的全过程。</text>
      <view class="brand-trust-tags">
        <text>从业10年</text>
        <text>免中介费</text>
        <text>只做罗湖</text>
      </view>
    </view>

    <!-- 功能入口卡 -->
    <view class="entry-card">
      <view class="entry-title-bar"><text class="entry-title-txt">我的功能</text></view>

      <view class="entry-item" bindtap="onGoFavorites">
        <view class="entry-left">
          <view class="entry-icon-bg fav-bg">
            <view class="ui-icon ui-icon-bookmark"></view>
          </view>
          <view class="entry-info">
            <text class="entry-name">我的收藏夹</text>
            <text class="entry-sub">已收藏 {{favoriteCount}} 套房源</text>
          </view>
        </view>
        <view class="entry-right">
          <view class="entry-badge fav-badge" wx:if="{{favoriteCount > 0}}">{{favoriteCount}}</view>
          <text class="entry-arr">›</text>
        </view>
      </view>

    </view>

    <!-- 菜单 -->
    <view class="menu-card">
      <view class="menu-item" bindtap="onAbout">
        <view class="menu-icon">
          <view class="ui-icon ui-icon-info"></view>
        </view>
        <text class="menu-txt">关于平台</text>
        <text class="menu-arr">›</text>
      </view>
    </view>

    <!-- 仅管理员 OPENID 显示管理中心 -->
    <view class="landlord-entry le-active" wx:if="{{isLandlord}}" bindtap="onLandlordEntry">
      <view class="le-icon">
        <view class="ui-icon ui-icon-shield"></view>
      </view>
      <text class="le-text">管家管理中心</text>
      <text class="le-arr">›</text>
    </view>

  </view>

  <view class="tab-bottom-space"></view>
</view>

<!-- 资料编辑弹窗 -->
<view class="modal-mask" wx:if="{{showProfileModal}}" bindtap="onProfileCancel">
  <view class="profile-modal-box" catchtap="noop">
    <text class="modal-title">编辑个人资料</text>
    <text class="modal-sub">设置头像和昵称，方便之后识别账号</text>

    <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image
        wx:if="{{profileForm.avatarUrl}}"
        src="{{profileForm.avatarUrl}}"
        class="avatar-picker-img"
        mode="aspectFill"
      />
      <view wx:else class="avatar-picker-ph">
        <view class="ui-icon ui-icon-user"></view>
      </view>
      <text class="avatar-picker-text">选择头像</text>
    </button>

    <input
      class="profile-input"
      type="nickname"
      placeholder="请输入昵称"
      value="{{profileForm.nickName}}"
      bindinput="onProfileNameInput"
    />

    <view class="modal-btns">
      <view class="modal-cancel" bindtap="onProfileCancel">取消</view>
      <view class="modal-confirm" bindtap="onProfileConfirm">保存</view>
    </view>
  </view>
</view>
