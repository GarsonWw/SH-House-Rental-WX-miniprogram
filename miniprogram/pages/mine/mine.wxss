/* pages/mine/mine.wxss */
.page-bg { background: #F4F1EA; min-height: 100vh; }

/* ── 未登录 ── */
.login-page { display: flex; flex-direction: column; align-items: center; padding: 80rpx 48rpx 0; }
.login-hero  { display: flex; flex-direction: column; align-items: center; margin-bottom: 48rpx; }
.login-big-icon { margin-bottom: 16rpx; color: #28B8BC; }
.login-title    { font-size: 40rpx; font-weight: 800; color: #171512; margin-bottom: 12rpx; }
.login-sub      { font-size: 26rpx; color: #777; text-align: center; line-height: 1.6; }

.login-btn {
  width: 100%; background: linear-gradient(135deg, #1F8A5B, #09A752);
  color: #FFF; font-size: 32rpx; font-weight: 700;
  padding: 28rpx 0; border-radius: 60rpx; text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.35);
}
.login-hint {
  font-size: 22rpx; color: #BBB; text-align: center; margin-top: 16rpx; line-height: 1.6;
}

.brand-trust-card {
  width: 100%;
  background: #FFF;
  border-radius: 20rpx;
  padding: 26rpx;
  margin-top: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15,47,74,0.08);
  border: 1rpx solid rgba(15,47,74,0.06);
  box-sizing: border-box;
}

.logged-trust {
  width: auto;
  margin: 20rpx 24rpx 0;
}

.brand-trust-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #171512;
  margin-bottom: 10rpx;
}

.brand-trust-desc {
  display: block;
  font-size: 24rpx;
  color: #4F4A43;
  line-height: 1.7;
}

.brand-trust-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.brand-trust-tags text {
  font-size: 22rpx;
  color: #8A6A3D;
  background: #F4EFE6;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

/* ── 已登录：用户头部 ── */
.user-header {
  background: linear-gradient(160deg, #0F2F4A, #1C4966);
  padding: 48rpx 32rpx 60rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.avatar-wrap { display: flex; align-items: center; flex: 1; }
.user-avatar-img {
  width: 110rpx; height: 110rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.7); margin-right: 24rpx; flex-shrink: 0;
}
.user-avatar-ph {
  width: 110rpx; height: 110rpx; border-radius: 50%;
  background: rgba(255,255,255,0.3); display: flex;
  align-items: center; justify-content: center;
  font-size: 60rpx; margin-right: 24rpx; flex-shrink: 0;
  border: 4rpx solid rgba(255,255,255,0.6);
}
.user-name { font-size: 36rpx; font-weight: 700; color: #FFF; display: block; }
.user-sub  { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 5rpx; display: block; }
.edit-profile {
  font-size: 24rpx; color: rgba(255,255,255,0.85);
  border: 1rpx solid rgba(255,255,255,0.4);
  padding: 8rpx 20rpx; border-radius: 50rpx; flex-shrink: 0;
}

/* 功能入口卡片 */
.entry-card {
  background: #FFF; margin: 20rpx 24rpx 0;
  border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.entry-title-bar { padding: 22rpx 28rpx 8rpx; }
.entry-title-txt { font-size: 22rpx; color: #999; font-weight: 600; letter-spacing: 1rpx; }
.entry-item      { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; }
.entry-left      { display: flex; align-items: center; flex: 1; }
.entry-icon-bg   {
  width: 80rpx; height: 80rpx; border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  color: #28B8BC; margin-right: 20rpx; flex-shrink: 0;
}
.fav-bg   { background: #FFF0F5; }
.entry-info { display: flex; flex-direction: column; }
.entry-name { font-size: 30rpx; font-weight: 700; color: #171512; }
.entry-sub  { font-size: 22rpx; color: #999; margin-top: 5rpx; }
.entry-right { display: flex; align-items: center; }
.entry-badge {
  font-size: 20rpx; font-weight: 700; padding: 3rpx 14rpx;
  border-radius: 50rpx; margin-right: 10rpx;
}
.fav-badge { background: #FFF0F0; color: #FF3B3B; }
.entry-arr { font-size: 36rpx; color: #CCC; }
.entry-divider { height: 1rpx; background: #F4F1EA; margin: 0 28rpx; }

/* 菜单 */
.menu-card {
  background: #FFF; margin: 20rpx 24rpx 0;
  border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.menu-item { display: flex; align-items: center; padding: 32rpx 28rpx; }
.menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  background: #DDF5F8;
  color: #28B8BC;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.menu-icon .ui-icon,
.le-icon .ui-icon {
  transform: scale(.72);
}
.menu-txt  { flex: 1; font-size: 28rpx; color: #333; }
.menu-arr  { font-size: 36rpx; color: #CCC; }

/* 管理员入口 */
.landlord-entry {
  display: flex; align-items: center; justify-content: center;
  margin: 28rpx 24rpx 0; padding: 24rpx;
  border-radius: 16rpx; border: 2rpx dashed #DDD;
  background: #FAFAFA;
}
.le-active { background: #EAF1F6; border-color: #0F4C75; }
.le-icon   {
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: #DDF5F8;
  color: #28B8BC;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.le-text   { font-size: 28rpx; color: #888; flex: 1; }
.le-active .le-text { color: #0F4C75; font-weight: 600; }
.le-arr    { font-size: 32rpx; color: #CCC; }

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center;
  z-index: 999;
}
.modal-box {
  background: #FFF; border-radius: 24rpx; padding: 48rpx 40rpx 36rpx;
  width: 620rpx; display: flex; flex-direction: column; align-items: center;
}
.profile-modal-box {
  background: #FFF; border-radius: 24rpx; padding: 44rpx 40rpx 36rpx;
  width: 620rpx; display: flex; flex-direction: column; align-items: center;
}
.modal-title { font-size: 36rpx; font-weight: 800; color: #171512; margin-bottom: 10rpx; }
.modal-sub   { font-size: 24rpx; color: #999; margin-bottom: 36rpx; }
.avatar-picker {
  padding: 0; margin: 0 0 28rpx; background: transparent;
  display: flex; flex-direction: column; align-items: center;
  line-height: 1; border: 0;
}
.avatar-picker::after { border: 0; }
.avatar-picker-img,
.avatar-picker-ph {
  width: 128rpx; height: 128rpx; border-radius: 50%;
  margin-bottom: 14rpx;
}
.avatar-picker-img { display: block; }
.avatar-picker-ph {
  background: #EAF1F6; display: flex; align-items: center; justify-content: center;
  font-size: 64rpx; color: #0F4C75;
}
.avatar-picker-text { font-size: 24rpx; color: #0F4C75; }
.profile-input {
  width: 100%; background: #F4F1EA; border-radius: 14rpx;
  padding: 24rpx 20rpx; font-size: 30rpx;
  text-align: center; margin-bottom: 32rpx; border: 2rpx solid #E6E0D8;
}
.code-input  {
  width: 100%; background: #F4F1EA; border-radius: 14rpx;
  padding: 24rpx 20rpx; font-size: 32rpx; text-align: center;
  letter-spacing: 6rpx; margin-bottom: 32rpx; border: 2rpx solid #E6E0D8;
}
.modal-btns { display: flex; width: 100%; }
.modal-cancel {
  flex: 1; text-align: center; padding: 20rpx 0;
  font-size: 28rpx; color: #999; border: 1rpx solid #E0E0E0;
  border-radius: 50rpx; margin-right: 16rpx;
}
.modal-confirm {
  flex: 1; text-align: center; padding: 20rpx 0;
  font-size: 28rpx; font-weight: 700; color: #FFF;
  background: linear-gradient(135deg, #1A3A5C, #0F4C75); border-radius: 50rpx;
}

/* 2026 UI refresh */
.page-bg {
  background: #EFF8FB;
}

.login-page {
  padding: 72rpx 36rpx 0;
}

.login-big-icon {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: #DDF5F8;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 136rpx;
}

.login-big-icon .ui-icon {
  width: 58rpx;
  height: 58rpx;
  transform: scale(1.18);
}

.login-title,
.user-name,
.entry-name,
.brand-trust-title,
.modal-title {
  color: #111111;
}

.login-sub,
.login-hint,
.brand-trust-desc,
.entry-sub,
.modal-sub,
.menu-txt,
.le-text {
  color: #667A82;
}

.login-btn,
.modal-confirm {
  background: #28B8BC;
  border-radius: 999rpx;
  box-shadow: 0 14rpx 30rpx rgba(40, 184, 188, 0.24);
}

.brand-trust-card,
.entry-card,
.menu-card,
.landlord-entry,
.modal-box,
.profile-modal-box {
  border-radius: 34rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.brand-trust-tags text,
.fav-badge,
.le-active,
.avatar-picker-ph {
  background: #DDF5F8;
  color: #111111;
}

.user-header {
  background: linear-gradient(180deg, #DDF5F8, #EFF8FB);
  padding: 46rpx 32rpx 64rpx;
}

.user-name {
  color: #111111;
}

.user-sub,
.edit-profile {
  color: #667A82;
  border-color: rgba(17, 17, 17, 0.12);
}

.user-avatar-ph,
.user-avatar-img {
  border-color: #FFFFFF;
}

.user-avatar-ph,
.avatar-picker-ph {
  color: #28B8BC;
}

.user-avatar-ph .ui-icon {
  transform: scale(1.28);
}

.avatar-picker-ph .ui-icon {
  transform: scale(1.45);
}

.stat-num,
.fav-num,
.blue-num,
.green-num {
  color: #111111;
}

.entry-icon-bg {
  border-radius: 50%;
}

.fav-bg {
  background: #DDF5F8;
}

.landlord-entry {
  background: #FFFFFF;
  border-style: solid;
}

.le-active {
  border-color: rgba(40, 184, 188, 0.5);
}

.profile-input,
.code-input {
  background: #F5FCFD;
  border-color: rgba(17, 17, 17, 0.08);
  border-radius: 999rpx;
}
