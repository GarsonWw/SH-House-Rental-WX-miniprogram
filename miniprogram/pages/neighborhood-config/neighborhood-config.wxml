<scroll-view scroll-y class="page">
  <view class="hero-card">
    <text class="hero-title">小区详情配置</text>
    <text class="hero-sub">房源发布只管房源本身；小区通勤、配套、点评和转化内容在这里单独维护。</text>
  </view>

  <view class="section-head-row" wx:if="{{!loading}}">
    <text class="section-label inline">选择小区</text>
    <view class="add-nb-btn" bindtap="onOpenAddModal">
      <text class="add-nb-icon">+</text>
      <text>新增小区</text>
    </view>
  </view>

  <view class="empty-card" wx:if="{{!loading && neighborhoods.length === 0}}">
    <text class="empty-title">还没有可配置的小区</text>
    <text class="empty-sub">点击右上角「新增小区」先创建小区资料，或发布房源后系统会自动出现对应小区。</text>
  </view>

  <view wx:if="{{neighborhoods.length > 0}}">
    <view class="nb-scroll">
      <view class="nb-row">
        <view
          class="nb-card {{selectedName === item.name ? 'nb-active' : ''}}"
          wx:for="{{neighborhoods}}"
          wx:key="name"
          bindtap="onSelectNeighborhood"
          data-name="{{item.name}}"
        >
          <text class="nb-name">{{item.name}}</text>
          <text class="nb-meta">{{item.district}} · {{item.count}}套房源 · {{item.available}}套在租</text>
          <text class="nb-progress">{{item.progressText}}{{item.count === 0 ? ' · 暂无房源' : ''}}</text>
        </view>
      </view>
    </view>

    <view class="editor-card" wx:if="{{selectedName}}">
      <view class="editor-head">
        <view>
          <text class="editor-title">{{selectedName}}</text>
          <text class="editor-sub">以下内容独立保存为小区资料，并统一展示在小区详情页。</text>
        </view>
        <view class="editor-actions">
          <view class="preview-btn" bindtap="onPreviewNeighborhood">预览</view>
          <view class="delete-btn" bindtap="onDeleteNeighborhood">{{deleting ? '删除中' : '删除配置'}}</view>
        </view>
      </view>

      <view class="name-card">
        <text class="name-card-title">小区名称</text>
        <text class="name-card-sub">修改后会同步更新该小区下的全部房源。</text>
        <input
          class="input name-input"
          value="{{editingName}}"
          bindinput="onEditingNameInput"
          placeholder="请输入小区名称"
          placeholder-class="form-placeholder"
        />
        <text wx:if="{{nameDuplicateHint}}" class="name-hint warning">{{nameDuplicateHint}}</text>
        <view class="name-save-btn {{renaming || editingName === selectedName ? 'disabled' : ''}}" bindtap="onSaveNeighborhoodName">
          {{renaming ? '保存中...' : '保存名称'}}
        </view>
      </view>

      <view class="district-card">
        <text class="district-card-title">罗湖片区</text>
        <text class="district-card-sub">修改后会同步更新该小区下的全部房源，并影响首页片区筛选。</text>
        <picker range="{{districtOptions}}" value="{{location.districtPickerIndex}}" bindchange="onEditorDistrictChange">
          <view class="location-picker">{{location.district || '请选择罗湖片区'}}</view>
        </picker>
        <view
          class="district-save-btn {{savingDistrict || location.district === savedDistrict ? 'disabled' : ''}}"
          bindtap="onSaveDistrict"
        >
          {{savingDistrict ? '保存中...' : '保存片区'}}
        </view>
      </view>

      <view class="location-card">
        <text class="location-card-title">地图位置</text>
        <text class="location-card-sub">同一小区下的所有房源共用此定位，保存后会同步到该小区全部房源。</text>
        <view class="field">
          <view class="location-choose-btn" bindtap="onChooseNeighborhoodLocation">
            <text class="{{location.latitude && location.longitude ? 'location-value' : 'location-placeholder'}}">
              {{location.locationName || (location.latitude && location.longitude ? '已选择小区位置' : '点击选择小区地图位置')}}
            </text>
            <text class="location-action">选择</text>
          </view>
        </view>
        <view class="field">
          <text class="label">小区地址</text>
          <input class="input" value="{{location.address}}" bindinput="onLocationAddressInput" placeholder="如：罗湖区XX路XX号（可选）" placeholder-class="form-placeholder" />
        </view>
        <text class="location-coords" wx:if="{{location.latitude && location.longitude}}">
          坐标：{{location.latitude}}, {{location.longitude}}
        </text>
        <view class="location-actions">
          <view class="location-save-btn {{savingLocation ? 'disabled' : ''}}" bindtap="onSaveLocation">
            {{savingLocation ? '保存中...' : '保存位置'}}
          </view>
          <view class="location-preview-btn" wx:if="{{location.latitude && location.longitude}}" bindtap="onPreviewLocation">查看位置</view>
        </view>
      </view>

      <view class="media-card">
        <text class="media-title">小区封面照片（可选，最多15张）</text>
        <text class="media-sub">首张将作为详情页头图；不填则自动使用房源首图。</text>
        <view class="image-upload-grid">
          <view class="img-item" wx:for="{{media.images}}" wx:key="index">
            <image src="{{item}}" class="uploaded-img" mode="aspectFill" />
            <view class="img-delete" catchtap="onDeleteCoverImage" data-index="{{index}}">删除</view>
          </view>
          <view class="add-img-btn" bindtap="onChooseCoverImage" wx:if="{{media.images.length < 15}}">
            <view class="add-icon ui-icon ui-icon-plus"></view>
            <text class="add-text">添加照片</text>
            <text class="add-hint">{{media.images.length}}/15</text>
          </view>
        </view>
      </view>

      <view class="media-card">
        <view class="video-title-row">
          <text class="media-title">小区带看视频（可选，120秒以内）</text>
          <text class="video-tip">1个视频</text>
        </view>
        <view class="video-preview-wrap" wx:if="{{media.videos.length > 0}}">
          <video
            src="{{media.videos[0]}}"
            poster="{{media.videoCover}}"
            class="preview-video"
            controls
            show-mute-btn
            object-fit="cover"
          ></video>
          <view class="video-delete-btn" catchtap="onDeleteNeighborhoodVideo">
            <text class="vd-text">删除视频</text>
          </view>
        </view>
        <view class="add-video-btn" bindtap="onChooseNeighborhoodVideo" wx:else>
          <text class="add-video-text">拍摄 / 选择视频</text>
          <text class="add-video-hint">限120秒，建议横拍</text>
        </view>
      </view>

      <view class="assist-card">
        <view class="assist-top">
          <view>
            <text class="assist-title">配置完成度 {{completion.percent}}%</text>
            <text class="assist-sub">{{completion.missingText}}</text>
          </view>
          <text class="assist-count">{{completion.filled}}/{{completion.total}}</text>
        </view>
        <view class="progress-track">
          <view class="progress-fill" style="width: {{completion.width}};"></view>
        </view>
        <view class="quick-actions">
          <view class="quick-btn primary" bindtap="onApplyStarterTemplate">一键生成基础文案</view>
          <view class="quick-btn" bindtap="onApplyCommonDefaults">补充常用默认项</view>
        </view>
        <text class="assist-note">智能填充只会补空白项，不会覆盖你已经写好的内容。</text>
      </view>

      <view class="config-section">
        <view class="section-head" bindtap="onToggleSection" data-section="basic">
          <text>基础展示</text>
          <text>{{openSections.basic ? '收起' : '展开'}}</text>
        </view>
        <view wx:if="{{openSections.basic}}">
          <view class="field">
            <text class="label">首页备注</text>
            <textarea class="textarea small" maxlength="200" value="{{form.neighborhoodNote}}" data-field="neighborhoodNote" bindinput="onInput" placeholder="如：罗湖成熟社区，近地铁，生活配套齐全" placeholder-class="form-placeholder" auto-height></textarea>
          </view>
          <view class="field">
            <text class="label">首页点评</text>
            <textarea class="textarea" maxlength="500" value="{{form.neighborhoodReview}}" data-field="neighborhoodReview" bindinput="onInput" placeholder="写给租客看的真实点评，如通勤、生活便利度、适合人群等" placeholder-class="form-placeholder" auto-height></textarea>
          </view>
          <view class="field">
            <text class="label">顶部宣传语</text>
            <input class="input" value="{{form.neighborhoodSlogan}}" data-field="neighborhoodSlogan" bindinput="onInput" placeholder="如：步行通勤 · 罗湖口岸 · 生活便利" placeholder-class="form-placeholder" />
          </view>
        </view>
      </view>

      <view class="config-section">
        <view class="section-head" bindtap="onToggleSection" data-section="commute">
          <text>通勤与居住信息</text>
          <text>{{openSections.commute ? '收起' : '展开'}}</text>
        </view>
        <view wx:if="{{openSections.commute}}">
          <view class="field">
            <text class="label">通勤信息</text>
            <input class="input" value="{{form.commuteInfo}}" data-field="commuteInfo" bindinput="onInput" placeholder="如：步行约12分钟直达罗湖口岸" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">通勤方式</text>
            <input class="input" value="{{form.commuteMode}}" data-field="commuteMode" bindinput="onInput" placeholder="如：步行 / 地铁 / 巴士" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">安全与门禁</text>
            <textarea class="textarea small" maxlength="200" value="{{form.safetyInfo}}" data-field="safetyInfo" bindinput="onInput" placeholder="如：大门人脸识别+单元门禁，保安值守" placeholder-class="form-placeholder" auto-height></textarea>
          </view>
          <view class="field">
            <text class="label">居住类型</text>
            <input class="input" value="{{form.propertyType}}" data-field="propertyType" bindinput="onInput" placeholder="如：传统住宅小区 / 商业公寓 / 酒店公寓" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">停车场情况</text>
            <input class="input" value="{{form.parkingInfo}}" data-field="parkingInfo" bindinput="onInput" placeholder="如：有地下停车场 / 无停车场 / 仅临停" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">快递外卖</text>
            <input class="input" value="{{form.deliveryInfo}}" data-field="deliveryInfo" bindinput="onInput" placeholder="如：外卖/快递可直接送上楼" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">短租支持</text>
            <input class="input" value="{{form.shortRentInfo}}" data-field="shortRentInfo" bindinput="onInput" placeholder="如：支持短租 / 最短3个月起" placeholder-class="form-placeholder" />
          </view>
        </view>
      </view>

      <view class="config-section">
        <view class="section-head" bindtap="onToggleSection" data-section="conversion">
          <text>转化内容与实探</text>
          <text>{{openSections.conversion ? '收起' : '展开'}}</text>
        </view>
        <view wx:if="{{openSections.conversion}}">
          <view class="field">
            <text class="label">房间实探总结</text>
            <textarea class="textarea" maxlength="700" value="{{form.roomInsight}}" data-field="roomInsight" bindinput="onInput" placeholder="写清优点、噪音、采光、装修、适合人群等真实体验" placeholder-class="form-placeholder" auto-height></textarea>
          </view>
          <view class="field">
            <text class="label">户型价格参考</text>
            <input class="input" value="{{form.priceReference}}" data-field="priceReference" bindinput="onInput" placeholder="如：1房3k-4k / 2房6k-6k5" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">水电费</text>
            <input class="input" value="{{form.waterElectricFee}}" data-field="waterElectricFee" bindinput="onInput" placeholder="如：民水民电 / 商水商电 / 水8电1.5" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">网费宽带</text>
            <input class="input" value="{{form.broadbandFee}}" data-field="broadbandFee" bindinput="onInput" placeholder="如：已含宽带 / 需自理约100元/月" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">停车费</text>
            <input class="input" value="{{form.parkingFee}}" data-field="parkingFee" bindinput="onInput" placeholder="如：固定车位600元/月 / 临停按物业标准" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">周边配套</text>
            <textarea class="textarea small" maxlength="300" value="{{form.surroundings}}" data-field="surroundings" bindinput="onInput" placeholder="如：楼下小卖部，餐饮偏少，吃饭需步行或依赖外卖" placeholder-class="form-placeholder" auto-height></textarea>
          </view>
          <view class="field">
            <text class="label">适合人群标签</text>
            <input class="input" value="{{form.suitableCrowd}}" data-field="suitableCrowd" bindinput="onInput" placeholder="如：合租党 / 省钱党 / 口岸通勤 / 安静优先" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">实探标题</text>
            <input class="input" value="{{form.scoutTitle}}" data-field="scoutTitle" bindinput="onInput" placeholder="如：管家实探｜罗湖通勤 ID: 250001" placeholder-class="form-placeholder" />
          </view>
          <view class="field">
            <text class="label">管家测评总结</text>
            <textarea class="textarea" maxlength="800" value="{{form.scoutSummary}}" data-field="scoutSummary" bindinput="onInput" placeholder="写一段像实地探盘笔记一样的客观总结" placeholder-class="form-placeholder" auto-height></textarea>
          </view>
          <view class="field">
            <text class="label">管家建议 / 避坑提醒</text>
            <textarea class="textarea" maxlength="600" value="{{form.scoutAdvice}}" data-field="scoutAdvice" bindinput="onInput" placeholder="如：声音敏感慎选低楼层；优先看北向高楼层" placeholder-class="form-placeholder" auto-height></textarea>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
</scroll-view>

<view class="modal-mask" wx:if="{{showAddModal}}" catchtap="onCloseAddModal">
  <view class="modal-card" catchtap="noop">
    <text class="modal-title">新增小区</text>
    <text class="modal-sub">先创建小区资料，可暂不挂房源；发布房源时可直接选择该小区。</text>
    <view class="modal-field">
      <text class="modal-label">小区名称</text>
      <input class="modal-input" value="{{newNeighborhoodName}}" bindinput="onAddNameInput" placeholder="如：翠竹家园" placeholder-class="form-placeholder" />
    </view>
    <view class="modal-field">
      <text class="modal-label">罗湖片区</text>
      <picker range="{{districtOptions}}" value="{{newNeighborhoodDistrictIndex}}" bindchange="onAddDistrictChange">
        <view class="modal-picker">{{newNeighborhoodDistrict || '请选择罗湖片区'}}</view>
      </picker>
    </view>
    <view class="modal-actions">
      <view class="modal-btn" bindtap="onCloseAddModal">取消</view>
      <view class="modal-btn primary" bindtap="onConfirmAddNeighborhood">{{addSaving ? '创建中...' : '创建'}}</view>
    </view>
  </view>
</view>

<view class="bottom-bar" wx:if="{{selectedName}}">
  <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="onSave">{{saving ? '保存中...' : '保存小区配置'}}</view>
</view>
