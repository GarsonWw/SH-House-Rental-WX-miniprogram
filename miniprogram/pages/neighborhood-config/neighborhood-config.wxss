.page {
  min-height: 100vh;
  background: #EFF8FB;
  padding: 24rpx 0 150rpx;
}

.hero-card,
.editor-card,
.empty-card {
  margin: 0 30rpx 22rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 34rpx;
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
  border: 1rpx solid rgba(17, 17, 17, 0.05);
}

.hero-title,
.editor-title,
.empty-title {
  display: block;
  color: #111111;
  font-size: 36rpx;
  font-weight: 900;
}

.hero-sub,
.editor-sub,
.empty-sub {
  display: block;
  margin-top: 10rpx;
  color: #667A82;
  font-size: 25rpx;
  line-height: 1.6;
}

.section-label {
  margin: 0 30rpx 14rpx;
  color: #111111;
  font-size: 26rpx;
  font-weight: 800;
}

.nb-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.nb-row {
  display: flex;
  padding: 0 30rpx;
}

.nb-card {
  flex-shrink: 0;
  width: 360rpx;
  margin-right: 18rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border-radius: 30rpx;
  border: 2rpx solid transparent;
}

.nb-active {
  background: #FFFFFF;
  border-color: #28B8BC;
  box-shadow: 0 14rpx 30rpx rgba(40, 184, 188, 0.16);
}

.nb-name {
  display: block;
  color: #111111;
  font-size: 30rpx;
  font-weight: 900;
}

.nb-meta,
.nb-progress {
  display: block;
  margin-top: 8rpx;
  color: #667A82;
  font-size: 22rpx;
}

.nb-progress {
  color: #28B8BC;
  font-weight: 800;
}

.editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.preview-btn {
  flex-shrink: 0;
  margin-left: 18rpx;
  padding: 12rpx 24rpx;
  color: #111111;
  background: #DDF5F8;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.assist-card {
  background: #F5FCFD;
  border-radius: 30rpx;
  padding: 24rpx;
  margin-bottom: 22rpx;
}

.assist-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.assist-title {
  display: block;
  color: #111111;
  font-size: 28rpx;
  font-weight: 900;
}

.assist-sub {
  display: block;
  margin-top: 8rpx;
  color: #667A82;
  font-size: 23rpx;
  line-height: 1.5;
}

.assist-count {
  flex-shrink: 0;
  margin-left: 20rpx;
  color: #28B8BC;
  font-size: 28rpx;
  font-weight: 900;
}

.progress-track {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(40, 184, 188, 0.14);
  overflow: hidden;
  margin-top: 18rpx;
}

.progress-fill {
  height: 12rpx;
  border-radius: 999rpx;
  background: #28B8BC;
}

.quick-actions {
  display: flex;
  margin-top: 20rpx;
  gap: 14rpx;
}

.quick-btn {
  flex: 1;
  min-height: 72rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #111111;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 16rpx;
}

.quick-btn.primary {
  background: #28B8BC;
  color: #FFFFFF;
}

.assist-note {
  display: block;
  margin-top: 14rpx;
  color: #8A9AA1;
  font-size: 22rpx;
  line-height: 1.5;
}

.config-section {
  background: #F5FCFD;
  border-radius: 30rpx;
  margin-top: 18rpx;
  overflow: hidden;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  color: #111111;
  font-size: 28rpx;
  font-weight: 900;
}

.section-head text:last-child {
  color: #28B8BC;
  font-size: 24rpx;
}

.field {
  padding: 0 24rpx 24rpx;
}

.label {
  display: block;
  color: #111111;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.input,
.textarea {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  padding: 20rpx 22rpx;
  color: #111111;
  font-size: 27rpx;
  line-height: 1.6;
}

.textarea {
  min-height: 180rpx;
}

.textarea.small {
  min-height: 112rpx;
}

.bottom-space {
  height: 160rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.94);
  padding: 18rpx 30rpx calc(18rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -10rpx 34rpx rgba(39, 122, 139, 0.12);
}

.save-btn {
  height: 88rpx;
  border-radius: 999rpx;
  background: #28B8BC;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
}

.save-btn.disabled {
  opacity: 0.6;
}
