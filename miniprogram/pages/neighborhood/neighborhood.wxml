<!-- pages/neighborhood/neighborhood.wxml -->
<view class="turn-page">
  <view class="turn-hero">
    <text class="turn-kicker">转转</text>
    <text class="turn-title">口岸通勤与精选好房</text>
    <text class="turn-sub">先看路线，再看经过实地测评的房源</text>
  </view>

  <view class="category-grid">
    <view class="category-card" bindtap="onScrollTo" data-target="guide">
      <view class="category-mark">
        <view class="ui-icon ui-icon-route"></view>
      </view>
      <text class="category-title">口岸通勤攻略</text>
      <text class="category-desc">罗湖、福田、深圳湾等口岸路线</text>
    </view>
    <view class="category-card" bindtap="onScrollTo" data-target="featured">
      <view class="category-mark">
        <view class="ui-icon ui-icon-home"></view>
      </view>
      <text class="category-title">精选好房推荐</text>
      <text class="category-desc">{{featuredHouses.length}} 套可看房源</text>
    </view>
  </view>

  <view id="guide" class="section-block">
    <view class="section-head">
      <text class="section-title">口岸通勤攻略</text>
      <text class="section-note">持续更新</text>
    </view>
    <view
      class="port-card"
      wx:for="{{portGuides}}"
      wx:key="name"
      bindtap="onGuideTap"
      data-name="{{item.name}}"
    >
      <view class="port-main">
        <text class="port-name">{{item.name}}</text>
        <text class="port-route">{{item.route}}</text>
      </view>
      <view class="port-time">
        <text>{{item.duration}}</text>
      </view>
    </view>
  </view>

  <view id="featured" class="section-block">
    <view class="section-head">
      <text class="section-title">精选好房推荐</text>
      <text class="section-note">按可租优先</text>
    </view>
    <view wx:if="{{featuredHouses.length === 0}}" class="empty-state">
      <text class="empty-title">暂无可推荐房源</text>
      <text class="empty-sub">新房源整理后会出现在这里</text>
    </view>
    <view
      class="featured-card"
      wx:for="{{featuredHouses}}"
      wx:key="id"
      bindtap="onHouseTap"
      data-id="{{item.id}}"
    >
      <image
        wx:if="{{item.images && item.images.length}}"
        src="{{item.images[0]}}"
        class="featured-img"
        mode="aspectFill"
        lazy-load
      />
      <view wx:else class="featured-img placeholder-img">
        <view class="ui-icon ui-icon-home"></view>
      </view>
      <view class="featured-info">
        <text class="featured-title">{{item.title}}</text>
        <text class="featured-meta">{{item.neighborhood}} · {{item.roomType}} · {{item.area}}㎡</text>
        <view class="featured-bottom">
          <text class="featured-price">{{item.price}}元/月</text>
          <text class="featured-action">看测评 ›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="tab-bottom-space"></view>
</view>
