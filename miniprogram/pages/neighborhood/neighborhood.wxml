<!-- pages/neighborhood/neighborhood.wxml -->
<view class="page-container">

  <!-- 小区列表视图 -->
  <block wx:if="{{!showHouseList}}">
    <!-- 搜索栏 -->
    <view class="search-section">
      <search-bar
        placeholder="搜索小区名称..."
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindsearch="onSearch"
        bindclear="onSearchClear"
      />
    </view>

    <!-- 区域筛选 -->
    <scroll-view scroll-x class="district-filter" wx:if="{{districtList.length > 1}}">
      <view class="district-list">
        <view
          class="district-chip {{selectedDistrict === item ? 'active' : ''}}"
          wx:for="{{districtList}}"
          wx:key="index"
          bindtap="onDistrictSelect"
          data-district="{{item}}"
        >{{item}}</view>
      </view>
    </scroll-view>

    <!-- 小区数量统计 -->
    <view class="stats-bar">
      <text class="stats-text">共 {{filteredNeighborhoodList.length}} 个小区</text>
    </view>

    <!-- 小区网格列表 -->
    <scroll-view scroll-y class="neighborhood-grid-scroll">
      <view wx:if="{{filteredNeighborhoodList.length === 0}}" class="empty-state">
        <text class="empty-icon">🏘️</text>
        <text class="empty-text">暂无小区数据</text>
      </view>

      <view class="neighborhood-grid">
        <view
          class="neighborhood-card"
          wx:for="{{filteredNeighborhoodList}}"
          wx:key="name"
          bindtap="onNeighborhoodTap"
          data-name="{{item.name}}"
        >
          <view class="card-cover">
            <text class="card-emoji">🏢</text>
          </view>
          <view class="card-info">
            <text class="card-name">{{item.name}}</text>
            <text class="card-district">📍 {{item.district}}</text>
            <view class="card-footer-row">
              <text class="card-count">{{item.count}} 套</text>
              <text class="card-arrow">›</text>
            </view>
          </view>
        </view>
      </view>

      <view style="height: 40rpx;"></view>
    </scroll-view>
  </block>

  <!-- 小区房源列表视图 -->
  <block wx:if="{{showHouseList}}">
    <!-- 小区标题头 -->
    <view class="neighborhood-header">
      <view class="back-btn" bindtap="onBack">
        <text class="back-icon">‹</text>
        <text class="back-text">返回</text>
      </view>
      <view class="header-info">
        <text class="header-name">{{selectedNeighborhood.name}}</text>
        <text class="header-district">{{selectedNeighborhood.district}}</text>
      </view>
      <view class="header-count">
        <text class="count-num">{{houseList.length}}</text>
        <text class="count-unit">套</text>
      </view>
    </view>

    <!-- 提示卡片 -->
    <view class="tips-card">
      <text class="tips-icon">💡</text>
      <text class="tips-text">点击房源卡片查看详情，可直接获取房东联系方式</text>
    </view>

    <!-- 房源列表 -->
    <scroll-view scroll-y class="house-list-scroll">
      <view wx:if="{{houseList.length === 0}}" class="empty-state">
        <text class="empty-icon">🏠</text>
        <text class="empty-text">该小区暂无房源</text>
      </view>

      <view class="house-list">
        <house-card
          wx:for="{{houseList}}"
          wx:key="id"
          house="{{item}}"
          show-contact="{{true}}"
          bindtap="onHouseTap"
        />
      </view>

      <view style="height: 40rpx;"></view>
    </scroll-view>
  </block>
</view>
