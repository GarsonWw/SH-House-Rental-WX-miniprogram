/* pages/neighborhood/neighborhood.wxss */
.turn-page {
  min-height: 100vh;
  background: #EFF8FB;
  padding: 26rpx 30rpx 0;
  box-sizing: border-box;
}

.turn-hero {
  padding: 30rpx;
  border-radius: 34rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.turn-kicker,
.turn-title,
.turn-sub {
  display: block;
}

.turn-kicker {
  font-size: 24rpx;
  color: #28B8BC;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.turn-title {
  font-size: 40rpx;
  color: #111111;
  font-weight: 900;
  line-height: 1.28;
}

.turn-sub {
  margin-top: 10rpx;
  font-size: 27rpx;
  color: #667A82;
  line-height: 1.55;
}

.category-grid {
  display: flex;
  flex-wrap: nowrap;
  gap: 18rpx;
  margin-top: 22rpx;
}

.category-card {
  flex: 1;
  min-width: 0;
  min-height: 172rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 12rpx 30rpx rgba(39, 122, 139, 0.07);
}

.category-mark {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 18rpx;
  border-radius: 16rpx;
  background: #DDF5F8;
  color: #28B8BC;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-mark .ui-icon {
  transform: scale(.72);
}

.category-title,
.category-desc {
  display: block;
}

.category-title {
  font-size: 28rpx;
  color: #111111;
  font-weight: 800;
  line-height: 1.35;
}

.category-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #667A82;
  line-height: 1.45;
}

.section-block {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #111111;
}

.section-note {
  font-size: 22rpx;
  color: #28B8BC;
  font-weight: 700;
  background: #DDF5F8;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.port-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(17, 17, 17, 0.06);
}

.port-card:first-of-type {
  border-top: 0;
}

.port-main {
  flex: 1;
  min-width: 0;
}

.port-name,
.port-route {
  display: block;
}

.port-name {
  font-size: 28rpx;
  color: #111111;
  font-weight: 800;
}

.port-route {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #667A82;
  line-height: 1.55;
}

.port-time {
  margin-left: 20rpx;
  min-width: 140rpx;
  height: 58rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111111;
  background: #F2F9FA;
  font-size: 22rpx;
  font-weight: 800;
}

.featured-card {
  display: flex;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(17, 17, 17, 0.06);
}

.featured-card:first-of-type {
  border-top: 0;
}

.featured-img {
  width: 168rpx;
  height: 138rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  background: #DDF5F8;
}

.placeholder-img {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #28B8BC;
}

.placeholder-img .ui-icon {
  transform: scale(1.05);
}

.featured-info {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.featured-title {
  font-size: 28rpx;
  color: #111111;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.featured-meta {
  font-size: 22rpx;
  color: #667A82;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.featured-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.featured-price {
  font-size: 27rpx;
  color: #138F94;
  font-weight: 900;
}

.featured-action {
  font-size: 23rpx;
  color: #28B8BC;
  font-weight: 800;
}

.empty-state {
  padding: 42rpx 0;
  text-align: center;
}

.empty-title,
.empty-sub {
  display: block;
}

.empty-title {
  font-size: 28rpx;
  color: #111111;
  font-weight: 800;
}

.empty-sub {
  margin-top: 8rpx;
  color: #667A82;
  font-size: 23rpx;
}
