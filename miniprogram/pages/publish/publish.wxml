<!-- pages/publish/publish.wxml -->
<scroll-view scroll-y class="page-container">

  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view class="step {{currentStep >= 1 ? 'active' : ''}} {{currentStep > 1 ? 'done' : ''}}">
      <view class="step-circle">{{currentStep > 1 ? '✓' : '1'}}</view>
      <text class="step-label">房源信息</text>
    </view>
    <view class="step-line {{currentStep > 1 ? 'done' : ''}}"></view>
    <view class="step {{currentStep >= 2 ? 'active' : ''}} {{currentStep > 2 ? 'done' : ''}}">
      <view class="step-circle">{{currentStep > 2 ? '✓' : '2'}}</view>
      <text class="step-label">联系方式</text>
    </view>
    <view class="step-line {{currentStep > 2 ? 'done' : ''}}"></view>
    <view class="step {{currentStep >= 3 ? 'active' : ''}}">
      <view class="step-circle">3</view>
      <text class="step-label">确认发布</text>
    </view>
  </view>

  <!-- Step 1: 房源信息 -->
  <view wx:if="{{currentStep === 1}}" class="form-section">

    <!-- 图片上传 -->
    <view class="form-card">
      <text class="form-section-title">📸 房间照片（可选，最多6张）</text>
      <view class="image-upload-grid">
        <view
          class="img-item"
          wx:for="{{form.images}}"
          wx:key="index"
        >
          <image src="{{item}}" class="uploaded-img" mode="aspectFill" />
          <view class="img-delete" catchtap="onDeleteImage" data-index="{{index}}">✕</view>
        </view>
        <view class="add-img-btn" bindtap="onChooseImage" wx:if="{{form.images.length < 6}}">
          <text class="add-icon">+</text>
          <text class="add-text">添加照片</text>
          <text class="add-hint">{{form.images.length}}/6</text>
        </view>
      </view>
    </view>

    <!-- 视频上传 -->
    <view class="form-card">
      <view class="video-title-row">
        <text class="form-section-title">🎬 带看视频（可选，60秒以内）</text>
        <text class="video-tip">1个视频</text>
      </view>

      <!-- 已有视频 -->
      <view class="video-preview-wrap" wx:if="{{form.videos.length > 0}}">
        <video
          src="{{form.videos[0]}}"
          poster="{{form.videoCover}}"
          class="preview-video"
          controls
          show-mute-btn
          object-fit="cover"
        ></video>
        <view class="video-delete-btn" catchtap="onDeleteVideo">
          <text class="vd-icon">✕</text>
          <text class="vd-text">删除视频</text>
        </view>
      </view>

      <!-- 添加视频 -->
      <view class="add-video-btn" bindtap="onChooseVideo" wx:else>
        <text class="add-video-icon">▶</text>
        <text class="add-video-text">拍摄 / 选择视频</text>
        <text class="add-video-hint">限60秒，建议横拍</text>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="form-card">
      <text class="form-section-title">🏠 基本信息</text>

      <view class="form-item required">
        <text class="form-label">小区名称</text>
        <input
          class="form-input"
          placeholder="请输入小区名称"
          value="{{form.neighborhood}}"
          bindinput="onInput"
          data-field="neighborhood"
        />
      </view>

      <view class="form-item required">
        <text class="form-label">罗湖片区</text>
        <picker
          range="{{districtOptions}}"
          bindchange="onPickerChange"
          data-field="district"
          data-options="districtOptions"
        >
          <view class="picker-view">
            <text class="{{form.district ? 'picker-value' : 'picker-placeholder'}}">
              {{form.district || '请选择罗湖片区'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">详细地址</text>
        <input
          class="form-input"
          placeholder="楼栋门牌号（可选）"
          value="{{form.address}}"
          bindinput="onInput"
          data-field="address"
        />
      </view>

      <view class="form-item required">
        <text class="form-label">地图位置</text>
        <view class="location-picker" bindtap="onChooseLocation">
          <view class="location-picker-main">
            <text class="{{form.latitude && form.longitude ? 'location-picker-value' : 'location-picker-placeholder'}}">
              {{form.locationName || (form.latitude && form.longitude ? '已选择小区位置' : '点击选择小区地图位置')}}
            </text>
            <text class="location-picker-sub" wx:if="{{form.address}}">{{form.address}}</text>
          </view>
          <text class="location-picker-action">选择</text>
        </view>
      </view>

      <view class="field-helper">小区详情、通勤配套、点评等复杂内容已移到「房东管理中心 → 小区详情配置」。发布房源时先填必要信息即可。</view>

      <view class="form-item required">
        <text class="form-label">月租金</text>
        <view class="input-with-unit">
          <input
            class="form-input"
            placeholder="请输入月租金"
            type="number"
            value="{{form.price}}"
            bindinput="onInput"
            data-field="price"
          />
          <text class="input-unit">元/月</text>
        </view>
      </view>

      <view class="form-item required">
        <text class="form-label">房型</text>
        <picker
          range="{{roomTypeOptions}}"
          bindchange="onPickerChange"
          data-field="roomType"
          data-options="roomTypeOptions"
        >
          <view class="picker-view">
            <text class="{{form.roomType ? 'picker-value' : 'picker-placeholder'}}">
              {{form.roomType || '请选择房型'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">建筑属性</text>
        <picker
          range="{{buildingAttributeOptions}}"
          bindchange="onPickerChange"
          data-field="buildingAttribute"
          data-options="buildingAttributeOptions"
        >
          <view class="picker-view">
            <text class="{{form.buildingAttribute ? 'picker-value' : 'picker-placeholder'}}">
              {{form.buildingAttribute || '请选择建筑属性'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item required">
        <text class="form-label">面积</text>
        <view class="input-with-unit">
          <input
            class="form-input"
            placeholder="请输入面积"
            type="number"
            value="{{form.area}}"
            bindinput="onInput"
            data-field="area"
          />
          <text class="input-unit">㎡</text>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">楼层</text>
        <input
          class="form-input"
          placeholder="如：8/18层"
          value="{{form.floor}}"
          bindinput="onInput"
          data-field="floor"
        />
      </view>

      <view class="form-item">
        <text class="form-label">朝向</text>
        <picker
          range="{{orientationOptions}}"
          bindchange="onPickerChange"
          data-field="orientation"
          data-options="orientationOptions"
        >
          <view class="picker-view">
            <text class="{{form.orientation ? 'picker-value' : 'picker-placeholder'}}">
              {{form.orientation || '请选择朝向'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">装修</text>
        <picker
          range="{{decorationOptions}}"
          bindchange="onPickerChange"
          data-field="decoration"
          data-options="decorationOptions"
        >
          <view class="picker-view">
            <text class="{{form.decoration ? 'picker-value' : 'picker-placeholder'}}">
              {{form.decoration || '请选择装修情况'}}
            </text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 标签 -->
    <view class="form-card">
      <text class="form-section-title">🏷️ 特色标签（最多5个）</text>
      <view class="tags-grid">
        <view
          class="tag-option {{item.selected ? 'selected' : ''}}"
          wx:for="{{tagOptions}}"
          wx:key="index"
          bindtap="onTagToggle"
          data-tag="{{item.label}}"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- 描述 -->
    <view class="form-card">
      <text class="form-section-title">📝 房源描述</text>
      <textarea
        class="form-textarea"
        placeholder="描述一下您的房子，如：装修情况、配套设施、周边环境、入住要求等..."
        maxlength="500"
        value="{{form.description}}"
        bindinput="onInput"
        data-field="description"
        auto-height
      />
      <text class="textarea-count">{{form.description.length}}/500</text>
    </view>

    <view class="form-card advanced-card">
      <view class="advanced-head" bindtap="onToggleAdvancedHouseFields">
        <view>
          <text class="form-section-title">📖 补充房源详情（可选）</text>
          <text class="field-helper compact">非必填，适合后续补充。填写后详情页会默认展示三行概述，用户点击后阅读完整内容。</text>
        </view>
        <text class="advanced-toggle">{{showAdvancedHouseFields ? '收起' : '展开'}}</text>
      </view>

      <view wx:if="{{showAdvancedHouseFields}}">

      <view class="form-item">
        <text class="form-label">展开标题</text>
        <input
          class="form-input"
          placeholder="如：步行通勤真实体验 / 这套房适合谁"
          value="{{form.detailGuideTitle}}"
          bindinput="onInput"
          data-field="detailGuideTitle"
        />
      </view>

      <view class="form-item">
        <text class="form-label">三行概述</text>
        <textarea
          class="form-textarea small-textarea"
          placeholder="先用简短、清晰的话概括核心卖点和注意点，详情页默认只展示这里的前几行"
          maxlength="220"
          value="{{form.detailGuideSummary}}"
          bindinput="onInput"
          data-field="detailGuideSummary"
          auto-height
        />
        <text class="textarea-count">{{form.detailGuideSummary.length}}/220</text>
      </view>

      <view class="form-item">
        <text class="form-label">展开正文</text>
        <textarea
          class="form-textarea"
          placeholder="展开后展示的大段内容，可写通勤、采光、噪音、楼层、家具、周边、适合人群、真实缺点等"
          maxlength="1200"
          value="{{form.detailGuideContent}}"
          bindinput="onInput"
          data-field="detailGuideContent"
          auto-height
        />
        <text class="textarea-count">{{form.detailGuideContent.length}}/1200</text>
      </view>

      <view class="form-item">
        <text class="form-label">提醒 / 避坑补充</text>
        <textarea
          class="form-textarea small-textarea"
          placeholder="如：声音敏感建议晚高峰实地感受；南向低楼层需确认采光"
          maxlength="300"
          value="{{form.detailGuideTip}}"
          bindinput="onInput"
          data-field="detailGuideTip"
          auto-height
        />
        <text class="textarea-count">{{form.detailGuideTip.length}}/300</text>
      </view>
      </view>
    </view>

    <button class="next-btn" bindtap="onNextStep">下一步：填写联系方式</button>
  </view>

  <!-- Step 2: 联系方式 -->
  <view wx:if="{{currentStep === 2}}" class="form-section">
    <view class="form-card">
      <text class="form-section-title">👤 房东信息</text>
      <view class="info-notice">
        <text class="notice-icon">🔒</text>
        <text class="notice-text">平台已有3年沉淀、服务1000+真实租客，专注罗湖直租，坚持免中介费和真实房源，联系方式用于直连高意向租客。</text>
      </view>

      <view class="prefill-landlord-btn" bindtap="onPrefillLandlordInfo">
        一键填充：孙先生 · 13520174107 · weixin123
      </view>

      <view class="form-item required">
        <text class="form-label">您的姓名</text>
        <input
          class="form-input"
          placeholder="请输入您的姓名/称呼"
          value="{{form.landlordName}}"
          bindinput="onInput"
          data-field="landlordName"
        />
      </view>

      <view class="form-item required">
        <text class="form-label">联系电话</text>
        <input
          class="form-input"
          placeholder="请输入手机号"
          type="number"
          maxlength="11"
          value="{{form.landlordPhone}}"
          bindinput="onInput"
          data-field="landlordPhone"
        />
      </view>

      <view class="form-item required">
        <text class="form-label">微信号</text>
        <input
          class="form-input"
          placeholder="请输入微信号，租客可直接添加"
          value="{{form.landlordWechat}}"
          bindinput="onInput"
          data-field="landlordWechat"
        />
      </view>
    </view>

    <view class="form-card">
      <text class="form-section-title">🔖 出租状态</text>
      <view class="switch-row">
        <text class="switch-label">当前状态</text>
        <view class="status-options">
          <view
            class="status-opt {{form.available ? 'opt-active' : ''}}"
            bindtap="onInput"
            data-field="available"
            data-value="true"
          >可租</view>
          <view
            class="status-opt {{!form.available ? 'opt-rented' : ''}}"
            bindtap="onInput"
            data-field="available"
            data-value="false"
          >已租</view>
        </view>
      </view>
    </view>

    <view class="step-buttons">
      <button class="prev-btn" bindtap="onPrevStep">上一步</button>
      <button class="next-btn flex1" bindtap="onNextStep">{{isEditMode ? '下一步：保存预览' : '下一步：预览'}}</button>
    </view>
  </view>

  <!-- Step 3: 预览确认 -->
  <view wx:if="{{currentStep === 3}}" class="form-section">
    <view class="preview-header">
      <text class="preview-title">📋 {{isEditMode ? '编辑预览' : '发布预览'}}</text>
      <text class="preview-sub">{{isEditMode ? '确认信息无误后保存修改' : '确认信息无误后发布'}}</text>
    </view>

    <!-- 预览卡片 -->
    <view class="preview-card">
      <!-- 图片预览 -->
      <view class="preview-images" wx:if="{{form.images.length > 0}}">
        <scroll-view scroll-x class="img-scroll">
          <view class="img-list">
            <image
              wx:for="{{form.images}}"
              wx:key="index"
              src="{{item}}"
              class="preview-img"
              mode="aspectFill"
            />
          </view>
        </scroll-view>
      </view>
      <view wx:else class="preview-no-img">
        <text>🏠</text>
        <text>{{form.neighborhood || '待填写小区名称'}}</text>
      </view>

      <view class="preview-body">
        <!-- 价格 -->
        <view class="preview-price-row">
          <text class="preview-price">{{form.price || '?'}}</text>
          <text class="preview-price-unit">元/月</text>
        </view>

        <!-- 标题 -->
        <text class="preview-house-title">
          {{form.title || (form.neighborhood + ' ' + form.roomType + ' ' + form.decoration + ' 出租')}}
        </text>

        <!-- 基本参数 -->
        <view class="preview-params">
          <text class="param">{{form.roomType || '-'}}</text>
          <text class="param-dot">·</text>
          <text class="param">{{form.buildingAttribute || '-'}}</text>
          <text class="param-dot">·</text>
          <text class="param">{{form.area || '-'}}㎡</text>
          <text class="param-dot">·</text>
          <text class="param">{{form.floor || '-'}}</text>
          <text class="param-dot">·</text>
          <text class="param">{{form.orientation || '-'}}</text>
        </view>

        <!-- 位置 -->
        <text class="preview-location">📍 {{form.neighborhood}} {{form.district}}</text>
        <text class="preview-location-detail" wx:if="{{form.locationName || form.address}}">
          {{form.locationName || ''}} {{form.address || ''}}
        </text>

        <!-- 标签 -->
        <view class="preview-tags" wx:if="{{form.tags.length > 0}}">
          <text class="tag" wx:for="{{form.tags}}" wx:key="index">{{item}}</text>
        </view>

        <view class="preview-neighborhood-extra" wx:if="{{form.detailGuideTitle || form.detailGuideSummary || form.detailGuideContent || form.detailGuideTip}}">
          <text class="preview-extra-title">详情页展开说明</text>
          <text class="preview-extra-text" wx:if="{{form.detailGuideTitle}}">标题：{{form.detailGuideTitle}}</text>
          <text class="preview-extra-text" wx:if="{{form.detailGuideSummary}}">概述：{{form.detailGuideSummary}}</text>
          <text class="preview-extra-text" wx:if="{{form.detailGuideContent}}">正文：{{form.detailGuideContent}}</text>
          <text class="preview-extra-text" wx:if="{{form.detailGuideTip}}">提醒：{{form.detailGuideTip}}</text>
        </view>

        <view class="preview-divider"></view>

        <!-- 房东信息 -->
        <view class="preview-landlord">
          <view class="landlord-left">
            <view class="preview-avatar">👤</view>
            <view>
              <text class="preview-landlord-name">{{form.landlordName}}</text>
              <text class="preview-landlord-badge">直租房东</text>
            </view>
          </view>
          <view class="preview-contact">
            <text class="contact-phone">📞 {{form.landlordPhone}}</text>
            <text class="contact-wechat">💬 {{form.landlordWechat}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="step-buttons">
      <button class="prev-btn" bindtap="onPrevStep">修改</button>
      <button
        class="submit-btn flex1"
        bindtap="onSubmit"
        loading="{{submitting}}"
        disabled="{{submitting}}"
      >{{isEditMode ? '保存修改' : '🚀 立即发布'}}</button>
    </view>
  </view>

  <view style="height: 60rpx;"></view>
</scroll-view>
