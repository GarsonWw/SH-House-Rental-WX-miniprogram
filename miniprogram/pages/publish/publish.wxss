/* pages/publish/publish.wxss */

/* 视频上传 */
.video-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.video-tip { font-size: 22rpx; color: #BBB; }

.add-video-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: #F5F6FA; border: 2rpx dashed #CCCCCC; border-radius: 16rpx;
  height: 200rpx;
}
.add-video-icon { font-size: 56rpx; color: #BBBBBB; margin-bottom: 10rpx; }
.add-video-text { font-size: 28rpx; color: #666; font-weight: 600; }
.add-video-hint { font-size: 22rpx; color: #BBBBBB; margin-top: 6rpx; }

.video-preview-wrap { position: relative; }
.preview-video {
  width: 100%; height: 360rpx; border-radius: 12rpx; display: block;
}
.video-delete-btn {
  display: flex; align-items: center; justify-content: center;
  margin-top: 16rpx; padding: 12rpx;
  background: #FFF2F2; border-radius: 10rpx;
}
.vd-icon { font-size: 24rpx; color: #FF3B30; margin-right: 8rpx; }
.vd-text { font-size: 24rpx; color: #FF3B30; }
.page-container {
  height: 100vh;
  background: #F5F5F5;
}

/* 步骤指示器 */
.step-indicator {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 40rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 3rpx solid #DDDDDD;
  color: #BBBBBB;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 60rpx;
  background: #FFFFFF;
  transition: all 0.3s;
}

.step.active .step-circle {
  border-color: #FF6B35;
  color: #FF6B35;
}

.step.done .step-circle {
  border-color: #FF6B35;
  background: #FF6B35;
  color: #FFFFFF;
}

.step-label {
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 8rpx;
}

.step.active .step-label,
.step.done .step-label {
  color: #FF6B35;
}

.step-line {
  flex: 1;
  height: 3rpx;
  background: #EEEEEE;
  margin: 0 16rpx;
  margin-bottom: 28rpx;
  transition: all 0.3s;
}

.step-line.done {
  background: #FF6B35;
}

/* 表单区 */
.form-section {
  padding: 20rpx 24rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.form-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222222;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

/* 图片上传 */
.image-upload-grid {
  display: flex;
  flex-wrap: wrap;
}

.image-upload-grid .img-item,
.image-upload-grid .add-img-btn {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.img-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.uploaded-img {
  width: 180rpx;
  height: 180rpx;
}

.img-delete {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 40rpx;
}

.add-img-btn {
  width: 180rpx;
  height: 180rpx;
  border: 3rpx dashed #DDDDDD;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 56rpx;
  color: #CCCCCC;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #BBBBBB;
  margin-top: 8rpx;
}

.add-hint {
  font-size: 20rpx;
  color: #CCCCCC;
  margin-top: 4rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 12rpx;
}

.form-item.required .form-label::before {
  content: '* ';
  color: #FF6B35;
}

.form-input {
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  width: 100%;
}

.input-with-unit {
  display: flex;
  align-items: center;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding-right: 20rpx;
}

.input-with-unit .form-input {
  background: transparent;
  flex: 1;
}

.input-unit {
  font-size: 26rpx;
  color: #999999;
  flex-shrink: 0;
}

.location-picker {
  min-height: 88rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.location-picker-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.location-picker-placeholder,
.location-picker-value {
  font-size: 28rpx;
  line-height: 1.4;
}

.location-picker-placeholder {
  color: #BBBBBB;
}

.location-picker-value {
  color: #333333;
  font-weight: 600;
}

.location-picker-sub {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
  margin-top: 6rpx;
}

.location-picker-action {
  flex-shrink: 0;
  margin-left: 20rpx;
  color: #FF6B35;
  font-size: 26rpx;
  font-weight: 700;
}

/* 选择器 */
.picker-view {
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #BBBBBB;
}

.picker-value {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #BBBBBB;
}

/* 标签网格 */
.tags-grid {
  display: flex;
  flex-wrap: wrap;
}

.tags-grid .tag-option {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.tag-option {
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666666;
  background: #F5F5F5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-option.selected {
  background: #FFF3EE;
  color: #FF6B35;
  border-color: #FF6B35;
  font-weight: 600;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.6;
}

.small-textarea {
  min-height: 120rpx;
}

.textarea-count {
  font-size: 22rpx;
  color: #BBBBBB;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* 提示 */
.info-notice {
  background: #FFF8F5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.notice-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #FF6B35;
}

.prefill-landlord-btn {
  background: #F0F7FF;
  color: #2B6FD9;
  border: 2rpx solid #CFE2FF;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  text-align: center;
}

/* 出租状态 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-label {
  font-size: 28rpx;
  color: #333333;
}

.status-options {
  display: flex;
}

.status-options .status-opt {
  margin-right: 16rpx;
}

.status-opt {
  padding: 12rpx 36rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #999999;
  background: #F5F5F5;
  border: 2rpx solid transparent;
}

.status-opt.opt-active {
  background: #EEFFF5;
  color: #2ECC71;
  border-color: #2ECC71;
  font-weight: 600;
}

.status-opt.opt-rented {
  background: #F5F5F5;
  color: #999999;
  border-color: #CCCCCC;
}

/* 按钮 */
.next-btn {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  width: 100%;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.35);
  margin-top: 8rpx;
}

.next-btn::after {
  border: none;
}

.step-buttons {
  display: flex;
  margin-top: 8rpx;
}

.step-buttons .prev-btn {
  margin-right: 20rpx;
}

.prev-btn {
  background: #F5F5F5;
  color: #666666;
  border-radius: 50rpx;
  border: none;
  font-size: 28rpx;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 40rpx;
}

.prev-btn::after {
  border: none;
}

.flex1 {
  flex: 1;
}

.submit-btn {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  color: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.35);
}

.submit-btn::after {
  border: none;
}

/* 预览 */
.preview-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.preview-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #222222;
  display: block;
}

.preview-sub {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.preview-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  margin-bottom: 24rpx;
}

.preview-images {
  height: 300rpx;
}

.img-scroll {
  height: 300rpx;
  white-space: nowrap;
}

.img-list {
  display: flex;
}

.preview-img {
  width: 400rpx;
  height: 300rpx;
  display: inline-block;
  margin-right: 4rpx;
}

.preview-no-img {
  height: 240rpx;
  background: linear-gradient(135deg, #FFE5D9, #FFD1BA);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
}

.preview-no-img text:last-child {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 600;
  margin-top: 12rpx;
}

.preview-body {
  padding: 24rpx;
}

.preview-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.preview-price {
  font-size: 52rpx;
  font-weight: 800;
  color: #FF6B35;
}

.preview-price-unit {
  font-size: 24rpx;
  color: #FF6B35;
  margin-left: 6rpx;
}

.preview-house-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.preview-params {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.param {
  font-size: 24rpx;
  color: #666666;
}

.param-dot {
  color: #DDDDDD;
  margin: 0 8rpx;
  font-size: 24rpx;
}

.preview-location {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 6rpx;
}

.preview-location-detail {
  font-size: 22rpx;
  color: #AAAAAA;
  display: block;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.preview-neighborhood-extra {
  background: #F8FAFF;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
}

.preview-extra-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #2B6FD9;
  display: block;
  margin-bottom: 8rpx;
}

.preview-extra-text {
  font-size: 23rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-top: 4rpx;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  background: #FFF3EE;
  color: #FF6B35;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.preview-divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 16rpx 0;
}

.preview-landlord {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.landlord-left {
  display: flex;
  align-items: center;
}

.preview-avatar {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  background: #FFF3EE;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 80rpx;
  margin-right: 16rpx;
}

.preview-landlord-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.preview-landlord-badge {
  font-size: 20rpx;
  color: #2ECC71;
  display: block;
  margin-top: 4rpx;
}

.preview-contact {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.contact-phone,
.contact-wechat {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}
