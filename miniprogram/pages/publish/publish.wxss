/* pages/publish/publish.wxss */

/* 视频上传 */
.video-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.video-tip { font-size: 22rpx; color: #BBB; }

.add-video-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: #F4F1EA; border: 2rpx dashed #C9C0B4; border-radius: 16rpx;
  height: 200rpx;
}
.add-video-icon { font-size: 56rpx; color: #A8A196; margin-bottom: 10rpx; }
.add-video-text { font-size: 28rpx; color: #666; font-weight: 600; }
.add-video-hint { font-size: 22rpx; color: #A8A196; margin-top: 6rpx; }

.video-preview-wrap { position: relative; }
.preview-video {
  width: 100%; height: 360rpx; border-radius: 12rpx; display: block;
}
.video-delete-btn {
  display: flex; align-items: center; justify-content: center;
  margin-top: 16rpx; padding: 12rpx;
  background: #F7ECE7; border-radius: 10rpx;
}
.vd-icon { font-size: 24rpx; color: #A64B3C; margin-right: 8rpx; }
.vd-text { font-size: 24rpx; color: #A64B3C; }
.page-container {
  height: 100vh;
  background: #F4F1EA;
}

/* 步骤指示器 */
.step-indicator {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 40rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 3rpx solid #D8D1C7;
  color: #A8A196;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 60rpx;
  background: #FFFFFF;
  transition: all 0.3s;
}

.step.active .step-circle {
  border-color: #0F2F4A;
  color: #0F2F4A;
}

.step.done .step-circle {
  border-color: #0F2F4A;
  background: #0F2F4A;
  color: #FFFFFF;
}

.step-label {
  font-size: 22rpx;
  color: #A8A196;
  margin-top: 8rpx;
}

.step.active .step-label,
.step.done .step-label {
  color: #0F2F4A;
}

.step-line {
  flex: 1;
  height: 3rpx;
  background: #E6E0D8;
  margin: 0 16rpx;
  margin-bottom: 28rpx;
  transition: all 0.3s;
}

.step-line.done {
  background: #0F2F4A;
}

/* 表单区 */
.form-section {
  padding: 20rpx 24rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.form-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #171512;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F4F1EA;
}

/* 图片上传 */
.image-upload-grid {
  display: flex;
  flex-wrap: wrap;
}

.image-upload-grid .img-item,
.image-upload-grid .add-img-btn {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.img-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.uploaded-img {
  width: 180rpx;
  height: 180rpx;
}

.img-delete {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 40rpx;
}

.add-img-btn {
  width: 180rpx;
  height: 180rpx;
  border: 3rpx dashed #D8D1C7;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 56rpx;
  color: #C9C0B4;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #A8A196;
  margin-top: 8rpx;
}

.add-hint {
  font-size: 20rpx;
  color: #C9C0B4;
  margin-top: 4rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #4F4A43;
  display: block;
  margin-bottom: 12rpx;
}

.form-item.required .form-label::before {
  content: '* ';
  color: #0F2F4A;
}

.form-input {
  height: 88rpx;
  background: #F8F6F1;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #27241F;
  width: 100%;
}

.input-with-unit {
  display: flex;
  align-items: center;
  background: #F8F6F1;
  border-radius: 12rpx;
  padding-right: 20rpx;
}

.input-with-unit .form-input {
  background: transparent;
  flex: 1;
}

.input-unit {
  font-size: 26rpx;
  color: #7A746B;
  flex-shrink: 0;
}

.location-picker {
  min-height: 88rpx;
  background: #F8F6F1;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.location-picker-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.location-picker-placeholder,
.location-picker-value {
  font-size: 28rpx;
  line-height: 1.4;
}

.location-picker-placeholder {
  color: #A8A196;
}

.location-picker-value {
  color: #27241F;
  font-weight: 600;
}

.location-picker-sub {
  font-size: 22rpx;
  color: #7A746B;
  line-height: 1.4;
  margin-top: 6rpx;
}

.location-picker-action {
  flex-shrink: 0;
  margin-left: 20rpx;
  color: #0F2F4A;
  font-size: 26rpx;
  font-weight: 700;
}

/* 选择器 */
.picker-view {
  height: 88rpx;
  background: #F8F6F1;
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #A8A196;
}

.picker-value {
  font-size: 28rpx;
  color: #27241F;
}

.picker-arrow {
  font-size: 36rpx;
  color: #A8A196;
}

/* 标签网格 */
.tags-grid {
  display: flex;
  flex-wrap: wrap;
}

.tags-grid .tag-option {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.tag-option {
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #4F4A43;
  background: #F4F1EA;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag-option:active {
  transform: scale(0.96);
}

.tag-option.selected {
  background: #0F2F4A;
  color: #FFFFFF;
  border-color: #0F2F4A;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(15,47,74,0.18);
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F8F6F1;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #27241F;
  box-sizing: border-box;
  line-height: 1.6;
}

.small-textarea {
  min-height: 120rpx;
}

.textarea-count {
  font-size: 22rpx;
  color: #A8A196;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

.field-helper {
  display: block;
  font-size: 23rpx;
  color: #7A746B;
  line-height: 1.6;
  background: #FAF7F1;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  margin: 0 0 24rpx;
}

.field-helper.compact {
  margin: 8rpx 0 0;
  padding: 0;
  background: transparent;
}

.advanced-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.advanced-toggle {
  flex-shrink: 0;
  margin-left: 20rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  color: #111111;
  background: #DDF5F8;
  font-size: 24rpx;
  font-weight: 800;
}

.neighborhood-config-card {
  background: #F8F6F1;
  border: 2rpx solid #E5D8C4;
  border-radius: 14rpx;
  padding: 22rpx;
  margin-bottom: 28rpx;
}

.config-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F4C75;
  display: block;
}

.config-sub {
  font-size: 22rpx;
  color: #6B7A90;
  line-height: 1.5;
  display: block;
  margin: 8rpx 0 24rpx;
}

/* 提示 */
.info-notice {
  background: #FAF7F1;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.notice-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #0F2F4A;
}

.prefill-landlord-btn {
  background: #EAF1F6;
  color: #0F4C75;
  border: 2rpx solid #C9D8E3;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  text-align: center;
}

/* 出租状态 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-label {
  font-size: 28rpx;
  color: #27241F;
}

.status-options {
  display: flex;
}

.status-options .status-opt {
  margin-right: 16rpx;
}

.status-opt {
  padding: 12rpx 36rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #7A746B;
  background: #F4F1EA;
  border: 2rpx solid transparent;
}

.status-opt.opt-active {
  background: #EAF6EF;
  color: #2E7D5B;
  border-color: #2E7D5B;
  font-weight: 600;
}

.status-opt.opt-rented {
  background: #F4F1EA;
  color: #7A746B;
  border-color: #C9C0B4;
}

/* 按钮 */
.next-btn {
  background: linear-gradient(135deg, #0F2F4A, #1C4966);
  color: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  width: 100%;
  box-shadow: 0 4rpx 16rpx rgba(15, 47, 74, 0.24);
  margin-top: 8rpx;
}

.next-btn::after {
  border: none;
}

.step-buttons {
  display: flex;
  margin-top: 8rpx;
}

.step-buttons .prev-btn {
  margin-right: 20rpx;
}

.prev-btn {
  background: #F4F1EA;
  color: #4F4A43;
  border-radius: 50rpx;
  border: none;
  font-size: 28rpx;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 40rpx;
}

.prev-btn::after {
  border: none;
}

.flex1 {
  flex: 1;
}

.submit-btn {
  background: linear-gradient(135deg, #0F2F4A, #1C4966);
  color: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 47, 74, 0.24);
}

.submit-btn::after {
  border: none;
}

/* 预览 */
.preview-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.preview-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171512;
  display: block;
}

.preview-sub {
  font-size: 24rpx;
  color: #7A746B;
  margin-top: 8rpx;
  display: block;
}

.preview-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  margin-bottom: 24rpx;
}

.preview-images {
  height: 300rpx;
}

.img-scroll {
  height: 300rpx;
  white-space: nowrap;
}

.img-list {
  display: flex;
}

.preview-img {
  width: 400rpx;
  height: 300rpx;
  display: inline-block;
  margin-right: 4rpx;
}

.preview-no-img {
  height: 240rpx;
  background: linear-gradient(135deg, #EFE3D0, #D9C19F);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
}

.preview-no-img text:last-child {
  font-size: 28rpx;
  color: #0F2F4A;
  font-weight: 600;
  margin-top: 12rpx;
}

.preview-body {
  padding: 24rpx;
}

.preview-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.preview-price {
  font-size: 52rpx;
  font-weight: 800;
  color: #0F2F4A;
}

.preview-price-unit {
  font-size: 24rpx;
  color: #0F2F4A;
  margin-left: 6rpx;
}

.preview-house-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #171512;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.preview-params {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.param {
  font-size: 24rpx;
  color: #4F4A43;
}

.param-dot {
  color: #D8D1C7;
  margin: 0 8rpx;
  font-size: 24rpx;
}

.preview-location {
  font-size: 24rpx;
  color: #7A746B;
  display: block;
  margin-bottom: 6rpx;
}

.preview-location-detail {
  font-size: 22rpx;
  color: #AAAAAA;
  display: block;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.preview-neighborhood-extra {
  background: #F8F6F1;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
}

.preview-extra-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #0F4C75;
  display: block;
  margin-bottom: 8rpx;
}

.preview-extra-text {
  font-size: 23rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-top: 4rpx;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  background: #F4EFE6;
  color: #0F2F4A;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}

.preview-divider {
  height: 1rpx;
  background: #F4F1EA;
  margin: 16rpx 0;
}

.preview-landlord {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.landlord-left {
  display: flex;
  align-items: center;
}

.preview-avatar {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  background: #F4EFE6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 80rpx;
  margin-right: 16rpx;
}

.preview-landlord-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #27241F;
  display: block;
}

.preview-landlord-badge {
  font-size: 20rpx;
  color: #2E7D5B;
  display: block;
  margin-top: 4rpx;
}

.preview-contact {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.contact-phone,
.contact-wechat {
  font-size: 22rpx;
  color: #7A746B;
  margin-bottom: 4rpx;
}

/* 2026 UI refresh */
.page-bg,
.publish-page,
.page-container {
  background: #EFF8FB;
}

.form-card,
.preview-card,
.neighborhood-config-card,
.info-notice,
.preview-neighborhood-extra {
  border-radius: 34rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  box-shadow: 0 14rpx 36rpx rgba(39, 122, 139, 0.08);
  background: #FFFFFF;
}

.form-section-title,
.form-label,
.preview-house-title,
.preview-extra-title,
.config-title,
.preview-landlord-name {
  color: #111111;
}

.config-sub,
.field-helper,
.preview-extra-text,
.contact-phone,
.contact-wechat,
.preview-location,
.preview-location-detail,
.textarea-count {
  color: #667A82;
}

.field-helper,
.form-input,
.form-textarea,
.picker-view,
.location-picker,
.preview-no-img,
.preview-neighborhood-extra {
  background: #F5FCFD;
  border-radius: 28rpx;
  border-color: rgba(17, 17, 17, 0.06);
}

.next-btn,
.submit-btn,
.prefill-landlord-btn,
.status-opt.opt-active,
.tag-option.selected {
  background: #28B8BC;
  color: #FFFFFF;
  border-color: #28B8BC;
  border-radius: 999rpx;
  box-shadow: 0 14rpx 30rpx rgba(40, 184, 188, 0.22);
}

.tag-option,
.status-opt,
.preview-avatar,
.preview-landlord-badge,
.tag {
  border-radius: 999rpx;
  background: #DDF5F8;
  color: #111111;
  border-color: transparent;
}

.preview-price,
.preview-price-unit {
  color: #111111;
}

.info-notice {
  box-shadow: none;
  background: #F5FCFD;
}
